/* Per-tab id: sessionStorage is scoped per browser-tab and survives reloads of
   that same tab, which is exactly what we need so the server-side cache files
   (displayed.{id}.json, etc.) line up with this tab's view. */
(function() {
	swal.setDefaults({ customClass: "ca_sweetalert_open" });

	var key = "ca_tabId";
	var id = "";
	try { id = sessionStorage.getItem(key) || ""; } catch (e) {}
	if (!id) {
		try {
			id = (window.crypto && crypto.randomUUID) ? crypto.randomUUID()
				: (Date.now().toString(36) + Math.random().toString(36).slice(2));
		} catch (e) {
			id = Date.now().toString(36) + Math.random().toString(36).slice(2);
		}
		try { sessionStorage.setItem(key, id); } catch (e) {}
	}
	data.tabId = id;
})();

