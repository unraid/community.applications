            closeSidebar();
          },
          afterClose: function() {
            showSidebarApp(data.sidebarapppath,data.sidebarappname);
          }
        }
      });
      slideInSidebar();

      if (!data.caReadmoreTopLessBound) {
        data.caReadmoreTopLessBound = true;
        $("#sidenavContent").on("click", ".ca_readless_top", function(e) {
          e.preventDefault();
          e.stopPropagation();
          // This control sits right before the readmore section it controls.
          var $section = $(this).nextAll(".popup_readmore").first();
          if (!$section.length) return;
          // Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
          var $toggle = $section.nextAll(".readmore-js-toggle").first();
          if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
          if ($toggle.length) $toggle.trigger("click");
          else $section.readmore("toggle");
        });
      }

      $('.popup_readmore').readmore({
        maxHeight:250,
        moreLink:"<i class='ca_readmore fa fa-chevron-down'> <?=tr("SHOW MORE");?></i>",
        lessLink:"<i class='ca_readmore fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>",
        afterToggle:function(trigger, element, expanded) {
          var $el = $(element);
          if (!$el.hasClass("ReadmeSection")) return;
          $el.prev(".ca_readless_top").remove();
          if (!expanded) return;
          var topLess = "<i class='ca_readmore ca_readless_top fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>";
          $el.before(topLess);
        }
      })
      popUpChart(result);
      setupContext(result.supportContext,"#supportPopup");
      setupContext(result.actionsContext,"#actionsPopup");
        
      $(".betaPopupText,.popupTableLeft,.upgradePopupText,.installedPopupText").fitText(true);

      postNoSpin({action:'getLastUpdate',ID:result.ID},function(lastUpdate) {
        if (lastUpdate.lastUpdate) {
          $("#template"+result.ID).fadeOut("slow","linear",function() {
            $("#template"+result.ID).html(lastUpdate.lastUpdate);
            $("#template"+result.ID).fadeIn("slow");
          });
        }
      });
    })
}

function slideInSidebar() {
  $(".sidenav").addClass("sidenavShow").removeClass("sidenavHide");
  updateSidenavBackToTopVisibility();
}
function showRepoPopup(repository) {
  if ( !repository ) return;
  data.repository = repository;
  context.destroy("#supportPopup");
  context.destroy("#actionsPopup");
  var fromCard = false;

  if ( ! $(".sidenavShow").length ) {
    $.cookie("sidebarAppName","",{path:"/;SameSite=Lax"});
    $.cookie("sidebarAppPath","",{path:"/;SameSite=Lax"});
    var fromCard = true;
  }
  var sidebarAppName = $.cookie("sidebarAppName");
  var sidebarAppPath = $.cookie("sidebarAppPath");

  $("#sidenavContent").html($("#sidebarLoading").html());

  $(".nav-user.show").hide();

  post({action:'getRepoDescription',repository:repository},function(result) {
    $("#sidenavContent").html(result.description); 
    $(".sidenav").removeClass("sidenavHide").addClass("sidenavShow");
    if (!data.caReadmoreTopLessBound) {
      data.caReadmoreTopLessBound = true;
      $("#sidenavContent").on("click", ".ca_readless_top", function(e) {
        e.preventDefault();
        e.stopPropagation();
        // This control sits right before the readmore section it controls.
        var $section = $(this).nextAll(".popup_readmore").first();
        if (!$section.length) return;
        // Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
        var $toggle = $section.nextAll(".readmore-js-toggle").first();
        if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
        if ($toggle.length) $toggle.trigger("click");
        else $section.readmore("toggle");
      });
    }

    $('.popup_readmore').readmore({
      maxHeight:250,
      moreLink:"<i class='ca_readmore fa fa-chevron-down'> <?=tr("SHOW MORE");?></i>",
      lessLink:"<i class='ca_readmore fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>",
      afterToggle:function(trigger, element, expanded) {
        var $el = $(element);
        if (!$el.hasClass("ReadmeSection")) return;
        $el.prev(".ca_readless_top").remove();
        if (!expanded) return;
        var topLess = "<i class='ca_readmore ca_readless_top fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>";
        $el.before(topLess);
      }
    });
    if (fromCard) {
      $(".popUpBack").addClass("ca_hide");
    } else {
      $(".popUpBack").removeClass("ca_hide");
    }

    $('.screenshot').magnificPopup({
      type:'image',
      closeMarkup: "<span class='magnificPopup caButton'>"+tr("CLOSE")+"</span>",
      closeOnContentClick: true,
      removalDelay: 100,
      mainClass: 'mfp-fade',
      zoom: {
        enabled: true,
        duration: 500,
        easing: 'ease-in-out'
      },
      callbacks: {
        beforeOpen: function() {
          event.stopPropagation();
          closeSidebar();
        },
        afterClose: function() {
          $('body').removeClass("mfp-zoom-out-cur");
          $(".sidebar").show();
          $.cookie("sidebarAppName",sidebarAppName,{path:"/;SameSite=Lax"});
          $.cookie("sidebarAppPath",sidebarAppPath,{path:"/;SameSite=Lax"});
          showRepoPopup(data.repository);
        }
      }
    });
  });
}

function checkSortOrder() {
  var sortButton = false;
  $(".sortIcons").each(function() {
    if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
      sortButton = true;
    }
  });
  if ( !sortButton) {
    $(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
    post({action:"defaultSortOrder"},function(data) {
      $("#defaultSort").addClass("enabledIcon");
    });
  }
}

function initDockerSearch() {
  caClearHomeSectionSubtitle();
  dockerSearch(1);
  data.docker = "searching docker";
  data.section = "";
  data.selected_category = "";
  data.committedSearchFilter = "";
  $(".selectedMenu").removeClass("selectedMenu");
  $(".nonDockerSearch").removeClass("caMenuEnabled").addClass("caMenuDisabled");
  hideSortIcons();
  $(".subCategory").hide();
  caSyncSearchFilterCollapsed();
  caSyncHomeSearchSubtitle();
}

function dockerSearch(pageNumber) {
  caRestoreCommittedSearchIfDrafted();
  if (searchBoxAwesomplete) searchBoxAwesomplete.close();
  scrollToTop();
  $(".selectedMenu").removeClass("selectedMenu");
  $(".nonDockerSearch").removeClass("caMenuEnabled").addClass("caMenuDisabled");
  var filter = $('#searchBox').val();
  var dockerURL = "https://registry.hub.docker.com/search?q=" + filter;
  data.docker = "searching docker";
  $(".dockerSearch,.multi_installDiv").hide();
  $(".templateSearch").show();
 // $(".category").html(sprintf("<?tr("DockerHub Search for %s")?>",filter)+" <span id='pageNumber'></span>");
  post({action:'search_dockerhub',filter:filter,page:pageNumber},function(result) {
    data.committedSearchFilter = $.trim(String(filter || ""));
    caSyncHomeSearchSubtitle();
    updateDisplay(result.display);
    caSyncSearchFilterCollapsed();
  });
}

function dockerConvert(dockerID) {
  saveState();
  swal({
    title: "<?tr("Determine configuration?");?>",
    text: '<?tr('Would you like CA to attempt to determine any applicable paths, ports, and variables for the template?  This will entail performing a test installation of the container.  It will be automatically deleted after processing.  The container will not be started.');?>',
    html: true,
    type: 'info',
    showCancelButton: true,
    showConfirmButton: true,
    confirmButtonText: "<?tr('Yes');?>",
    cancelButtonText: "<?tr('No');?>"
  }, function (isConfirm) {
    if ( isConfirm ) {
      $("#sb-nav-close").css("visibility","hidden"); // Because docker install cannot be aborted so why allow window to close
      openBox('/plugins/<?=$plugin?>/scripts/dockerConvert.php?ID='+dockerID,"<?tr('Docker Test Install')?>",600,1100,true);
    } else {
      post({action:'convert_docker',ID:dockerID},function(result) {
        myCloseAlert();
        templateURL = "/Apps/AddContainer?xmlTemplate=default:" + $.trim(result.xml);
        openNewWindow(templateURL);
      });
    }
  });

}

var caSortMenuObserver = null;
function caInitializeSortMenu() {
  caRefreshSortMenu();
  if (caSortMenuObserver) {
    return;
  }
  var sortContainer = document.getElementById("sortIconOptions");
  if (!sortContainer) {
    return;
  }
  caSortMenuObserver = new MutationObserver(function() {
    caRefreshSortMenu();
  });
  caSortMenuObserver.observe(sortContainer, {
    subtree: true,
    attributes: true,
    attributeFilter: ["class"]
  });
}

function caRefreshSortMenu() {
  if (!$("#sortByButton").length) {
    return;
  }
  var $selectedSort = $(".sortIcons.enabledIcon").not(".startupMore").first();
  if (!$selectedSort.length) {
    $selectedSort = $("#defaultSort");
  }
  var selectedText = $.trim($selectedSort.text());
  $("#sortByButton").html(sprintf("<?tr("Sort By: %s");?>", selectedText));
  context.destroy("#sortByButton");
  context.attach("#sortByButton", getSortOpts());
}

function getSortOpts() {
  var sortOpts = [];
  $(".sortIcons").each(function() {
    var sortOption = this;
    var $sortOption = $(sortOption);
    var sortText = $.trim($sortOption.text());
    var isSelected = $sortOption.hasClass("enabledIcon") && !$sortOption.hasClass("startupMore");
    sortOpts.push({
      icon: isSelected ? "ca_fa-checkmark" : " ",
      text: isSelected ? "<span class='ca_green'>" + sortText + "</span>" : sortText,
      action: function() {
        $(sortOption).trigger("click");
      }
    });
  });
  return sortOpts;
}

function setupActionCentre() {
  // set up action centre - run in background without tying anything up
  var acBanner = false;
  $.post(execURL,{action:'enableActionCentre'},function(ret) {
    if ( ret.status == "action" ) {
      if ( !$(".actionCentre").is(":visible") ) {
        // Don't show banner for action centre if menu isn't visibile (Covers hamburger on mobile if scrolled down)
        if ( ! actionCentreRestoreState && $(".menuItems").is(":visible") ) {
          acBanner = addBannerWarning("<?tr("Action Centre Enabled");?>",false,true);
          setTimeout(function() {
            removeBannerWarning(acBanner);
          },10000);
        }
        $(".actionCentre").show();
      }
    } else
      $(".actionCentre").hide();
  });
}

function postCheckForUpdates() {
  setupActionCentre();
  $(".selectedMenu").click();
}

</script>