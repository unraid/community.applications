/* Build the .ca_templatesDisplay wrapper from structured display_data. The
   header may contain inline scripts (showSidebarApp / hideSortIcons / etc.);
   the trailing scripts string holds caRenderPageNavigation, which only
   updates data.* (no DOM target since we removed the paginator). jQuery's
   html() evaluates both as part of the assignment. */
/* Refresh the "displaying X - Y of Z" indicator in the search area. X..Y is
   the range of cards currently visible in the viewport (computed from scrollTop
   plus the live card layout); Z is data.totalApps, kept current by the
   caRenderPageNavigation script the server emits with each batch. Falls back
   to the loaded range when the layout signals aren't measurable, and hides
   itself on the home page / empty result. */
function caUpdateAlphaBar(entries) {
	data.alphaJump = null;
	data.alphaLastActive = null;
	var $bar = $("#caAlphaBar");
	if (!$bar.length) return;
	if (!$.isArray(entries) || !entries.length) {
		$bar.addClass("ca_hide").empty();
		return;
	}
	var ordered = entries.slice().sort(function(a, b) {
		return (parseInt(a && a.i, 10) || 0) - (parseInt(b && b.i, 10) || 0);
	}).map(function(e) { return { l: e.l, i: parseInt(e.i, 10) || 0 }; });
	data.alphaAll = ordered;
	// Keep every distinct letter; only the window-fit thinning below drops any.
	var kept = ordered.slice();
	var render = function(list) {
		var html = "";
		list.forEach(function(e) {
			var label = (e.l === "#") ? "#" : e.l.toUpperCase();
			html += "<span class='caAlphaLetter' data-letter='" + e.l + "' data-index='" + e.i + "'>" + label + "</span>";
		});
		$bar.html(html).removeClass("ca_hide");
		data.alphaShown = list;
	};
	render(kept);
	var avail = $bar[0].clientHeight || 0;
	var first = $bar.children().get(0);
	var letterH = first ? first.offsetHeight : 0;
	if (avail > 0 && letterH > 0) {
		var maxFit = Math.floor(avail / letterH);
		if (maxFit >= 1 && kept.length > maxFit) {
			var thinned = [];
			for (var n = 0; n < maxFit; n++) {
				var idx = Math.round((n * (kept.length - 1)) / Math.max(1, maxFit - 1));
				if (!thinned.length || thinned[thinned.length - 1].i !== kept[idx].i) {
					thinned.push(kept[idx]);
				}
			}
			render(thinned);
		}
		$bar.css("gap", Math.max(0, (avail - 27 * letterH) / 26) + "px");
	}
}

function caAlphaLetterFor(list, globalIndex) {
	if (!$.isArray(list) || !list.length) return null;
	var active = list[0].l;
	for (var k = 0; k < list.length; k++) {
		if (list[k].i <= globalIndex) active = list[k].l;
		else break;
	}
	return active;
}

function caUpdateAlphaActive(globalIndex) {
	var $bar = $("#caAlphaBar");
	if (!$bar.length || $bar.hasClass("ca_hide")) {
		$(".caSpacerHintLetter").text("");
		return;
	}
	var activeShown, exact;
	if (data.alphaJump) {
		activeShown = data.alphaJump;
		exact = data.alphaJump;
	} else {
		activeShown = caAlphaLetterFor(data.alphaShown, globalIndex);
		exact = caAlphaLetterFor(data.alphaAll, globalIndex);
	}
	$bar.find(".caAlphaLetter").removeClass("caAlphaActive");
	if (activeShown !== null) {
		$bar.find(".caAlphaLetter").filter(function() { return $(this).attr("data-letter") === activeShown; }).addClass("caAlphaActive");
	}
	if (activeShown && data.alphaLastActive && activeShown !== data.alphaLastActive && data.alphaWheelActive) {
		caFlashAlphaLetter(activeShown);
	}
	data.alphaLastActive = activeShown;
	$(".caSpacerHintLetter").text(exact === null ? "" : (exact === "#" ? "#" : exact.toUpperCase()));
}

function caFlashAlphaLetter(letter) {
	var $bar = $("#caAlphaBar");
	if (!$bar.length || $bar.hasClass("ca_hide")) return;
	var $f = $("#caAlphaFlash");
	if (!$f.length) $f = $("<div id='caAlphaFlash' aria-hidden='true'></div>").appendTo("body");
	var $active = $bar.find(".caAlphaActive").first();
	var ref = ($active.length ? $active[0] : $bar[0]).getBoundingClientRect();
	var bar = $bar[0].getBoundingClientRect();
	$f.stop(true, true).text(letter === "#" ? "#" : letter.toUpperCase()).css({ display: "block", opacity: 1 });
	$f.css({ top: (ref.top + ref.height / 2 - $f.outerHeight() / 2) + "px", right: (window.innerWidth - bar.left + 8) + "px", left: "auto" });
	clearTimeout(data.alphaFlashTimer);
	data.alphaFlashTimer = setTimeout(function() { $("#caAlphaFlash").fadeOut(250); }, 1500);
}

function caJumpToLetter(letter) {
	if (!letter) return;
	caCardCache.generation = (caCardCache.generation || 0) + 1;
	data.loadingMore = false;
	var jumpGen = caCardCache.generation;
	post({ action: "jumpToLetter", letter: letter, maxPerPage: data.maxPerPage, selected: data.selected }, function(result) {
		if ((caCardCache.generation || 0) !== jumpGen) return;
		var dd = result.display_data || result.display;
		var G = parseInt(result.index, 10);
		if (!dd || isNaN(G) || G < 0) return;
		if (dd.pageNumber) data.currentpage = parseInt(dd.pageNumber, 10) || 1;
		updateDisplay(dd, false);
		var ma = $(".mainArea")[0];
		var $c = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
		var off = parseInt(caCardCache.offset, 10) || 0;
		var idxInPage = G - off;
		if (ma && $c.length && idxInPage >= 0 && idxInPage < $c.length) {
			ma.scrollTop = $c[idxInPage].getBoundingClientRect().top - ma.getBoundingClientRect().top + ma.scrollTop;
		} else {
			scrollToTop();
		}
		data.alphaJump = letter;
		caUpdateAlphaActive(G);
	});
}

function caUpdateDisplayCount() {
	var $el = $(".ca_displayCount");
	if (!$el.length) return;
	var loaded = $.isArray(caCardCache.cache) ? caCardCache.cache.length : 0;
	var total = parseInt(data.totalApps, 10) || 0;
	var committed = $.trim(String(data.committedSearchFilter || ""));
	/* The caShowInApps single template view also carries an ALL RESULTS
	   affordance. One click runs a normal Apps search for the box term, even
	   though only one card is present. It is detected by the subtitle override
	   still belonging to the current committed term, the same signal the
	   subtitle uses, so it self clears the moment the user searches or navigates. */
	var inShowInApps = !!(data.committedSearchSubtitleFor && data.committedSearchSubtitleFor === committed);
	if ((total < 2 && !inShowInApps) || loaded === 0) {
		$el.empty().hide();
		return;
	}

	var offset = parseInt(caCardCache.offset, 10) || 0;
	var first = offset + 1;
	var last = Math.min(offset + loaded, total);

	var mainArea = $(".mainArea")[0];
	var $cards = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
	/* Same row math as the random-access jump (caVirtScrollRow), so the "X - Y of
	   Z" the user reads is exactly the position the jump will fetch and land on -
	   correct whether the viewport is on loaded cards or being dragged over an
	   empty spacer, with no clamp to the loaded edge while scrubbing. */
	var posDC = (typeof caVirtScrollRow === "function") ? caVirtScrollRow(mainArea, $cards, total) : null;
	if (posDC) {
		first = (posDC.topRow * posDC.perRow) + 1;
		last  = (posDC.topRow + posDC.rowsVisible) * posDC.perRow;
	}
	if (first > total) first = total;
	if (last > total) last = total;
	if (last < first) last = first;

	if (typeof caUpdateAlphaActive === "function") caUpdateAlphaActive(first - 1);

	var countText = first + " - " + last + " " + tr("of") + " " + total;
	/* Append an "ALL RESULTS" affordance when the user has narrowed search
	   via the "Limit search results" setting and a search is actually
	   active — one click to widen the current search. Skipped while the
	   one-shot override is already in effect, and on Docker Hub search
	   (different code path on the server, the setting doesn't apply). */
	var searchOn = !!(data.searchActive || data.searchFlag);
	var limitedByName = $("#caSettingsFlags").hasClass("ca_searchLimitToName");
	var isDockerSearch = !!data.docker;
	if (!isDockerSearch && (inShowInApps || (searchOn && limitedByName && !data.searchLimitOverride))) {
		var allTx = stripTags(tr("ALL RESULTS"));
		$el.html(
			$("<span></span>").text(countText).prop("outerHTML")
			+ " — "
			+ "<span class='caShowAllResults' role='button' tabindex='0'>"
			+ $("<span></span>").text(allTx).html()
			+ "</span>"
		).show();
	} else {
		$el.text(countText).show();
	}
}

/**
 * Replace `#templates_content` with a fresh `.ca_templatesDisplay` wrapper built from structured PHP payload (`header`, `cards`, trailing `scripts`).
 *
 * @param {object} content `{ header, cards[], scripts }`
 */
function caRenderStructuredFresh(content) {
	var html = "<div class='ca_templatesDisplay'>" +
		(content.header || "") +
		content.cards.join("") +
		(content.scripts || "") +
		"</div>";
	$("#templates_content").html(html);
}
/**
 * Paint server HTML or structured card payloads: maintains `caCardCache.cache` for virtualization, runs fitText, translation banner, and scroll affordances.
 *
 * @param {string|object} content HTML string or `{ cards, header, scripts, pageNumber, maxPerPage }`
 * @param {boolean} [append] Infinite-scroll append vs full replace
 */
function updateDisplay(content, append) {
	var isStructured = content && typeof content === "object" && $.isArray(content.cards);

	if (!append) caUpdateAlphaBar(isStructured ? content.alphaBar : null);

	if (isStructured) {
		if (append === "prepend") {
			/* Backfill: a page that sits immediately above the current cache.
			   Grow the cache at the front and shift the DOM-window pointers up by
			   the same count; the cards land in the cache only, and restore-above
			   (caVirtUpdate) pulls them into the DOM as the user keeps scrolling
			   up. Scripts are intentionally NOT re-evaluated — this is a backward
			   fetch and must not clobber forward pagination state (data.nextpage,
			   data.currentpage). */
			var $exP = $("#templates_content .ca_templatesDisplay").first();
			if ($exP.length && content.cards.length) {
				caCardCache.cache = content.cards.concat(caCardCache.cache);
				caCardCache.offset = Math.max(0, (parseInt(caCardCache.offset, 10) || 0) - content.cards.length);
				caCardCache.firstInDom += content.cards.length;
				caCardCache.lastInDom += content.cards.length;
			}
		} else if (append) {
			var $existing = $("#templates_content .ca_templatesDisplay").first();
			if ($existing.length) {
				for (var i = 0; i < content.cards.length; i++) {
					caCardCache.cache.push(content.cards[i]);
					$existing.append(content.cards[i]);
				}
				/* Appended cards become the new bottom of the DOM window. */
				caCardCache.lastInDom = caCardCache.cache.length - 1;
				/* Re-evaluate scripts (caRenderPageNavigation) so data.nextpage updates.
				   Detached-element .html() doesn't auto-eval scripts in jQuery, so pull
				   each <script> body out and pass it through $.globalEval. */
				if (content.scripts) {
					$("<div>").html(content.scripts).find("script").each(function() {
						$.globalEval(this.text || this.textContent || $(this).html() || "");
					});
				}
			} else {
				caRenderStructuredFresh(content);
			}
		} else {
			caCardCache.cache = content.cards.slice();
			caCardCache.firstInDom = 0;
			caCardCache.lastInDom = caCardCache.cache.length - 1;
			var _pn  = parseInt(content.pageNumber, 10) || 1;
			var _ppg = parseInt(content.maxPerPage, 10) || data.maxPerPage || 12;
			caCardCache.offset = (_pn - 1) * _ppg;
			caRenderStructuredFresh(content);
		}
	} else {
		if (append) {
			var $existing = $("#templates_content .ca_templatesDisplay").first();
			if ($existing.length) {
				var $tmp = $("<div>").html(content);
				var $newChildren = $tmp.find(".ca_templatesDisplay").first().contents();
				$existing.append($newChildren);
			} else {
				$("#templates_content").html(content);
				caCardCache.firstInDom = 0;
				caCardCache.lastInDom = -1;
				caCardCache.cache = [];
				caCardCache.offset = 0;
			}
		} else {
			$("#templates_content").html(content);
			caCardCache.firstInDom = 0;
			caCardCache.cache = [];
			caCardCache.offset = 0;
		}
	}
	data.loadingMore = false;
	caVirtUpdateTopSpacer();
	caVirtUpdateBottomSpacer();
	/* After a backfill, pull the just-cached rows into the DOM right away so a
	   user parked at the top boundary sees them without having to nudge-scroll. */
	if (append === "prepend" && typeof caVirtUpdate === "function") caVirtUpdate();
	caEnsureScrollable();
	/* A scrollbar jump requested while this fetch was in flight was coalesced to
	   a flag rather than queued. Now that the render is done, re-evaluate once
	   against the user's current scroll position (caReevaluateJump re-queues
	   itself if caEnsureScrollable above kicked off another fetch). */
	if (window.caJumpPending && typeof window.caReevaluateJump === "function") {
		window.caJumpPending = false;
		setTimeout(window.caReevaluateJump, 30);
	}
	caUpdateDisplayCount();
	if (typeof caUpdateScrollControls === "function") caUpdateScrollControls();
	enableSearch();

	$(".betaPopupText,.upgradePopupText,.LTOfficialPopupText").fitText(true);

	if ( $("html").hasClass("translated-ltr") || $("html").hasClass("translated-rtl") || $("head").hasClass("translated-ltr") || $("head").hasClass("translated-rtl") ) {
		data.translationBanner = addBannerWarning("<?=tr("Browser translation detected.  Display issues may result");?>");
	}	else {
		removeBannerWarning(data.translationBanner);
	}
//	saveState();

	if ( ! $(".startupButton").hasClass("selectedMenu") && ! data.docker && ! $("#templates_content .ca_templatesDisplay").length && ! $(".selectedMenu").length ) {
		$(".startupButton").addClass("selectedMenu");
	}
	if ( $(".ca_multiselect").length ) {
			$(".multi_installAll").attr("disabled",false);
	} else {
		$(".multi_installAll").attr("disabled",true);
	}
	myCloseAlert(true);
}
/* No `window.onbeforeunload` save hook. Two reasons:
   1. Unreliable — modern browsers throttle/skip unload events on mobile and
      during bfcache transitions; saves get cut off mid-write.
   2. Registering a beforeunload listener at all disables bfcache for this
      page, which makes the back button slow.
   We instead save proactively at the one place that matters: the top of
   showSidebarApp(). Sidebar-open is the gateway to every install /
   uninstall / update / xmlInstall path. */

/**
 * Read and validate the sessionStorage state snapshot. Returns the parsed
 * object on success or null when:
 *   - sessionStorage is unavailable (Safari private mode, etc.)
 *   - no snapshot has been taken yet
 *   - JSON.parse fails
 *   - schema version doesn't match (forwards-compat guard)
 *   - feed timestamp is missing on either side or has changed since the
 *     snapshot (stale render risk — templates may have been added/removed/
 *     recategorised under us). The strict "both present and equal" check
 *     stops a snapshot with feedMtime=0 (e.g. from a save taken before
 *     lastUpdated.json was readable) from bypassing the freshness gate.
 *
 * @returns {object|null}
 */
function caReadSavedState() {
	var raw;
	try { raw = sessionStorage.getItem("ca_state"); } catch (e) { return null; }
	if (!raw) return null;
	var s;
	try { s = JSON.parse(raw); } catch (e) { return null; }
	if (!s || s.v !== 1) return null;
	var savedMtime = parseInt(s.feedMtime, 10) || 0;
	var currentMtime = parseInt(window.caFeedMtime, 10) || 0;
	if (savedMtime <= 0 || currentMtime <= 0 || savedMtime !== currentMtime) {
		try { sessionStorage.removeItem("ca_state"); } catch (e) { /* no-op */ }
		return null;
	}
	return s;
}

/**
 * Serialize CA UI state into sessionStorage so the user lands on the same
 * search / filter / category / scroll position when they come back from
 * /Apps/AddContainer, plugin install, etc. Always called at the top of
 * showSidebarApp() — the one gateway every state-mutating action funnels
 * through.
 *
 * On the home / spotlight view there's no .ca_templatesDisplay grid to
 * meaningfully restore (content comes from .ca_homeTemplates rows which
 * don't line up with the templates_displayed cache refreshDisplay relies
 * on). For that case we save a `wasHome: true` marker plus the sidebar app
 * identity only — the bootstrap detects the marker and takes the
 * fresh-startup branch, then reopens the sidebar after the home paint
 * settles.
 *
 * @returns {void}
 */
function saveState() {
	if (data.ignoreUnload) return;
	var isHome = !$("#templates_content .ca_templatesDisplay").length;
	var state = {
		v: 1,
		feedMtime: window.caFeedMtime || 0,
		wasHome: isHome,
		sidebarAppPath: data.sidebarapppath || "",
		sidebarAppName: data.sidebarappname || "",
		/* Persist Docker Hub mode so `restoreState` can pick the right
		   top-bar chrome (Apps button + no sort icons vs DockerHub button
		   + sort icons). Without this every restore reverts to Apps-mode
		   chrome even when the user was mid-Docker-Hub-search. */
		dockerMode: !!data.docker,
	};
	if (!isHome) {
		state.filter        = $("#searchBox").val() || "";
		state.installMulti  = $(".multi_installDiv").is(":visible");
		state.selectedMenu  = $(".selectedMenu").data("category") || "";
		state.categoryName  = $(".categoryMenuName").html() || "";
		state.currentpage   = parseInt(data.currentpage, 10) || 1;
		var _ma = $(".mainArea")[0];
		state.scrollY       = _ma ? (_ma.scrollTop || 0) : 0;
	}
	try { sessionStorage.setItem("ca_state", JSON.stringify(state)); } catch (e) { /* no-op */ }
}

/**
 * Rehydrate the templates-view (search / filter / category / sort / scroll)
 * from a previously-saved state object. Only called by the bootstrap when
 * it's already decided we're in the templates-restore branch — the home
 * branch is handled inline at the bootstrap.
 *
 * @param {object} s validated state from caReadSavedState()
 * @returns {void}
 */
function restoreState(s) {
	/* Coming back to /Apps from anywhere — drop the docker info cache so
	   the restore renders against fresh container state. */
	if (typeof caDropInfoCache === "function") caDropInfoCache();
	caSessRemove("ca_languageSwitch");

	$(".multi_installDiv").toggle(!!s.installMulti);
	caCardCache.cache = [];
	caCardCache.firstInDom = 0;
	caCardCache.offset = 0;
	data.loadingMore = false;
	data.ignoreUnload = false;

	$("#searchBox").val(s.filter || "");
	data.committedSearchFilter = $.trim(s.filter || "");
	data.searchActive = (s.filter || "") !== "";
	/* Restore searchFlag too, not just searchActive. The category-menu click
	   handler clears the search box and committed term unless data.searchFlag is
	   set, so without this a category click after a restore drops back to the
	   full category instead of subsetting the restored search. */
	data.searchFlag = data.searchActive;

	/* Restore top-bar control visibility — the live search/install paths
	   show `#sortIconArea` and toggle the `.dockerSearch` / `.templateSearch`
	   buttons in their post-search callbacks, but on a fresh page-load
	   restore the DOM defaults (sort row hidden, both toggle buttons
	   carrying `ca_hide` from skin.html) are still in place. Branch on
	   the saved `dockerMode` flag so Docker Hub restores get Apps-toggle
	   chrome and Apps restores get DockerHub-toggle chrome (mirror of
	   the live search code below at L1683 for the Apps side, and of
	   initDockerSearch / changeSortOrder's docker-mode chrome for the
	   Docker side). */
	if (s.dockerMode) {
		/* Sticky-docker restore: signal subsequent doSearch calls to
		   keep traffic on Docker Hub instead of dropping back to the
		   app store. */
		data.docker = "searching docker";
		hideSortIcons();
		$('.dockerSearch').addClass("ca_hide");
		$('.templateSearch').removeClass("ca_hide");
	} else {
		showSortIcons();
		if (data.searchActive
		    && !dockerNotEnabled
		    && (s.filter || "").indexOf(" Repository") < 1) {
			$('.dockerSearch').removeClass("ca_hide");
		} else {
			$('.dockerSearch').addClass("ca_hide");
		}
		$('.templateSearch').addClass("ca_hide");
	}

	$(".categoryMenuName").html(s.categoryName || "");
	restoreStateMenu = s.selectedMenu || "";
	data.currentpage = parseInt(s.currentpage, 10) || 1;
	data.maxPerPage = getMaxPerPage();
	caSyncSearchFilterCollapsed();
	caSyncHomeSearchSubtitle();

	post({action:"getSortOrder"}, function(sortOrder) {
		$(".sortIcons").removeClass("enabledIcon");
		$(".sortIcons").each(function() {
			if ( ($(this).attr("data-sortBy") == sortOrder.sortBy) && ($(this).attr("data-sortDir") == sortOrder.sortDir) ) {
				$(this).addClass("enabledIcon");
			}
		});
		populateAutoComplete(function() {
			/* Two awesomplete instances on the page:
			     - inlineSearchAwesomplete = desktop horizontal strip (minChars=2,
			       always visible alongside the search input)
			     - searchBoxAwesomplete    = mobile modal dropdown (minChars=3,
			       only renders while the search modal is open)
			   For a restore we just want each to re-evaluate against the
			   restored query at its NATIVE threshold — the inline strip
			   then repopulates with chips on desktop, and the mobile
			   dropdown stays closed (its modal isn't open on restore
			   anyway). The mobile user opens the modal manually and the
			   suggestions appear as soon as they re-focus. */
			if (data.searchActive) {
				try {
					if (inlineSearchAwesomplete) inlineSearchAwesomplete.evaluate();
				} catch (e) { /* no-op */ }
			}
		});
		if (!s.installMulti) clearMultiInstall();
		caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
	});
}



/**
 * Open the Credits panel in the alternate (sidenav) view via jQuery helper.
 */
function showCredits() {
	/* Credits is the root of this little view stack, so clear the back target -
	   no back arrow here, and outside-click closes (handled in the overlay
	   click via .popUpBack being hidden). */
	window.caSidebarBackTarget = "";
	$("#caCredits").showAlternateView();
}

/**
 * Open Settings in the alternate view and bind unsaved-change handlers on `.ca_settingsForm`.
 */
function showSettings() {
	const $content = $(".settingsContainer");
	$content.showAlternateView();
	const $sidenav = $("#sidenavContent");
	const $form = $sidenav.find(".ca_settingsForm");
	const initialFormState = $form.serialize();
	caBindSettingsFormHandlers(initialFormState);
}

/**
 * Expand mobile / hamburger chrome (`menuShowing` on `.menuAdjust`, `.hideWithMenu`, `.mobileMenu`).
 */
function showMenu() {
	$(".menuAdjust,.hideWithMenu,.mobileMenu").addClass("menuShowing").removeClass("menuHidden");
	/* Snap the menu scroll back to the top each time it opens — wherever the
	   user left it (after a long category list, etc.) shouldn't carry over. */
	$(".menuItems").scrollTop(0);
	/* Reset menu: hide any parent the user expanded but didn't pick from.
	   Branches with an active selection stay fully expanded. */
	caHideUnselectedSubs();
}

/**
 * Hide every `.subCategory` wrapper that doesn't contain `.selectedMenu`.
 * Wrappers with an active selection stay fully expanded — clicking another
 * parent never collapses the branch holding the current pick.
 *
 * @param {jQuery} [$keepOpen] Optional wrapper to leave visible regardless
 */
function caHideUnselectedSubs($keepOpen) {
	$(".subCategory").each(function() {
		var $sub = $(this);
		if ($keepOpen && $keepOpen.is && $keepOpen.is($sub)) return;
		if ($sub.find(".selectedMenu").length) return;
		if ($sub.is(":visible")) $sub.hide("fast");
	});
}

/* Back-compat alias for older call sites. */
function caCollapseUnselectedSubs($keepOpen) { caHideUnselectedSubs($keepOpen); }
function caNormalizeSubs($keepOpen) { caHideUnselectedSubs($keepOpen); }

/**
 * Collapse mobile menu when the close control is in the expanded state.
 */
function closeMenu() {
	if ( ! $(".closeMenuButton").hasClass("menuShowing") ) {
		return;
	}
	$(".menuAdjust,.hideWithMenu,.mobileMenu").addClass("menuHidden").removeClass("menuShowing");
}

/**
 * Fetch rendered changelog HTML (`caChangeLog`) and show it in the alternate view.
 */
function caChangeLog() {
	post({action:'caChangeLog'},function(result) {
		$(".caChanges").html(result.changelog);
		$("#caChangeLog").showAlternateView();
		/* Opened from Credits? showAlternateView hides .popUpBack by default;
		   bring it back so there's a top-left arrow to Credits (the handler in
		   clickHandlers.js routes it there when caSidebarBackTarget is credits). */
		if (window.caSidebarBackTarget === "credits") $(".popUpBack").removeClass("ca_hide");
	});
}

/**
 * Toggle a single sidebar menu item between enabled/disabled state by adding/
 * removing caMenuEnabled and caMenuDisabled. caMenuDisabled is what the
 * .sectionMenu click handler checks to swallow clicks on empty submenus.
 *
 * @param {string} category Value of the menu item's `data-category` attribute
 * @param {boolean} enabled True to enable, false to grey out and swallow clicks
 */
function caToggleMenuItem(category, enabled) {
	var $item = $(".caMenuItem[data-category='" + category + "']");
	if ( ! $item.length) return;
	if (enabled) {
		$item.removeClass("caMenuDisabled").addClass("caMenuEnabled");
	} else {
		$item.removeClass("caMenuEnabled").addClass("caMenuDisabled");
	}
}

/**
 * Pull the four Installed / Previous Apps submenu populations from the server
 * and grey out the submenu items that would render nothing — e.g. Installed
 * Apps > Docker is disabled when no containers are present (and therefore
 * also when docker itself is off, since collectDockerApplications short-
 * circuits to []). Cheap enough to call after every install/uninstall.
 */
function caRefreshInstalledMenuStates() {
	post({action:'installedAndPreviousCounts'}, function(result) {
		if ( ! result || ! result.counts) return;
		caToggleMenuItem("inst_docker",  result.counts.instDocker  > 0);
		caToggleMenuItem("inst_plugins", result.counts.instPlugins > 0);
		caToggleMenuItem("prev_docker",  result.counts.prevDocker  > 0);
		caToggleMenuItem("prev_plugins", result.counts.prevPlugins > 0);
	});
}

/**
 * Fetch favourite repository name from PHP and enable/disable `.favouriteRepo` menu + `data-repository`.
 */
function setFavRepoSearch() {
	post({action:'getFavourite'},function(result) {
		if (result.favourite) {
			$(".favouriteRepo").addClass("caMenuEnabled").removeClass("caMenuDisabled");
		} else {
			$(".favouriteRepo").addClass("caMenuDisabled").removeClass("caMenuEnabled");
		}
		$(".favouriteRepo").attr("data-repository",result.favourite);
	});
}

/**
 * Repaint category HTML from server, re-enable standard menu rows, sync favourite + pinned states, restore menu selection from cookies when applicable.
 */
function getCategories() {
	post({action:'get_categories'},function(result) {
		$("#category_list").html(result.categories);
		$(".subCategory").hide();
		$(".caMenuItem").each(function() {
			if ( ! ( $(this).hasClass("favouriteRepo") || $(this).hasClass("caPinnedMenu") ) ) {
				$(this).addClass("caMenuEnabled").removeClass("caMenuDisabled");
			}
		});
		/* Re-apply count-based gating on the Installed / Previous submenus
		   *after* the wholesale caMenuEnabled reset above, otherwise our
		   caMenuDisabled state gets clobbered when these two requests race. */
		caRefreshInstalledMenuStates();
		setFavRepoSearch();

		post({action:'areAppsPinned'},function(result) {
			if (!result.status) {
				$(".caPinnedMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
			} else {
				$(".caPinnedMenu").removeClass("caMenuDisabled").addClass("caMenuEnabled");
			}
		});

		if ( ! restoreStateMenu )
			restoreStateMenu = caLocalGet("ca_startupButton");

		caDebug(restoreStateMenu);
		var menuItem = $.find(".caMenuItem[data-category='"+restoreStateMenu+"']");
		/* Parent-with-subs and its auto-generated "All" sub share the same
		   data-category. Prefer the "All" sub so only it shows selectedMenu —
		   the parent itself is never a fetch target. */
		var $matched = $(menuItem);
		if ($matched.filter(".caCategoryAll").length) menuItem = $matched.filter(".caCategoryAll").get();
		$(".caMenuItem").each(function(){
			$(this).removeClass("selectedMenu");
		});
		$(menuItem).addClass("selectedMenu");
		$(menuItem).parent().show();
		$(menuItem).next().show();
		/* If the restored item is a sub-item nested inside a `<li class='subCategory'>`
		   wrapper (e.g. Media Servers → Photos), the immediate parent is the inner
		   `<ul>` — but the .subCategory wrapper is what's hidden by the wholesale
		   $(".subCategory").hide() above, and a visible `<ul>` inside a hidden
		   `<li>` still renders nothing. Show the wrapper so the branch the leaf
		   belongs to opens up. */
		$(menuItem).closest(".subCategory").show();
		restoreStateMenu = false;

		if ( $("#searchBox").val() ) {
			post({action:'getCategoriesPresent'},function(result) {
				$(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
				result.forEach(function(category) {
					var menuItem = $.find(".caMenuItem[data-category='"+category+"']");
					$(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
					document.referrer = "/Apps";
				});
				var selectedMenu = caLocalGet("ca_selectedMenu");
				if ( selectedMenu ) {
					var menuItem = $.find(".caMenuItem[data-category='"+selectedMenu+"']");
					var $matched = $(menuItem);
					if ($matched.filter(".caCategoryAll").length) {
						menuItem = $matched.filter(".caCategoryAll").get();
						$(menuItem).closest(".subCategory").show();
					}
					$(menuItem).addClass("selectedMenu");
				}	else
					$(".allApps").addClass("selectedMenu");

			});
		}
	});
}

// Function should no longer be required
function feedWarning(currentServer) {
	if ( currentServer != "Primary Server" ) {
		if ( currentServer == "" ) {
			addBannerWarning("<?tr("Unknown error happened.  Please post a screenshot in the support thread of the Statistics screen");?>");
		} else {
				if ( !backupServerWarning ) {
				backupServerWarning = addBannerWarning("<?tr("Backup Server Active.  Some icons may not appear, and plugin installations may be affected");?>",true,true);
			} else {
				removeBannerWarning(backupServerWarning);
				backupServerWarning = false;
			}
		}
	} else if ( backupServerWarning ) {
		removeBannerWarning(backupServerWarning);
		backupServerWarning = false;
	}
}


/**
 * Switch UI language: stash prior locale in cookie, POST `switchLanguage`, set `ca_languageSwitch`, reload.
 *
 * @param {string} language Target locale id (`en_US` clears override)
 */
function CAswitchLanguage(language) {
	if ( language == "en_US" || ! language)
		var oldlanguage = '<?=$locale?>';
	else
		var oldlanguage = "";

	data.searchActive = true; // so the system doesn't resort
	saveState();
	$.cookie('locale',oldlanguage,{path:"/;SameSite=Lax"}); // save the previous locale
	post({action:'switchLanguage',language:language},function(result) {
		caSessSet("ca_languageSwitch","switched");
		myCloseSpinner();
		window.location.reload();
	});
}

/**
 * Install a language pack via {@link ca_openPlugin} (`postLanguageRefresh` on success).
 *
 * @param {string} languageURL Pack URL/path for `language install`
 * @param {string} language Pack id for pending-row hiding
 */
function installLanguage(languageURL,language) {
	hideLanguagePending(language);
	disableSearch();
	ca_openPlugin('language install '+languageURL,"<?tr('Install Language Pack');?>",'','postLanguageRefresh');
}

/**
 * Update an installed language pack (cookie stores id for `postUpdateLanguage`).
 *
 * @param {string} language Pack basename/id
 */
function updateLanguage(language) {
	hideLanguagePending(language);
	disableSearch();
	caSessSet("updateLanguage",language);
	ca_openPlugin('language update '+language,"<?tr('Update Language Pack');?>",'','postUpdateLanguage');
}

/**
 * After language update: full reload if the active UI locale changed, else refresh Action Centre or sidebar + grid.
 */
function postUpdateLanguage() {
	var languageUpdate = caSessGet("updateLanguage");
	var currentLanguage = "<?=$_SESSION['locale']?>";

	if (languageUpdate == currentLanguage)
		window.location.reload();
	else {
		if ( $(".selectedMenu").data("category") == "action_centre" ) {
			actionCentre();
		} else {
			var apppath = caSessGet("sidebarAppPath");
			var appname = caSessGet("sidebarAppName");
			showSidebarApp(apppath,appname);
			refreshDisplay();
		}
	}
}
/**
 * Remove a language pack (`language remove` via {@link ca_openPlugin}).
 *
 * @param {string} language Pack id
 */
function removeLanguage(language) {
	hideLanguagePending(language);
	closeSidebar();
	ca_openPlugin('language remove '+language,"<?tr('Remove Language Pack');?>",'','postLanguageRemove');
}

/**
 * Reopen saved sidebar app (if any) and {@link refreshDisplay} after language install.
 */
function postLanguageRefresh() {
	var apppath = caSessGet("sidebarAppPath");
	var appname = caSessGet("sidebarAppName");
	if ( $.trim(apppath) ) {
		showSidebarApp(apppath,appname);
	}
	refreshDisplay();
}

/**
 * Refresh the current view after a language pack uninstall.
 *
 * The `trigger("click")` on selectedMenu re-fires the Action Centre handler
 * (its `.sectionMenu` binding has no already-selected guard, so it re-runs
 * actionCentre()). For every other category the `.caMenuItem`/`.categoryMenu`
 * handlers early-return on the already-selected item, so the click is a
 * no-op there — `refreshDisplay()` is what actually re-pulls
 * `display_content` and re-evaluates `Installed` server-side. Matches
 * postUninstallPlugin so card state stops going stale after uninstall.
 */
function postLanguageRemove() {
	enableSearch();
	$(".selectedMenu").trigger("click");
	setupActionCentre();
	refreshDisplay(); /* chains caRefreshInstalledMenuStates */
}

/**
 * Issue `openDocker` `update_container` for one container; Action Centre uses a different completion callback than the main store.
 *
 * @param {string} container Container id/path token understood by `openDocker`
 */
function updateDocker(container) {
	closeSidebar();
	$("#sb-nav-close").css("visibility","hidden"); // Because docker install cannot be aborted so why allow window to close
	if ( $(".selectedMenu").data("category") == "action_centre" ) {
		var postFunction = "actionCentre";
	} else {
		var postFunction = "refreshDisplay";
	}
	openDocker('update_container '+container,'<?tr('Update Application');?>','',postFunction);
}

/**
 * Refresh `title` tooltips on `.ca_fav` favourite/non-favourite icons from server-side repository naming.
 */
function setToolTipForFavourite() {
	$(".ca_fav").each(function(){
		if ( $(this).hasClass("ca_favouriteRepo") ) {
			$(this).attr("title","<?tr("Click to remove favourite repository");?>");
		} else {
			var repository = $(this).data("repository");
			repository = repository.replace("'s Repository","").replace("' Repository","").replace(" Repository","");
			$(this).attr("title",sprintf("<?tr("Click to set %s as favourite repository")?>",repository));
		}
	});
}

/**
 * Toggle favourite repository for a repo card: POST `toggleFavourite`, show transient banner, repaint backgrounds, {@link setFavRepoSearch}.
 *
 * @param {HTMLElement} button `.ca_fav` control with `data-repository`
 */
function setFavourite(button) {
	$(button).toggleClass("fav nonfav");
	var repo = $(button).data("repository");

	/* No transient banner: this is virtually always invoked from inside the
	   sidebar, where the modal scrim would dim the banner anyway. The
	   .favCardBackground repaint and the favourite-icon state change are
	   visible feedback enough. */
	post({action:'toggleFavourite',repository:repo},function(data) {
		$(".favCardBackground").each(function() {
			if ( $(this).data("repository") == data.fav.replace("'","") )
				$(this).addClass("favCardBackgroundShow").removeClass("favCardBackgroundHide");
			else
				$(this).removeClass("favCardBackgroundShow").addClass("favCardBackgroundHide");
		});
		setFavRepoSearch();
	});
}

/**
 * Run host port conflict checks, optionally ask to auto-adjust, then {@link installXML} to build XML and open Add Container.
 *
 * @param {string} xml Template path/key for `createXML`
 * @param {string} type Template type slot (`default` / `second` / …)
 * @param {string} [ports=''] JSON list of ports (string) used for conflict detection
 */
function popupInstallXML(xml,type) {
	event.stopPropagation();
	saveState();
	installXML(xml,type);
}
/**
 * Ask PHP to materialize a Docker XML template (`createXML`), then open `/Apps/AddContainer` with the returned template handle.
 *
 * @param {string} xml
 * @param {string} type
 */
function installXML(xml,type) {
	post({action:'createXML',xml:xml,type:type},function(result){
		if ( result.status == "ok" ) {
			// Server remapped conflicting host ports — stash the note so the
			// AddContainer page can surface it once (ca_browser_back_helper.page).
			if (result.portAdjustMessage)
				caSessSet("ca_port_adjustments", result.portAdjustMessage);
			if (type == "second") {
				type = "default";
			}
			openNewWindow("/Apps/AddContainer?xmlTemplate="+type+":"+xml);
		}
	});
}

