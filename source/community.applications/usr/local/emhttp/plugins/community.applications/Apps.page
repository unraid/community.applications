/* Virtualization: evict cards far above the viewport into a top-spacer (so
   scroll height stays the same) and restore them from caCardCache.cache when the
   user scrolls back up. Cards are kept in row-aligned chunks because the float
   layout would mis-pack a partial row. */
function caVirtSpacer() {
	var $spacer = $("#templates_content .ca_virtTopSpacer").first();
	if ($spacer.length) return $spacer;
	var $first = $("#templates_content").find(".ca_holder").first();
	if (!$first.length) return $();
	$spacer = $("<div class='ca_virtTopSpacer'></div>").css({
		width: "100%",
		height: "0px",
		flexBasis: "100%"
	});
	$first.before($spacer);
	return $spacer;
}
/**
 * Pixel height of the virtualization top spacer (0 when absent).
 *
 * @returns {number}
 */
function caVirtSpacerHeight() {
	var $s = $("#templates_content .ca_virtTopSpacer").first();
	if (!$s.length) return 0;
	return parseFloat($s[0].style.height) || 0;
}
/**
 * Grow or shrink `#templates_content .ca_virtTopSpacer` height by `deltaPx` (clamped at 0).
 *
 * @param {number} deltaPx Pixel delta (positive adds scroll range for evicted rows)
 */
function caVirtAdjustSpacer(deltaPx) {
	var $s = caVirtSpacer();
	if (!$s.length) return;
	var current = parseFloat($s[0].style.height) || 0;
	var next = Math.max(0, current + deltaPx);
	$s.css("height", next + "px");
}
/**
 * Count how many `.ca_holder` cards share the first row’s `offsetTop` (cards per row for float layout).
 *
 * @param {jQuery} $cards Card collection
 * @returns {number}
 */
function caVirtCardsPerRow($cards) {
	if (!$cards.length) return 0;
	var firstTop = $cards[0].offsetTop;
	for (var i = 1; i < $cards.length; i++) {
		if ($cards[i].offsetTop !== firstTop) return i;
	}
	return $cards.length;
}
/**
 * Vertical distance between the first card in row 0 and the first card in row 1.
 *
 * @param {jQuery} $cards Card collection
 * @param {number} perRow From {@link caVirtCardsPerRow}
 * @returns {number}
 */
function caVirtRowHeight($cards, perRow) {
	if (perRow < 1 || $cards.length <= perRow) return 0;
	return $cards[perRow].offsetTop - $cards[0].offsetTop;
}
/**
 * Evict off-screen card rows into a top spacer or restore from `caCardCache.cache` on upward scroll; may trigger `changePage(1)` on large jumps.
 */
function caVirtUpdate() {
	var mainArea = $(".mainArea")[0];
	if (!mainArea) return;
	/* The home/spotlight view uses .ca_homeTemplates rows (everything already in
	   the DOM, no pagination), not the .ca_templatesDisplay grid we virtualize.
	   Skip eviction/restoration there. */
	if (!$("#templates_content .ca_templatesDisplay").length) return;
	/* When the section explicitly loaded everything (Previous Apps / Action
	   Centre / Installed Apps) we keep the full DOM around so things like
	   Select All can operate on every checkbox at once. */
	if (data.allLoaded) return;
	var $cards = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
	if ($cards.length < 24) return;

	var perRow = caVirtCardsPerRow($cards);
	if (perRow < 1) return;
	var rowHeight = caVirtRowHeight($cards, perRow);
	if (rowHeight <= 0) return;

	var scrollTop = mainArea.scrollTop;
	var clientHeight = mainArea.clientHeight;
	var buffer = clientHeight; // 1 viewport above & below
	var mainTop = mainArea.getBoundingClientRect().top;

	/* If the user just jumped a long way upward (Cmd/Ctrl+Up, Home, End→top,
	   thumb drag, etc.) into the evicted region, the spacer can be many rows
	   tall and incremental restoration would only fill 8 rows per scroll event
	   — leaving them looking at blank space. Detect the jump and reset to a
	   fresh page-1 fetch instead. */
	var prevScrollTop = data._prevScrollTop || 0;
	data._prevScrollTop = scrollTop;
	if (caCardCache.firstInDom > 0 && scrollTop < buffer && (prevScrollTop - scrollTop) > clientHeight * 2) {
		caCardCache.firstInDom = 0;
		caCardCache.cache = [];
		data.loadingMore = false;
		data._prevScrollTop = 0;
		if (typeof changePage === "function") changePage(1);
		return;
	}

	/* EVICT: rows whose bottom is more than 1 viewport above the visible area. */
	var evictAboveY = scrollTop - buffer;
	var rowsToEvict = 0;
	for (var i = 0; i + perRow <= $cards.length; i += perRow) {
		var rowBottom = $cards[i].getBoundingClientRect().bottom - mainTop + scrollTop;
		if (rowBottom >= evictAboveY) break;
		rowsToEvict++;
	}
	var minKeep = 36;
	rowsToEvict = Math.min(rowsToEvict, Math.floor(($cards.length - minKeep) / perRow));
	if (rowsToEvict > 0) {
		var n = rowsToEvict * perRow;
		for (var k = 0; k < n; k++) {
			$cards[k].parentNode.removeChild($cards[k]);
		}
		caCardCache.firstInDom += n;
		caVirtAdjustSpacer(rowsToEvict * rowHeight);
		return;
	}

	/* RESTORE: user has scrolled back into the spacer region. */
	if (caCardCache.firstInDom > 0) {
		var spacerH = caVirtSpacerHeight();
		if (spacerH > 0 && scrollTop < spacerH + buffer) {
			var rowsToRestore = Math.min(
				Math.ceil(((spacerH + buffer) - scrollTop) / rowHeight),
				Math.floor(caCardCache.firstInDom / perRow) || 1
			);
			rowsToRestore = Math.min(rowsToRestore, 8);
			if (rowsToRestore <= 0) return;
			var cardsToRestore = Math.min(rowsToRestore * perRow, caCardCache.firstInDom);
			var html = "";
			for (var j = 0; j < cardsToRestore; j++) {
				var idx = caCardCache.firstInDom - cardsToRestore + j;
				html += caCardCache.cache[idx];
			}
			caCardCache.firstInDom -= cardsToRestore;
			caVirtSpacer().after(html);
			caVirtAdjustSpacer(-(rowsToRestore * rowHeight));
		}
	}
}

/* If the rendered page doesn't fill .mainArea — or only just barely fills it —
   pull the next page automatically. We require at least one card-row's worth
   of overflow past the viewport so there's always a visible "more below" cue
   at the bottom; this also covers the zoom-out edge case where the page goes
   from scrollable to non-scrollable without crossing the trigger. */
function caEnsureScrollable() {
	if (data.loadingMore) return;
	if (!data.nextpage || data.nextpage <= 0) return;
	var el = $(".mainArea")[0];
	if (!el) return;

	var rowHeight = 4;
	var $card = $("#templates_content").find(".ca_holder").first();
	if ($card.length) {
		var rect = $card[0].getBoundingClientRect();
		var style = getComputedStyle($card[0]);
		var rowH = rect.height + (parseFloat(style.marginTop) || 0) + (parseFloat(style.marginBottom) || 0);
		if (rowH > rowHeight) rowHeight = rowH;
	}

	if (el.scrollHeight - el.clientHeight > rowHeight * 2) return;

	data.loadingMore = true;
	var nextPage = data.nextpage;
	if (data.docker) {
		dockerSearch(nextPage, true);
	} else {
		changePage(nextPage, true);
	}
}

/* Infinite scroll: when the user nears the bottom of .mainArea and the most
   recent caRenderPageNavigation said another page exists, append the next 12
   cards rather than waiting for a page-number click. dockerSearch and the
   regular display path share the same pagination state (data.nextpage). */
function caInitInfiniteScroll() {
	var virtScheduled = false;
	var triggerNext = function() {
		if (data.loadingMore) return;
		if (!data.nextpage || data.nextpage <= 0) return;
		data.loadingMore = true;
		var nextPage = data.nextpage;
		if (data.docker) {
			dockerSearch(nextPage, true);
		} else {
			changePage(nextPage, true);
		}
	};

	/* CA's own scroll controls (.ca_back_to_top / .ca_move_to_end). dynamix's
	   .back_to_top / .move_to_end are left alone so other plugins keep working;
	   ours operate on whichever pane is currently the user-facing scroller —
	   .sidenav when the sidebar is open, otherwise .mainArea. Visibility is
	   driven from the same scroll events the rest of CA already uses. */
	var $backTop = $(".ca_back_to_top");
	var $moveEnd = $(".ca_move_to_end");
	var caGetActiveScroller = function() {
		var $sidenav = $(".sidenav.sidenavShow");
		if ($sidenav.length) return $sidenav[0];
		return $(".mainArea")[0];
	};
	$backTop.on("click", function(e) {
		e.preventDefault();
		var s = caGetActiveScroller();
		if (s) $(s).stop(true, true).animate({ scrollTop: 0 }, 500);
		return false;
	});
	$moveEnd.on("click", function(e) {
		e.preventDefault();
		var s = caGetActiveScroller();
		if (!s) return false;

		/* Sidebar mode: content is already entirely in the DOM, just scroll
		   to its bottom — no fetch needed (and the Apps grid pagination logic
		   below would be irrelevant anyway). */
		if ($(".sidenav.sidenavShow").length) {
			$(s).stop(true, true).animate({ scrollTop: s.scrollHeight }, 500);
			return false;
		}

		/* Home page (no .ca_templatesDisplay): everything is already in the
		   DOM — just scroll to the bottom of the viewport, no fetch needed. */
		if (!$("#templates_content .ca_templatesDisplay").length) {
			$(s).stop(true, true).animate({ scrollTop: s.scrollHeight }, 500);
			return false;
		}

		var total = parseInt(data.totalApps, 10) || 0;
		if (total <= 0) return false;

		if (data.docker) {
			/* DockerHub API caps each search at 25 results/page — we can't
			   ask for everything in one shot like the Apps grid path. Jump
			   to the last page instead; updateDisplay's structured-replace
			   path sets cardCacheOffset from the server's pageNumber so the
			   "Displaying X - Y of Z" indicator stays correct, and the
			   existing jump-to-top reset in caVirtUpdate handles scroll-up
			   back to page 1 when the user wants it. */
			var dockerPerPage = 25;
			var dockerLastPage = Math.max(1, Math.ceil(total / dockerPerPage));
			dockerSearch(dockerLastPage, false);
			return false;
		}

		/* Apps grid: fetch the entire result set in one request so the user can
		   scroll up freely from the end. Virtualization + content-visibility
		   keep this affordable even for thousands of cards. data.maxPerPage is
		   bumped only for this request and restored once cards are in the DOM. */
		var savedMaxPerPage = data.maxPerPage;
		data.maxPerPage = Math.max(total, 12);
		var scrollToEnd = function() {
			data.maxPerPage = savedMaxPerPage;
			var ma2 = $(".mainArea")[0];
			if (ma2) ma2.scrollTop = ma2.scrollHeight;
		};
		changePage(1, false);
		var attempts = 0;
		var poll = function() {
			if ($.isArray(caCardCache.cache) && caCardCache.cache.length >= total) {
				scrollToEnd();
				return;
			}
			if (++attempts > 60) {
				scrollToEnd();
				return;
			}
			setTimeout(poll, 100);
		};
		setTimeout(poll, 100);
		return false;
	});
	var caUpdateScrollControls = window.caUpdateScrollControls = function() {
		/* Fresh queries each call so a removed/re-added element or a class
		   change still gets picked up. */
		var $bt = $(".ca_back_to_top");
		var $me = $(".ca_move_to_end");
		if (!$bt.length && !$me.length) return;
		var s = caGetActiveScroller();
		if (!s) return;
		var atTop = s.scrollTop <= 0;
		var atBottom = s.scrollTop + s.clientHeight >= s.scrollHeight - 1;
		var canScroll = s.scrollHeight - s.clientHeight > 1;
		var showBack = canScroll && !atTop;
		var showEnd  = canScroll && !atBottom;
		if ($bt.length && ($bt.data("caShown") || false) !== showBack) {
			$bt.data("caShown", showBack);
			$bt.stop(true, true)[showBack ? "fadeIn" : "fadeOut"](500);
		}
		if ($me.length && ($me.data("caShown") || false) !== showEnd) {
			$me.data("caShown", showEnd);
			$me.stop(true, true)[showEnd ? "fadeIn" : "fadeOut"](500);
		}
	};
	/* Initial state: hide both until we know the page actually scrolls.
	   Live updates come from attachOverlay's existing scroll listener (which
	   already covers .mainArea, .sidenav, .menuItems, .ca_homeTemplates), so
	   we don't bind a second scroll handler here. */
	$backTop.hide().data("caShown", false);
	$moveEnd.hide().data("caShown", false);
	caUpdateScrollControls();
	/* Re-check after first paint so the initial values reflect post-layout
	   scroll dimensions, not whatever they are at attach time. */
	requestAnimationFrame(function() { caUpdateScrollControls(); });
	setTimeout(function() { caUpdateScrollControls(); }, 250);

	/* Sidebar open/close changes the active scroller, so recompute when its
	   class list flips between sidenavShow / sidenavHide. */
	(function() {
		var sn = $(".sidenav")[0];
		if (!sn || typeof MutationObserver !== "function") return;
		new MutationObserver(function() { caUpdateScrollControls(); })
			.observe(sn, { attributes: true, attributeFilter: ["class"] });
	})();

	$(".mainArea").on("scroll", function() {
		if (!virtScheduled) {
			virtScheduled = true;
			requestAnimationFrame(function() {
				virtScheduled = false;
				caVirtUpdate();
			});
		}
		caUpdateDisplayCount();
		var el = this;
		var bottomGap = el.scrollHeight - el.clientHeight - el.scrollTop;
		if (bottomGap > 600) return;
		triggerNext();
	});

	/* When the user is parked at the exact scroll bottom, the browser stops
	   firing scroll events on further wheel/touch attempts — so a "scroll past
	   the end" gesture wouldn't pull the next page. Catch that intent directly
	   from the wheel/touch input. */
	$(".mainArea").on("wheel", function(e) {
		var dy = e.originalEvent ? e.originalEvent.deltaY : 0;
		if (dy <= 0) return; // only downward
		var el = this;
		if (el.scrollTop + el.clientHeight >= el.scrollHeight - 2) {
			triggerNext();
		}
	});
	var touchStartY = 0;
	$(".mainArea").on("touchstart", function(e) {
		var t = e.originalEvent && e.originalEvent.touches && e.originalEvent.touches[0];
		touchStartY = t ? t.clientY : 0;
	});
	$(".mainArea").on("touchmove", function(e) {
		var t = e.originalEvent && e.originalEvent.touches && e.originalEvent.touches[0];
		if (!t) return;
		if (touchStartY - t.clientY < 12) return; // upward swipe = scroll down; require modest distance
		var el = this;
		if (el.scrollTop + el.clientHeight >= el.scrollHeight - 2) {
			triggerNext();
		}
	});

	/* Zoom-out / window-resize can leave the page non-scrollable even though
	   more results exist on the server — without a scrollbar the infinite-scroll
	   handler never fires. Re-run caEnsureScrollable on viewport changes so we
	   keep pulling pages until the layout is scrollable again. */
	var resizeTimer = null;
	var onResize = function() {
		if (resizeTimer) clearTimeout(resizeTimer);
		resizeTimer = setTimeout(function() {
			resizeTimer = null;
			caEnsureScrollable();
		}, 150);
	};
	$(window).on("resize", onResize);
	if (window.visualViewport) {
		$(window.visualViewport).on("resize", onResize);
	}
}
$(caInitInfiniteScroll);

</script>
