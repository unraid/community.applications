function changePage(pageNumber) {
  pageNumber = parseInt(pageNumber, 10) || 1;
  var max = getMaxPerPage();
  if ( max !== data.maxPerPage ) {
    if ( pageNumber !== data.currentpage ) {
      $(".ca_bottomBanner").removeClass("ca_hide");
      setTimeout(function() {
        $(".ca_bottomBanner").addClass("ca_hide");
      }, 3000);
    }
    // If per-page changes mid-pagination, keep the same first visible result.
    var oldMax = Math.max(1, parseInt(data.maxPerPage, 10) || 1);
    var oldPage = Math.max(1, parseInt(data.currentpage, 10) || pageNumber || 1);
    if ( oldPage > 1 ) {
      var startingIndex = (oldPage - 1) * oldMax; // 0-based index of first visible item
      pageNumber = Math.floor(startingIndex / Math.max(1, max)) + 1;
    } else {
      pageNumber = 1;
    }
    data.maxPerPage = max;
  }
  caRestoreCommittedSearchIfDrafted();
  if (searchBoxAwesomplete) searchBoxAwesomplete.close();
  var selected = data.selected;
  data.currentpage = pageNumber;

  post({action:'display_content',pageNumber:pageNumber,selected:selected,maxPerPage:data.maxPerPage},function(result) {
    updateDisplay(result.display);
    scrollToTop();
  });
}

function myCloseAlert(force=false) {

  swal.close();
  $("div.spinner, .sweet-alert").hide();
  enableSearch();
}

function doSidebarSearch(newSearch) {
  swal.close();
  closeSidebar();
  doSearch(false,newSearch);
}

function doSearch(button,newSearch) {
  if ( data.searchInProgress )
    return;

  data.searchInProgress = true;

  if ( ! newSearch === false ) {
    $('#searchBox').val(newSearch);
  }
  var filter = $('#searchBox').val();
  filter = $.trim(filter);
  filter = stripTags(filter);
  if ( ! filter ) {
    $("#searchBox").val(filter);
    data.searchInProgress = false;
    if ( data.searchActive || data.searchFlag || data.docker ) {
      appStore();
      return;
    }
    data.committedSearchFilter = "";
    caSyncSearchFilterCollapsed();
    caSyncHomeSearchSubtitle();
    return;
  }

  data.docker = "";
  data.section = "AppStore";

  $('#searchBox').val(filter);
  $(".multi_installDiv").hide();

  if ($('#searchButton').hasClass('fa-search')) {
    if (filter) {
      $('#searchButton').toggleClass('fa-search fa-remove');
    }
  } else if (button) {
    clearSearchBox();
    filter = '';
  }

  scrollToTop();
  if (filter) {
    caClearHomeSectionSubtitle();
    $("#sortIconArea").show();
   // $(".category").html(sprintf("<?tr("Search for %s")?>",filter));
    data.searchFlag = true;
  } else {
    if (searchBoxAwesomplete) searchBoxAwesomplete.close();
    /* X clear: only leave search / go home via updateContent when a search was actually active. Draft text alone must not trigger home. */
    if (data.searchActive || data.searchFlag || data.docker) {
      updateContent();
    }
    data.searchFlag = false;
    data.searchInProgress = false;
    data.committedSearchFilter = "";
    caSyncSearchFilterCollapsed();
    caSyncHomeSearchSubtitle();
    return;
  }
  data.searchActive = true;

  if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
    $('.dockerSearch').show();
    $('.templateSearch').hide();
  } else {
    $('.dockerSearch').hide();
    $('.templateSearch').hide();
  }

  data.searchInProgress = true;
  data.committedSearchFilter = filter;
  caSyncHomeSearchSubtitle();

  data.maxPerPage = getMaxPerPage();
  post({action:'get_content',filter:filter,maxPerPage:data.maxPerPage},function(result) {
    enableButtons();
    $(".selectedMenu").removeClass("selectedMenu");
    $(".subCategory").hide();
    $(".allApps").addClass("selectedMenu");
    updateDisplay(result.display);
    caSyncSearchFilterCollapsed();
    data.section = "AppStore";
    post({action:'getCategoriesPresent'},function(result) {
      $(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
      result.forEach(function(category) {
        var menuItem = $.find(".caMenuItem[data-category='"+category+"']");
        $(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
      });
      data.searchInProgress = false;
    });
  });
}

function changeSortOrder(button,buttonClass,previousApps) {
  var pageNumber = data.currentpage;
  var selected = data.selected;
  var startup = false;
  if ( button || buttonClass || previousApps) {
    data.searchFlag = false;
  }

  $(".startupButton").each(function(){
    if ($(this).hasClass("selectedMenu")) {
      startup = "true";
    }
  });
  post({action:'display_content',pageNumber:pageNumber,selected:selected,startup:startup},function(result) {
    updateDisplay(result.display);
  });
}

