/**
 * Build a themed SmoothieChart with sensible defaults shared by all three
 * live-stats charts. Caller adds TimeSeries and calls streamTo() when the
 * canvas is first revealed.
 *
 * @param {object} extra Chart-specific overrides (minValue/maxValue/yMax/
 *                       yMinFormatter/maxValueScale/etc.)
 * @returns {SmoothieChart}
 */
function caBuildLiveSmoothie(extra) {
	var grid  = cssVar("--chart-grid")          || "rgba(127,127,127,0.25)";
	var label = cssVar("--tooltipster-content") || "#cccccc";
	var base = {
		millisPerPixel: 50,
		responsive: true,
		grid: {
			strokeStyle: grid,
			fillStyle: 'transparent',
			lineWidth: 1,
			millisPerLine: 1000,
			verticalSections: 4
		},
		labels: {
			fillStyle: label,
			fontSize: 11,
			precision: 0
		},
		timestampFormatter: function(date) { return ''; }
	};
	return new SmoothieChart($.extend(true, base, extra || {}));
}

/**
 * Format a byte-rate (bytes/sec) into human-readable form for the summary
 * panel and disk/network chart axes. Picks B/s → KB/s → MB/s based on
 * magnitude.
 *
 * @param {number} bps Bytes per second
 * @returns {string}
 */
function caFmtRate(bps) {
	if (!isFinite(bps) || bps < 0) bps = 0;
	if (bps < 1024)        return bps.toFixed(0) + " B/s";
	if (bps < 1024 * 1024) return (bps / 1024).toFixed(1) + " KB/s";
	return (bps / 1048576).toFixed(2) + " MB/s";
}

/**
 * Format a memory value (in MB) into MB or GB depending on magnitude. Used
 * for both the memory chart's axis labels and the donut's center text.
 *
 * @param {number} mb Megabytes
 * @returns {string}
 */
function caFmtMB(mb) {
	if (!isFinite(mb) || mb < 0) mb = 0;
	if (mb < 1024) return mb.toFixed(0) + " MB";
	return (mb / 1024).toFixed(2) + " GB";
}

/**
 * Build an analog-speedometer SVG gauge in the supplied mount node. Used
 * by the live-stats summary view.
 *
 * Modeled after a classic dashboard dial: white face inside a darker
 * bezel ring, dark major tick marks with lighter minor ticks in between,
 * yellow / orange / red warning bands across the upper portion of the
 * arc, a tapered red needle, and a blue center hub. The metric name
 * ("CPU" / "MEM" / "NET") is rendered large in the dial's interior;
 * the current value is shown below the SVG in the caLiveDonutSub slot.
 *
 * Geometry: 270 degree arc from -135 (lower-left) through 0 (straight
 * up) to +135 (lower-right). Values 0..100 map linearly across the
 * sweep. One needle only — the container's. (Host overlay lives on
 * the chart views, where two lines can sit side by side without the
 * needles fighting for the same arc position.)
 *
 * Zones are optional {from, to, cssClass} ranges in the value domain.
 *
 * @param {jQuery} $mount Container <div class="caLiveGaugeMount">.
 * @param {object} opts   {title, zones[]}
 * @returns Gauge handle { setValue(contVal) }.
 */
function caBuildGauge($mount, opts) {
	var SVG_NS = 'http://www.w3.org/2000/svg';
	var cx = 50, cy = 50;
	var rArc = 38;          /* center-of-stroke radius for the colored arc */
	var rFace = 47;         /* white dial face radius */
	var startA = -135, endA = 135;

	function polar(angleDeg, r) {
		var rad = (angleDeg - 90) * Math.PI / 180;
		return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };
	}
	function arcD(fromA, toA, r) {
		var s = polar(fromA, r), e = polar(toA, r);
		var large = (toA - fromA) > 180 ? 1 : 0;
		return 'M ' + s.x.toFixed(3) + ' ' + s.y.toFixed(3) +
		       ' A ' + r + ' ' + r + ' 0 ' + large + ' 1 ' +
		       e.x.toFixed(3) + ' ' + e.y.toFixed(3);
	}
	function valToAngle(v) {
		v = Math.max(0, Math.min(100, v));
		return startA + (v / 100) * (endA - startA);
	}
	function svgEl(tag, attrs) {
		var el = document.createElementNS(SVG_NS, tag);
		for (var k in (attrs || {})) el.setAttribute(k, attrs[k]);
		return el;
	}

	var svg = svgEl('svg', { viewBox: '0 0 100 100', 'class': 'caLiveGaugeSvg' });

	/* Dial face — a filled circle with a soft outer rim. Drawn first so
	   everything else sits on top of it. */
	svg.appendChild(svgEl('circle', { cx: cx, cy: cy, r: rFace,     'class': 'caLiveGaugeFace' }));
	svg.appendChild(svgEl('circle', { cx: cx, cy: cy, r: rFace - 2, 'class': 'caLiveGaugeFaceRim' }));

	/* Colored arc segments. The base track is the dark gauge background
	   stroke; warning zones override their segments with brighter colors. */
	var stops = [0];
	(opts.zones || []).forEach(function(z) { stops.push(z.from); stops.push(z.to); });
	stops.push(100);
	stops = stops.filter(function(v, i, a) { return a.indexOf(v) === i; }).sort(function(a, b) { return a - b; });
	for (var i = 0; i < stops.length - 1; i++) {
		var from = stops[i], to = stops[i + 1];
		if (from === to) continue;
		var inZone = null;
		(opts.zones || []).forEach(function(z) { if (from >= z.from && to <= z.to) inZone = z; });
		svg.appendChild(svgEl('path', {
			d: arcD(valToAngle(from), valToAngle(to), rArc),
			fill: 'none',
			'stroke-width': inZone ? 4 : 1.6,
			'stroke-linecap': 'butt',
			'class': inZone ? inZone.cssClass : 'caLiveGaugeTrack'
		}));
	}

	/* Tick marks. Majors at every 10% (thicker, longer); minors at every
	   2% in between (thin, short). Both sit just inside the colored arc. */
	for (var t = 0; t <= 50; t++) {
		var pct = t * 2;
		var ang = valToAngle(pct);
		var major = (pct % 10 === 0);
		var pInner = polar(ang, rArc - (major ? 5.5 : 3.2));
		var pOuter = polar(ang, rArc - (major ? 0.4 : 1.4));
		svg.appendChild(svgEl('line', {
			x1: pInner.x.toFixed(2), y1: pInner.y.toFixed(2),
			x2: pOuter.x.toFixed(2), y2: pOuter.y.toFixed(2),
			'stroke-width': major ? 1.0 : 0.5,
			'class': major ? 'caLiveGaugeTickMajor' : 'caLiveGaugeTickMinor'
		}));
	}

	function addText(x, y, txt, size, cls) {
		var node = svgEl('text', {
			x: x.toFixed(2), y: y.toFixed(2),
			'text-anchor': 'middle',
			'dominant-baseline': 'middle',
			'font-size': size,
			'class': cls
		});
		node.textContent = txt;
		svg.appendChild(node);
		return node;
	}

	/* "0" and "100" labels tucked just inside the arc's start and end. */
	var p0   = polar(valToAngle(0),   rArc - 9);
	var p100 = polar(valToAngle(100), rArc - 9);
	addText(p0.x,   p0.y,   '0',   4, 'caLiveGaugeAxisText');
	addText(p100.x, p100.y, '100', 4, 'caLiveGaugeAxisText');

	/* Title above the hub. Supports either a string ("CPU") or an array
	   of strings (["Unraid","CPU"]) for two-line labels — the dial cluster
	   uses the array form for the Unraid CPU gauge so the longer name
	   fits inside the dial face without overlapping the arc or hub. */
	var titleLines = Array.isArray(opts.title) ? opts.title : [opts.title || ''];
	var titleSize  = (titleLines.length > 1) ? 8 : 11;
	var titleGap   = (titleLines.length > 1) ? 9 : 0;
	var titleTopY  = cy - 12 - ((titleLines.length - 1) * titleGap / 2);
	titleLines.forEach(function(line, i) {
		addText(cx, titleTopY + i * titleGap, line, titleSize, 'caLiveGaugeTitle');
	});

	/* Tapered triangular needle: a polygon defined pointing straight up
	   (toward the top of the dial). The wrapping <g>'s rotate transform
	   walks it around the arc. CSS handles the smooth tween. */
	var needle = svgEl('g', { 'class': 'caLiveGaugeNeedle' });
	var tipY  = cy - (rArc - 3);
	var tailY = cy + 8;
	needle.appendChild(svgEl('polygon', {
		points:
			cx + ',' + tipY + ' ' +
			(cx - 2.2) + ',' + (cy + 1) + ' ' +
			(cx - 1.0) + ',' + tailY + ' ' +
			(cx + 1.0) + ',' + tailY + ' ' +
			(cx + 2.2) + ',' + (cy + 1)
	}));
	needle.setAttribute('transform', 'rotate(' + startA + ' ' + cx + ' ' + cy + ')');
	svg.appendChild(needle);

	/* Two-layer hub: outer ring covers the needle's pivot, inner highlight
	   gives the same "screw" look as a real instrument cluster. */
	svg.appendChild(svgEl('circle', { cx: cx, cy: cy, r: 4.5, 'class': 'caLiveGaugeHub' }));
	svg.appendChild(svgEl('circle', { cx: cx - 1, cy: cy - 1, r: 1.4, 'class': 'caLiveGaugeHubInner' }));

	/* Subtitle inside the dial face, BELOW the "0"/"100" axis labels
	   (which sit around y=70). Putting it here instead of between hub
	   and axis labels gives us a much wider corridor (~55 SVG units of
	   clear dial face vs ~30 above) so the base font-size can be large
	   enough to actually read at the rendered scale — at viewBox 100×92
	   stretched to ~130px CSS wide, 1 SVG unit ≈ 1.3 CSS px, so size 7
	   lands at ~9 CSS px.
	   Optional opts.subtitleHeader is a tiny static caption rendered just
	   above the dynamic body line — e.g. the Unraid CPU gauge uses it to
	   prefix "Loads" over its three-value pipe-separated load average,
	   while the Net gauge sticks to a single static body line of "Rx+Tx"
	   with no header. */
	var hasHeader        = !!opts.subtitleHeader;
	var subtitleBodyY    = hasHeader ? (cy + 30) : (cy + 28);
	var subtitleBodySize = hasHeader ? 6 : 7;
	if (hasHeader) {
		var subtitleHeader = svgEl('text', {
			x: cx.toFixed(2), y: (cy + 22).toFixed(2),
			'text-anchor': 'middle',
			'dominant-baseline': 'middle',
			'font-size': 4,
			'class': 'caLiveGaugeSubtitleHeader'
		});
		subtitleHeader.textContent = opts.subtitleHeader;
		svg.appendChild(subtitleHeader);
	}
	var subtitleText = svgEl('text', {
		x: cx.toFixed(2), y: subtitleBodyY.toFixed(2),
		'text-anchor': 'middle',
		'dominant-baseline': 'middle',
		'font-size': subtitleBodySize,
		'class': 'caLiveGaugeSubtitle'
	});
	subtitleText.textContent = opts.subtitle || '';
	svg.appendChild(subtitleText);

	var subtitleMaxLen = 50;
	function fitSubtitle() {
		subtitleText.setAttribute('font-size', subtitleBodySize);
		var len = 0;
		try { len = subtitleText.getComputedTextLength(); } catch (e) { /* unrendered */ }
		if (len > subtitleMaxLen && len > 0) {
			subtitleText.setAttribute('font-size', (subtitleBodySize * subtitleMaxLen / len).toFixed(2));
		}
	}
	if (opts.subtitle) fitSubtitle();

	$mount.empty().append(svg);

	return {
		setValue: function(contVal) {
			needle.setAttribute('transform', 'rotate(' + valToAngle(contVal).toFixed(2) + ' ' + cx + ' ' + cy + ')');
		},
		setSubtitle: function(txt) {
			subtitleText.textContent = txt || '';
			fitSubtitle();
		}
	};
}

/**
 * Start the live-stats subscription for a docker container. Builds three
 * SmoothieChart instances (CPU, Memory, Network) and three speedometer
 * gauges (Summary view), then subscribes to nchan channel
 * /sub/stats_<containerName> to receive one snapshot per second from this
 * container's dedicated publisher (scripts/caLiveStats.php <containerName>).
 *
 * One publisher process per container being watched: two tabs on the same
 * container share one publisher, two tabs on different containers spawn
 * two lightweight publishers. Each does exactly one Docker socket call
 * per tick regardless of host container count.
 *
 * Calling startLiveStatsPublisher first is idempotent per-container —
 * exec.php's pgrep on path+container-arg returns "already_running" if
 * another tab keeps it warm, otherwise spawns a new one.
 *
 * Default view is Summary; chart canvases lazy-bind streamTo() the first
 * time their tab is clicked, but the TimeSeries data accumulates from
 * message one so switching tabs after a while still shows history.
 *
 * Render delay: 1000 ms — matches the publisher's tick interval so
 * samples are drawn one beat after they arrive, hiding the natural
 * jitter from the publish round-trip.
 *
 * Teardown lives in caStopLiveStats() — closeSidebar() and popUpChart()'s
 * prelude both call it so a back-to-back sidebar open doesn't leak the
 * previous container's WebSocket. The publisher itself self-terminates
 * ~10s after the last subscriber drops via publish()'s abort path.
 *
 * @param {string} containerName Docker container Name (already validated server-side).
 */
function caStartLiveStats(containerName) {
	if (!$(".popupLiveStatsBlock").length) return;
	if (typeof SmoothieChart !== "function") return;

	/* Magenta — used everywhere the "host total" overlay appears (inner
	   donut ring, secondary chart series, legend swatches). Kept in one
	   place so the visual association across donuts/charts/legends stays
	   consistent if it ever needs to be retuned. */
	var HOST_COLOR = '#C341D6';
	var HOST_FILL  = 'rgba(195,65,214,0.10)';

	/* CPU% — whole-host normalized. Y-axis is *dynamic*: SmoothieChart fits
	   to the peak inside the currently-visible window (rather than pinning
	   at 100), so a container that peaked at 35% and dropped to 20% will
	   show the 35% headroom until that sample scrolls off the left edge,
	   then re-scale down to the new peak. maxValueScale 1.10 leaves 10%
	   headroom above the running peak so the line doesn't ride the
	   ceiling. Host CPU% rides the same dynamic axis. */
	var cpuChart = caBuildLiveSmoothie({
		minValue: 0,
		maxValueScale: 1.10,
		yMinFormatter: function(v) { return Math.max(0, Math.floor(v)) + ' %'; },
		yMaxFormatter: function(v) { return Math.max(0, Math.ceil(v)) + ' %'; }
	});
	var cpuSeries     = new TimeSeries();
	var cpuHostSeries = new TimeSeries();
	cpuChart.addTimeSeries(cpuSeries,     { strokeStyle: '#FF8C2F', fillStyle: 'rgba(255,140,47,0.15)', lineWidth: 2 });
	cpuChart.addTimeSeries(cpuHostSeries, { strokeStyle: HOST_COLOR, fillStyle: HOST_FILL,             lineWidth: 1.5 });

	/* Memory — raw MB series (auto-formatted to GB above 1024). Y-max is
	   pinned to the host total RAM once we see it on the first tick, so
	   both the container line and the host total line fit on the same
	   axis. The donut's outer ring uses container_used / container_limit
	   (so a small-limit container still shows full when saturated), while
	   the inner host ring uses host_used / host_total. */
	var memChart = caBuildLiveSmoothie({
		minValue: 0,
		yMinFormatter: function(v) { return caFmtMB(Math.max(0, v)); },
		yMaxFormatter: function(v) { return caFmtMB(Math.max(0, v)); }
	});
	var memSeries     = new TimeSeries();
	var memHostSeries = new TimeSeries();
	memChart.addTimeSeries(memSeries,     { strokeStyle: '#3FB6F2', fillStyle: 'rgba(63,182,242,0.15)', lineWidth: 2 });
	memChart.addTimeSeries(memHostSeries, { strokeStyle: HOST_COLOR, fillStyle: HOST_FILL,             lineWidth: 1.5 });

	/* Network I/O — two container series (RX/TX) plus a single host total
	   line. Green = RX, red = TX, matching the dashboard's network colors.
	   (Disk I/O was intentionally dropped — see the server-side comment
	   above getContainerCpu(); cgroup blkio doesn't capture bind-mount or
	   named-volume traffic so the container figure isn't honest.) */
	var netChart = caBuildLiveSmoothie({
		minValue: 0,
		minValueScale: 1.02,
		maxValueScale: 1.05,
		yMinFormatter: function(v) { return caFmtRate(Math.max(0, v)); },
		yMaxFormatter: function(v) { return caFmtRate(Math.max(0, v)); }
	});
	var netRxSeries   = new TimeSeries();
	var netTxSeries   = new TimeSeries();
	var netHostSeries = new TimeSeries();
	netChart.addTimeSeries(netRxSeries,   { strokeStyle: '#41C46C', fillStyle: 'rgba(65,196,108,0.12)', lineWidth: 2 });
	netChart.addTimeSeries(netTxSeries,   { strokeStyle: '#E22828', fillStyle: 'rgba(226,40,40,0.12)', lineWidth: 2 });
	netChart.addTimeSeries(netHostSeries, { strokeStyle: HOST_COLOR, fillStyle: HOST_FILL,             lineWidth: 1.5 });

	window.caLiveStats = {
		container: containerName,
		sub: null,                   /* NchanSubscriber, set after start() below */
		prev: null,                  /* previous cumulative counters {tsMs, container + host} */
		peakNet:  1,                 /* session-relative max net byte-rate when NIC speed unknown */
		netSpeedBps: 0,              /* aggregate NIC link speed in bytes/sec, populated from first tick */
		memMaxPinned: false,
		gauges: { cpu: null, cpuHost: null, memory: null, net: null },
		charts: {
			cpu:    { chart: cpuChart, series: cpuSeries, host: cpuHostSeries,                              canvasId: 'caLiveCpuChart', streamed: false },
			memory: { chart: memChart, series: memSeries, host: memHostSeries,                              canvasId: 'caLiveMemChart', streamed: false },
			net:    { chart: netChart, rx:     netRxSeries, tx:    netTxSeries, host: netHostSeries,        canvasId: 'caLiveNetChart', streamed: false }
		}
	};

	/* Summary gauges. Warning zones at 70/85/95 of full scale across all
	   three metrics. For network the "full scale" is the fastest single
	   NIC's link speed (set on the first tick once we know what it is),
	   so the 95-100 red band is literally "saturating the wire". */
	var standardZones = [
		{ from: 70, to: 85, cssClass: 'caLiveGaugeZoneWarn' },
		{ from: 85, to: 95, cssClass: 'caLiveGaugeZoneHigh' },
		{ from: 95, to: 100, cssClass: 'caLiveGaugeZoneCrit' }
	];
	window.caLiveStats.gauges.cpu     = caBuildGauge($(".caLiveGaugeMount[data-metric='cpu']"),     { title: 'CPU',                zones: standardZones });
	window.caLiveStats.gauges.cpuHost = caBuildGauge($(".caLiveGaugeMount[data-metric='cpuhost']"), { title: ['Unraid', 'CPU'],    zones: standardZones, subtitleHeader: 'Loads' });
	window.caLiveStats.gauges.memory  = caBuildGauge($(".caLiveGaugeMount[data-metric='memory']"),  { title: 'MEM',                zones: standardZones });
	window.caLiveStats.gauges.net     = caBuildGauge($(".caLiveGaugeMount[data-metric='net']"),     { title: 'NET',                zones: standardZones, subtitle: 'Rx+Tx' });

	/* Eager-bind every chart canvas now, even though only one view is
	   currently visible. SmoothieChart's RAF loop runs regardless of the
	   canvas's CSS visibility; while hidden it appends data to TimeSeries
	   but the paint goes to a 0-sized canvas (no visible pixels). The
	   moment the user flips to that chart's tab, responsive:true picks up
	   the now-real canvas dimensions on the next frame and the line
	   appears already drawn with the accumulated history.
	   Without this, switching tabs after a while showed an empty chart
	   that started painting from t=now, hiding everything that happened
	   while the other tab was up. */
	var refWidth = Math.max(300, Math.floor(($(".popupLiveStatsBlock").width() || 600)));
	$.each(window.caLiveStats.charts, function(_, spec) {
		var canvas = document.getElementById(spec.canvasId);
		if (!canvas) return;
		/* Seed an explicit pixel-buffer size since the chart's hidden
		   view divs report clientWidth:0. responsive:true will resize the
		   buffer up/down once the canvas is laid out for real. */
		canvas.width  = refWidth;
		canvas.height = 120;
		spec.chart.streamTo(canvas, 1000);
		spec.streamed = true;
	});

	/* Tab strip — toggles the .caLiveStatsActive class which controls
	   visibility (not display) via CSS. All views are laid out in the
	   same grid cell at full size all the time; only one is visibility:
	   visible at any moment. This keeps the hidden chart canvases at
	   their real clientWidth so Smoothie keeps drawing into them, and a
	   tab switch instantly reveals the already-drawn history.
	   Scoped to the live-stats block so it tears down with the sidebar's
	   DOM when closeSidebar() wipes #sidenavContent. */
	$(".popupLiveStatsBlock").on("click", ".caLiveStatsTab", function() {
		var $tab = $(this);
		if ($tab.hasClass("selectedMenu")) return;
		var view = $tab.data("view");
		$(".popupLiveStatsBlock .caLiveStatsTab")
			.removeClass("selectedMenu")
			.attr("aria-pressed", "false");
		$tab.addClass("selectedMenu").attr("aria-pressed", "true");
		$(".popupLiveStatsBlock .caLiveStatsView").removeClass("caLiveStatsActive");
		$(".popupLiveStatsBlock .caLiveStatsView[data-view='" + view + "']").addClass("caLiveStatsActive");
	});

	/* Per-snapshot processor. Called by the nchan onmessage handler below
	   for each second's all-containers payload — extracts this sidebar's
	   container entry, flattens host fields into the same shape the old
	   per-poll endpoint used to return, and runs the gauge/chart updates.
	   Self-contained so the contents of the handler stay readable. */
	var processSnapshot = function(result) {
			if (!window.caLiveStats || window.caLiveStats.container !== containerName) return;
			if (!result || !result.ok) {
				/* Container stopped or disappeared mid-session — tear the
				   subscriber down and message the summary panel rather
				   than spamming reconnects against a dead container. The
				   gauge needles park at whatever they last read; the
				   sub-label change is the signal. */
				caStopLiveStats();
				$(".caLiveDonutSubCpu, .caLiveDonutSubCpuHost, .caLiveDonutSubMem, .caLiveDonutSubNet").text("<?tr("stopped");?>");
				return;
			}
			/* Use the server's sample timestamp for chart X-positions, not
			   the WebSocket arrival time. Otherwise any latency between
			   the publisher emitting and the browser receiving shifts the
			   X-axis around per-sample, which on a slow tick looks like
			   gaps in the line (Smoothie scrolls at wall-clock speed and
			   draws nothing between widely-spaced samples). */
			var nowMs = (typeof result.tsMs === "number" && result.tsMs > 0) ? result.tsMs : new Date().getTime();

			/* Pin the memory chart's Y-max to the host's total RAM the
			   first time we see it. Smoothie picks up the option change
			   on the next render frame. Using host total (not container
			   limit) keeps the axis consistent across both lines so the
			   host overlay isn't off the top of the chart on containers
			   that have a small explicit memory limit. */
			if (!window.caLiveStats.memMaxPinned && result.hostMemTotalMb > 0) {
				window.caLiveStats.charts.memory.chart.options.maxValue = result.hostMemTotalMb;
				window.caLiveStats.memMaxPinned = true;
			}

			/* Container rate deltas (net) and host rate/CPU deltas.
			   First poll has no prev → all rates collapse to 0 so the
			   chart leaves zeros at t0 and starts plotting real numbers
			   from tick two onward. */
			var rxRate = 0, txRate = 0;
			var hostCpu = 0, hostNetRate = 0;
			var prev = window.caLiveStats.prev;
			if (prev && result.tsMs > prev.tsMs) {
				var elapsedSec = (result.tsMs - prev.tsMs) / 1000.0;
				if (elapsedSec > 0) {
					rxRate = Math.max(0, (result.netRxBytes - prev.netRxBytes) / elapsedSec);
					txRate = Math.max(0, (result.netTxBytes - prev.netTxBytes) / elapsedSec);

					var hostNetDelta = (result.hostNetRxBytes - prev.hostNetRxBytes) +
					                   (result.hostNetTxBytes - prev.hostNetTxBytes);
					hostNetRate = Math.max(0, hostNetDelta / elapsedSec);
				}
				/* Host CPU% from /proc/stat jiffies: busy_delta / total_delta. */
				var totalDelta = result.hostCpuTotal - prev.hostCpuTotal;
				var busyDelta  = result.hostCpuBusy  - prev.hostCpuBusy;
				if (totalDelta > 0 && busyDelta >= 0) hostCpu = (busyDelta / totalDelta) * 100.0;
			}
			window.caLiveStats.prev = {
				tsMs:           result.tsMs,
				netRxBytes:     result.netRxBytes,
				netTxBytes:     result.netTxBytes,
				hostCpuBusy:    result.hostCpuBusy,
				hostCpuTotal:   result.hostCpuTotal,
				hostNetRxBytes: result.hostNetRxBytes,
				hostNetTxBytes: result.hostNetTxBytes
			};

			/* Chart appends — every chart gets both a container line and
			   a host line. Memory: container_mb vs host_used_mb. Net
			   shows container RX/TX plus a single host total to keep the
			   chart from getting too crowded. */
			window.caLiveStats.charts.cpu.series.append(nowMs, result.cpu);
			window.caLiveStats.charts.cpu.host.append(nowMs, hostCpu);
			window.caLiveStats.charts.memory.series.append(nowMs, result.memMb);
			window.caLiveStats.charts.memory.host.append(nowMs, result.hostMemUsedMb);
			window.caLiveStats.charts.net.rx.append(nowMs, rxRate);
			window.caLiveStats.charts.net.tx.append(nowMs, txRate);
			window.caLiveStats.charts.net.host.append(nowMs, hostNetRate);

			/* Gauge value mapping — both needles read against the same
			   per-metric scale, so the container needle is always at or
			   behind the host needle (the host metric is a superset).
			   - CPU: both already 0..100 of total host CPU.
			   - Memory: % of host RAM.
			   - Network: % of aggregate NIC link speed (falls back to a
			     session peak if /sys/class/net reported no usable speed). */
			var netTotal = rxRate + txRate;

			/* Pin the network gauge scale to the fastest single NIC's link
			   speed once we see a non-zero value — the redline (red zone
			   at the top of the gauge) then maps to actually saturating
			   that wire. If it stays 0 (virtual hosts, unknown PHY) we
			   fall back to a session peak. */
			if (!window.caLiveStats.netSpeedBps && result.hostNetMaxBps > 0) {
				window.caLiveStats.netSpeedBps = result.hostNetMaxBps;
			}
			var netScale = window.caLiveStats.netSpeedBps;
			if (!netScale) {
				if (netTotal    > window.caLiveStats.peakNet) window.caLiveStats.peakNet = netTotal;
				if (hostNetRate > window.caLiveStats.peakNet) window.caLiveStats.peakNet = hostNetRate;
				netScale = window.caLiveStats.peakNet;
			}

			var hostMemPerc = result.hostMemTotalMb > 0 ? (result.hostMemUsedMb / result.hostMemTotalMb) * 100.0 : 0;
			var contMemPerc = result.hostMemTotalMb > 0 ? (result.memMb         / result.hostMemTotalMb) * 100.0 : 0;
			var netHostPct  = netScale > 0 ? (hostNetRate / netScale) * 100.0 : 0;
			var netContPct  = netScale > 0 ? (netTotal    / netScale) * 100.0 : 0;

			/* All four donuts refresh every tick regardless of which view
			   is currently visible, so flipping to Summary always shows
			   fresh numbers. Center text + outer ring = container; sub-
			   label "H ..." + inner ring = host. */
			/* Refresh every gauge each tick regardless of which view is
			   visible, so flipping to Summary always shows fresh needles.
			   The Unraid CPU gauge gets its load-average annotation set
			   *inside* the dial via setSubtitle — auto-fit shrinks the
			   font if the three values would otherwise overflow the
			   axis-label gap. */
			var g = window.caLiveStats.gauges;
			if (g.cpu)     g.cpu.setValue(result.cpu);
			if (g.cpuHost) g.cpuHost.setValue(hostCpu);
			if (g.memory)  g.memory.setValue(contMemPerc);
			if (g.net)     g.net.setValue(netContPct);

			if (g.cpuHost && g.cpuHost.setSubtitle) {
				var loads = (result.hostLoadAvg && result.hostLoadAvg.length === 3)
					? result.hostLoadAvg[0].toFixed(2) + "|" + result.hostLoadAvg[1].toFixed(2) + "|" + result.hostLoadAvg[2].toFixed(2)
					: "";
				g.cpuHost.setSubtitle(loads);
			}

			$(".caLiveDonutSubCpu").text(result.cpu.toFixed(1) + "%");
			$(".caLiveDonutSubCpuHost").text(hostCpu.toFixed(1) + "%");
			$(".caLiveDonutSubMem").text(caFmtMB(result.memMb));
			$(".caLiveDonutSubNet").text(caFmtRate(netTotal));
			/* Suppress unused-var noise when other host vars don't drive
			   a gauge directly — they're still read by the chart-append
			   block above. */
			void hostMemPerc; void netHostPct;
	};

	/* Kick the per-container publisher (no-op if one is already running
	   for this exact container — another tab subscribed, or our own
	   previous sidebar within the publisher's post-disconnect grace
	   window). The publisher script publishes to stats_<containerName>;
	   the subscriber below listens on that same channel. The message body
	   is the FLAT per-snapshot shape processSnapshot already expects, so
	   we just JSON.parse and hand it off — no reshaping. */
	postNoSpin({action:"startLiveStatsPublisher", container: containerName}, function() { /* fire-and-forget */ });

	var sub = new NchanSubscriber('/sub/stats_' + containerName, {subscriber:'websocket', reconnectTimeout:5000});
	sub.on('message', function(raw) {
		if (!window.caLiveStats || window.caLiveStats.container !== containerName) return;
		var result;
		try { result = JSON.parse(raw); } catch (e) { return; }
		if (!result || typeof result !== 'object') return;
		processSnapshot(result);
	});
	sub.start();
	window.caLiveStats.sub = sub;
}

/**
 * Tear down the live-stats subscription. Safe to call when nothing is
 * running. Invoked from closeSidebar() and from popUpChart()'s prelude so
 * back-to-back sidebar opens don't leak the previous container's WebSocket.
 *
 * The shared publisher (scripts/caLiveStats.php) doesn't need an explicit
 * stop signal — nchan's subscriber-count drops as soon as sub.stop() runs,
 * and publish() in the script self-terminates ~10s later if nobody else
 * picks up the channel.
 *
 * SmoothieChart has no `.destroy()` — the documented teardown is to call
 * `.stop()` on the chart (halts the requestAnimationFrame loop) and drop
 * the reference so its TimeSeries can be garbage collected.
 */
function caStopLiveStats() {
	if (!window.caLiveStats) return;
	try {
		if (window.caLiveStats.sub && typeof window.caLiveStats.sub.stop === "function") {
			window.caLiveStats.sub.stop();
		}
		var charts = window.caLiveStats.charts || {};
		$.each(charts, function(_, spec) {
			if (spec && spec.chart && typeof spec.chart.stop === "function") spec.chart.stop();
		});
	} catch (e) { /* stop() mid-frame is fine — Smoothie tolerates it */ }
	window.caLiveStats = null;
}

/**
 * Show the sliding sidebar pane: inject optional HTML, reveal `.sidebar`, hide back affordance, {@link slideInSidebar}.
 *
 * @param {string} [content=''] Optional HTML for `#sidenavContent`
 */
function showAlternateView(content="") {
	/* In-place swap of #sidenavContent — if a live-stats subscription is
	   running for a previously-open container sidebar its callbacks would
	   keep firing against detached gauge/chart DOM after this replaces
	   the content. Tear it down explicitly here (closeSidebar() and
	   popUpChart()'s prelude don't fire on this code path). */
	if (typeof caStopLiveStats === "function") caStopLiveStats();
	if ( content ) {
		$("#sidenavContent").html(content);
	}
	$(".sidebar").show();
	$(".sidenav").removeClass("sidenavHide");

	$(".popUpBack").addClass("ca_hide");

	slideInSidebar();
	$(".sidenav").removeClass("sidenavHide").addClass("sidenavShow");
}

/**
 * Detach the per-app action + support button strip from the freshly-rendered
 * sidebar content and append it into the fixed-bottom .popupActionsAreaInner
 * container. Server keeps emitting the strip inline with the popup body (so
 * it ships with the right per-app actions for the template); this just
 * relocates it after each render so the buttons stay glued to the bottom
 * edge of the viewport while the user scrolls the popup content above.
 * The top bar (.popupCloseAreaButtons) is left with just CLOSE/BACK/STAT.
 */
function caRelocatePopupActions() {
	$(".popupActionsAreaInner .popupStickyActions").remove();   // clear any stragglers
	var $strip = $("#sidenavContent .popupStickyActions").first();
	if ($strip.length) $strip.detach().appendTo(".popupActionsAreaInner");
	caSyncSidenavBottomPadding();
}

/**
 * Measure the rendered .popupActionsArea height and stamp it into the
 * --ca-sidenav-bottom CSS variable so #sidenavContent's bottom padding always
 * clears the action bar — even when buttons wrap to multiple rows on narrow
 * sidebars. CSS keeps a 9rem fallback for the pre-measure paint. We re-run on
 * every relocation and on resize (caRelocatePopupActions itself is also bound
 * to viewport changes elsewhere).
 */
function caSyncSidenavBottomPadding() {
	var $bar = $(".popupActionsArea").first();
	if (!$bar.length || !$bar.is(":visible")) {
		document.documentElement.style.removeProperty("--ca-sidenav-bottom");
		return;
	}
	/* outerHeight(true) includes margin so any future spacing change on the
	   action bar carries straight into the padding. Add a 1rem breathing gap
	   below the last row so content doesn't kiss the buttons. */
	var h = $bar.outerHeight(true) + 16;
	document.documentElement.style.setProperty("--ca-sidenav-bottom", h + "px");
}

/**
 * Load app popup HTML via `getPopupDescription`, wire MagnificPopup galleries, context menus, charts, and async readme/change sections.
 *
 * @param {string} apppath Template path key
 * @param {string} appname Human-readable application name
 */
function showSidebarApp(apppath,appname) {
	/* Opening an app popup leaves the Credits view-stack, so its top-left back
	   arrow goes back to the app (default), not Credits. */
	window.caSidebarBackTarget = "";
	mySpinner();
	disableSearch();
	caSessSet("sidebarAppPath",apppath);
	caSessSet("sidebarAppName",appname);
	data.sidebarapppath = apppath;
	data.sidebarappname = appname;
	/* Sidebar-open is the canonical save trigger. Every install / uninstall /
	   update / xmlInstall path lives behind a sidebar button, so the snapshot
	   is guaranteed to be fresh before any navigation away from /Apps. */
	saveState();

	$(".popUpBack").addClass("ca_hide");
	$(".sidenav").removeClass("sidenavHide");
	$(".nav-user.show").hide();
	$("#sidenavContent").html($("#sidebarLoading").html());
	$(".sidebar").show();
		post({action:'getPopupDescription',appName:appname,appPath:apppath},function(result) {
			myCloseSpinner();
			$("#sidenavContent").html(result.description);
			caRelocatePopupActions();
			caInitSidebarReadmore();
			caLoadSidebarReadmeSections();
			caLoadSidebarTemplateChanges();
			caRenderSidebarRequires();
			/* Bind to the .caMediaGallery wrapper with delegate so all photos +
			   videos inside are a single MFP gallery — MFP picks `image` vs
			   `iframe` per item from the per-element `mfp-<type>` class. The
			   carats / arrow keys / click-to-next now work because gallery
			   options are in object form (the boolean `gallery: true` form
			   never enabled the module — `r.enabled` was undefined). */
			$('.caMediaGallery').magnificPopup({
				delegate: '.screenshot',
				closeMarkup: "<span class='mfp-close magnificPopup caButton popUpClose' aria-label='"+tr("Close")+"' title='"+tr("Close")+"'>&times;</span>",
				/* Gallery mode: don't close on content click — gallery's own
				   navigateByImgClick handles image clicks (advances to next).
				   Otherwise the click both advances AND closes. */
				closeOnContentClick: false,
				removalDelay: 100,
				mainClass: 'mfp-fade',
				gallery: { enabled: true, navigateByImgClick: true, preload: [0,1] },
				zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
				iframe: { patterns: caMfpIframePatterns },
				callbacks: caWithVideoResumeCallbacks({
					beforeOpen: function() {
						/* keepIdentity=true: afterClose below reopens the same
						   sidebar via data.sidebarapp{path,name}, which the
						   default closeSidebar() path would have nuked → the
						   reopen would silently fall through to the first app
						   in displayed.json. */
						closeSidebar(true);
						/* MFP binds keydown(left/right) to gallery.next/prev
						   regardless of item count. With the default loop:true,
						   a single-item gallery wraps back to itself on each
						   key, which re-runs updateItemHTML() and rebuilds the
						   iframe from scratch — reloading the video and losing
						   playback position. Disabling loop makes next()/prev()
						   early-return at both boundaries (0 and length-1), so
						   the keys are no-ops when items.length === 1. */
						this.st.gallery.loop = (this.items && this.items.length > 1);
					},
					afterClose: function() {
						showSidebarApp(data.sidebarapppath,data.sidebarappname);
					}
				})
			});
			/* Stragglers — .screenshot elements that aren't part of a gallery
			   (eg. the popup app icon) get a plain single-item popup.
			   Run them through caWithVideoResumeCallbacks too: the wrapper
			   is a no-op for single-item popups except that its `open` hook
			   clears any leftover .caMfpThumbs / .caHasThumbStrip from a
			   prior gallery's open — MFP keeps m.wrap detached between
			   opens rather than empty, so without this hook the previous
			   app's thumb strip would still be hanging off it. */
			$('.screenshot').not($('.caMediaGallery').find('.screenshot')).magnificPopup({
				type:'image',
				closeMarkup: "<span class='mfp-close magnificPopup caButton popUpClose' aria-label='"+tr("Close")+"' title='"+tr("Close")+"'>&times;</span>",
				closeOnContentClick: true,
				removalDelay: 100,
				mainClass: 'mfp-fade',
				zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
				callbacks: caWithVideoResumeCallbacks({})
			});

			/* App icon → open the media gallery at idx 0 (the hidden
			   .caGalleryIconSeed tile). Lets the icon participate in arrow /
			   carousel navigation alongside screenshots/videos without
			   being painted twice in the visible media row. */
			$('.caIconOpensGallery').off('click.caIconGallery').on('click.caIconGallery', function(ev) {
				ev.preventDefault();
				ev.stopPropagation();
				var $gallery = $('.caMediaGallery');
				if ($gallery.length) $gallery.magnificPopup('open', 0);
			});
			caMountInlineVideoPreviews();
			slideInSidebar();

			if (!data.caReadmoreTopLessBound) {
				data.caReadmoreTopLessBound = true;
				$("#sidenavContent").on("click", ".ca_readless_top", function(e) {
					e.preventDefault();
					e.stopPropagation();
					// This control sits right before the readmore section it controls.
					var $section = $(this).nextAll(".popup_readmore").first();
					if (!$section.length) return;
					// Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
					var $toggle = $section.nextAll(".readmore-js-toggle").first();
					if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
					if ($toggle.length) $toggle.trigger("click");
					else $section.readmore("toggle");
				});
			}

			popUpChart(result);
			/* Support entries now render as inline caButtons in skin.php — no
			   #supportPopup dropdown to attach. Actions still uses the menu. */
			setupContext(result.actionsContext,"#actionsPopup");

			$(".betaPopupText,.popupTableLeft,.upgradePopupText,.installedPopupText").fitText(true);

			postNoSpin({action:'getLastUpdate',ID:result.ID},function(lastUpdate) {
				if (lastUpdate.lastUpdate) {
					$("#template"+result.ID).fadeOut("slow","linear",function() {
						$("#template"+result.ID).html(lastUpdate.lastUpdate);
						$("#template"+result.ID).fadeIn("slow");
					});
				}
			});
		})
}

/**
 * Lazy-load README fragments for `.ReadmeSection` placeholders in the open sidebar.
 *
 * Goes through the PHP backend (`caFetchSidebarSource` action) rather than
 * fetch()ing the upstream README directly. Two reasons:
 *   1. CORS — some repo hosts don't set Access-Control-Allow-Origin, which
 *      broke the old client-side path with a console error and no fallback.
 *   2. Shared on-disk cache — the backend stores the body under
 *      templates-community as `{RepoName}-README.md`, so repeat opens (and
 *      concurrent tabs) reuse one copy. Cache lives until the next appfeed
 *      refresh, same window the old browser HTTP cache was valid for.
 *
 * Falls through to the existing `data-readme-url-fallback` (master branch
 * variant) on first-call failure.
 */
function caLoadSidebarReadmeSections() {
	var $sections = $("#sidenavContent .ReadmeSection[data-readme-url]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		if ($section.data("readmeLoaded") || $section.data("readmeLoading")) {
			return;
		}
		$section.data("readmeLoading", true);
		var readmeId = $section.attr("data-readme-id") || $section.attr("id") || "";
		var url = $section.attr("data-readme-url") || "";
		var fallback = $section.attr("data-readme-url-fallback") || "";
		var repoName = $section.attr("data-readme-repo") || "";
		var appName = $section.attr("data-readme-app") || "";

		/* Server-side fetch + cache. caIsPublicHttpUrlJs is still applied as
		   a belt-and-braces gate — the backend re-validates with the stricter
		   caIsPublicHttpUrl, but failing fast here avoids a round-trip on a
		   URL we already know is unusable. */
		function fetchText(u) {
			if (!caIsPublicHttpUrlJs(u)) return Promise.reject(new Error("URL not allowed"));
			/* $.post directly (not postNoSpin) so the Promise also rejects on
			   transport failures — non-2xx responses, XHR aborts, JSON parse
			   errors. postNoSpin only fires its callback on the success path,
			   which would leave the README section stuck in "Loading…" forever
			   on any backend hiccup. tabId stamped manually since we're
			   bypassing post()'s auto-stamping. */
			return new Promise(function(resolve, reject) {
				$.post(execURL, {
					action: "caFetchSidebarSource",
					url: u,
					repoName: repoName,
					appName: appName,
					kind: "readme",
					noSpinner: true,
					tabId: (typeof data !== "undefined" && data.tabId) ? data.tabId : ""
				})
				.done(function(result) {
					if (result && result.ok && typeof result.content === "string" && result.content !== "") {
						resolve(result.content);
					} else {
						reject(new Error((result && result.message) ? result.message : "fetch failed"));
					}
				})
				.fail(function() { reject(new Error("transport failure")); });
			});
		}
		function paint($current, html, isError) {
			if (isError) {
				$current.find(".ca_readme_body").text(html);
			} else {
				$current.find(".ca_readme_body").html(html);
			}
			$current.data("readmeLoaded", true);
			$current.data("readmeLoading", false);
			caInitSidebarReadmore($current);
		}
		function locateCurrent() {
			/* Re-locate by id in case the sidebar was re-rendered mid-flight.
			   Then verify the placeholder still points at the same URL we set
			   out to fetch — drops the response on the floor if the user has
			   moved on to a different app. */
			var $current = readmeId ? $("#sidenavContent #" + readmeId) : $section;
			if (!$current.length) return null;
			var currentUrl = $current.attr("data-readme-url") || "";
			if (url && currentUrl !== url) return null;
			return $current;
		}

		fetchText(url)
			.catch(function() { return fallback ? fetchText(fallback) : Promise.reject(); })
			.then(function(text) {
				var $current = locateCurrent();
				if (!$current) return;
				paint($current, caSanitizeReadme(text), false);
			})
			.catch(function() {
				var $current = locateCurrent();
				if (!$current) return;
				paint($current, tr("README can't be loaded"), true);
			});
	});
}

/**
 * Lazy-load template change-log HTML for `.ca_template_changes` blocks in the
 * sidebar.
 *
 * The body (a .plg for plugins or a template XML for containers) is fetched
 * by the PHP backend (`caFetchSidebarSource` with kind=changes) so we don't
 * trip CORS on custom-hosted repos, and so the on-disk cache under
 * templates-community is shared across tabs. Cache file is named
 * `{RepoName}-{basename(url)}` which keeps the .plg / .xml suffix from the
 * source URL for debuggability.
 *
 * The `<CHANGES>` element is then extracted via caExtractChangesFromXml and
 * the markdown run through caSanitizeReadme (same strip+marked+DOMPurify+
 * URL allowlist pipeline as README).
 */
function caLoadSidebarTemplateChanges() {
	var $sections = $("#sidenavContent .ca_template_changes[data-changes-url]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		if ($section.data("changesLoaded") || $section.data("changesLoading") || $section.attr("data-changes-loaded") == "1") {
			return;
		}
		$section.data("changesLoading", true);
		var changesId = $section.attr("data-changes-id") || $section.attr("id") || "";
		var url = $section.attr("data-changes-url") || "";
		var repoName = $section.attr("data-changes-repo") || "";

		function locateCurrent() {
			var $current = changesId ? $("#sidenavContent #" + changesId) : $section;
			if (!$current.length) return null;
			var currentUrl = $current.attr("data-changes-url") || "";
			if (url && currentUrl !== url) return null;
			return $current;
		}
		function paint($current, content, isHtml) {
			if (isHtml) $current.html(content);
			else $current.text(content);
			$current.data("changesLoaded", true);
			$current.data("changesLoading", false);
			$current.attr("data-changes-loaded", "1");
		}

		/* Gate the URL through caIsPublicHttpUrlJs before posting so a
		   future drift that lets a feed-controlled value land in the
		   data-changes-url attribute can't make the server pull from a
		   LAN host. The backend re-validates anyway. */
		/* $.post directly (not postNoSpin) so the Promise also rejects on
		   transport failures — non-2xx, XHR aborts, JSON parse errors. The
		   postNoSpin callback only fires on the success path, which would
		   leave the Changes section stuck in "Loading…" on any backend
		   hiccup. See the README block above for the same pattern. */
		var fetchPromise = caIsPublicHttpUrlJs(url)
			? new Promise(function(resolve, reject) {
				$.post(execURL, {
					action: "caFetchSidebarSource",
					url: url,
					repoName: repoName,
					kind: "changes",
					noSpinner: true,
					tabId: (typeof data !== "undefined" && data.tabId) ? data.tabId : ""
				})
				.done(function(result) {
					if (result && result.ok && typeof result.content === "string" && result.content !== "") {
						resolve(result.content);
					} else {
						reject(new Error((result && result.message) ? result.message : "fetch failed"));
					}
				})
				.fail(function() { reject(new Error("transport failure")); });
			})
			: Promise.reject(new Error("URL not allowed"));
		fetchPromise
			.then(function(xmlText) {
				var $current = locateCurrent();
				if (!$current) return;
				var markdown = caExtractChangesFromXml(xmlText);
				if (markdown === "") {
					paint($current, tr("Change log can't be loaded"), false);
					return;
				}
				paint($current, caSanitizeReadme(markdown), true);
			})
			.catch(function() {
				var $current = locateCurrent();
				if (!$current) return;
				paint($current, tr("Change log can't be loaded"), false);
			});
	});
}

/**
 * Render the Additional Requirements block client-side. skin.php emits a
 * placeholder `<div class='ca_requires_pending' data-requires='...'>` with the
 * raw text JSON-encoded in the data attribute; this walks every such div in
 * the freshly-loaded sidebar, pipes the text through the same
 * strip→marked→DOMPurify chain we use for README/Changes, then applies the
 * sidebar-search-link substitution that's unique to this field.
 *
 * No fetch — the data is already in the DOM payload, just deferred-render so
 * the sanitization pipeline matches everywhere else. JSON-decode is defensive
 * against the attribute being absent or malformed.
 */
function caRenderSidebarRequires() {
	var $sections = $("#sidenavContent .ca_requires_pending[data-requires]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		var raw = "";
		try { raw = JSON.parse($section.attr("data-requires") || "\"\""); }
		catch (e) { raw = ""; }
		if (typeof raw !== "string" || raw === "") {
			$section.text("");
		} else {
			/* Normalize the feed/template multi-line encoding before handing to
			   markdown. The feed stores breaks as <br> and indentation as &nbsp;
			   runs; left in, caSanitizeReadme's stripTags drops the < > and leaves
			   a literal "br", and marked escapes the &nbsp; into visible text. So:
			   convert <br> to newlines, collapse &nbsp; to spaces, drop carriage
			   returns (incl. the &#xD; the feed pads lines with), strip the
			   structural leading indentation, then turn \n into a markdown
			   hard-break (two trailing spaces + newline; marked treats "  \n" as a
			   break regardless of the `breaks` option). Whitespace/break only — the
			   result still goes through caSanitizeReadme (stripTags + marked +
			   DOMPurify), so sanitization is unchanged. */
			var normalized = raw
				.replace(/<br\s*\/?>/gi, "\n")
				.replace(/&nbsp;|&#160;|&#xA0;/gi, " ")
				.replace(/&#xD;|&#13;|\r/gi, "")
				.replace(/^[ \t]+/gm, "")
				.replace(/\n/g, "  \n");
			var html = caSanitizeReadme(normalized);
			html = caApplySidebarSearchLinksJs(html);
			$section.html(html);
		}
		$section.removeAttr("data-requires").removeClass("ca_requires_pending");
	});
}

/**
 * Initialize jQuery readmore.js on `.popup_readmore` nodes (optional scoped root); inserts inline “show less” control for readme sections.
 *
 * @param {jQuery|HTMLElement|undefined} [$scope] When set, only initializes within this subtree
 */
function caInitSidebarReadmore($scope) {
	var $targets = $scope ? $scope : $('.popup_readmore');
	$targets.each(function() {
		var $el = $(this);
		// Avoid double-initializing readmore on the same element.
		if ($el.hasClass("readmore-js")) return;
		$el.readmore({
		maxHeight:250,
		moreLink:"<i class='ca_readmore fa fa-chevron-down'> <?=tr("SHOW MORE");?></i>",
		lessLink:"<i class='ca_readmore fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>",
		afterToggle:function(trigger, element, expanded) {
			var $el = $(element);
			if (!$el.hasClass("ReadmeSection")) return;
			$el.prev(".ca_readless_top").remove();
			if (!expanded) return;
			var topLess = "<i class='ca_readmore ca_readless_top fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>";
			$el.before(topLess);
		}
		});
	});
}

/**
 * Apply CSS classes that slide the sidebar into view (`sidenavShow` / `sidenavHide`)
 * and move focus into the dialog so the first interaction inside it actually
 * fires its handler.
 *
 * Without the focus move, opening the sidebar from a card click leaves focus
 * on the card; on mobile the first tap inside the sidebar is consumed by the
 * browser establishing touch focus on the new pane instead of triggering the
 * click handler — the most visible symptom was needing to tap a video
 * thumbnail twice to open it. On desktop the same race occasionally appears
 * when focus didn't transfer cleanly from the opener.
 *
 * `preventScroll:true` avoids the panel jumping when focus lands on it
 * mid-transition (it's still partway off-screen during the 500ms slide).
 * Supported in every browser we target (Chrome 64+, Firefox 68+, Safari 15+).
 */
function slideInSidebar() {
	/* If the mobile hamburger menu happens to be open, fold it away so
	   the sidebar isn't sliding in over a competing fullscreen overlay. */
	if (typeof closeMenu === "function") closeMenu();
	$(".sidenav").addClass("sidenavShow").removeClass("sidenavHide");
	var el = document.querySelector(".sidenav.sidenavShow");
	if (el) el.focus({ preventScroll: true });
}
/**
 * Open sidebar with repository metadata (`getRepoDescription`): restores cookies when opened from a card vs nested navigation; sets up same media popup pattern as {@link showSidebarApp}.
 *
 * @param {string} repository Repository handle from PHP
 */
function showRepoPopup(repository) {
	if ( !repository ) return;
	/* In-place swap of #sidenavContent further down — if the previous
	   sidebar had a live-stats panel running, its NchanSubscriber +
	   SmoothieChart RAF loops would keep firing against detached gauge
	   DOM. Tear them down before navigating to the repo profile.
	   closeSidebar() / popUpChart()'s prelude don't fire on this path
	   because the sidebar transitions in place. */
	if (typeof caStopLiveStats === "function") caStopLiveStats();
	data.repository = repository;
	context.destroy("#actionsPopup");
	var fromCard = false;

	if ( ! $(".sidenavShow").length ) {
		caSessRemove("sidebarAppName");
		caSessRemove("sidebarAppPath");
		var fromCard = true;
	}
	var sidebarAppName = caSessGet("sidebarAppName");
	var sidebarAppPath = caSessGet("sidebarAppPath");

	$("#sidenavContent").html($("#sidebarLoading").html());

	$(".nav-user.show").hide();

	post({action:'getRepoDescription',repository:repository},function(result) {
		$("#sidenavContent").html(result.description);
		caRelocatePopupActions();
		/* Go through slideInSidebar() rather than toggling the classes inline so
		   the dialog focus handoff happens here too — without it, opening a
		   repo popup leaves focus on the originating card and the first tap
		   inside the panel gets eaten. */
		slideInSidebar();
		caInitSidebarReadmore();
		caLoadSidebarReadmeSections();
		if (!data.caReadmoreTopLessBound) {
			data.caReadmoreTopLessBound = true;
			$("#sidenavContent").on("click", ".ca_readless_top", function(e) {
				e.preventDefault();
				e.stopPropagation();
				// This control sits right before the readmore section it controls.
				var $section = $(this).nextAll(".popup_readmore").first();
				if (!$section.length) return;
				// Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
				var $toggle = $section.nextAll(".readmore-js-toggle").first();
				if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
				if ($toggle.length) $toggle.trigger("click");
				else $section.readmore("toggle");
			});
		}

		if (fromCard) {
			$(".popUpBack").addClass("ca_hide");
		} else {
			$(".popUpBack").removeClass("ca_hide");
		}

		/* Same gallery + delegate setup as the app popup, but with the repo-
		   popup callbacks for sidebar restore. Items pick image/iframe type
		   from their own `mfp-image`/`mfp-iframe` class. */
		$('.caMediaGallery').magnificPopup({
			delegate: '.screenshot',
			closeMarkup: "<span class='mfp-close magnificPopup caButton popUpClose' aria-label='"+tr("Close")+"' title='"+tr("Close")+"'>&times;</span>",
			closeOnContentClick: false,    /* gallery's navigateByImgClick handles image clicks */
			removalDelay: 100,
			mainClass: 'mfp-fade',
			gallery: { enabled: true, navigateByImgClick: true, preload: [0,1] },
			zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
			iframe: { patterns: caMfpIframePatterns },
			callbacks: caWithVideoResumeCallbacks({
				beforeOpen: function() {
					/* keepIdentity=true so afterClose's showRepoPopup() reopens
					   to the same repo; without this, closeSidebar() would
					   clear data.sidebarapp{path,name} and the cookies, and
					   the explicit cookie restore in afterClose would be the
					   only thing holding identity together (the in-memory copy
					   used by saveState() would already be gone). */
					closeSidebar(true);
					/* See app-popup gallery: disable loop for 1-item galleries
					   so arrow keys can't re-trigger updateItemHTML() and
					   rebuild the iframe (reloading the video). */
					this.st.gallery.loop = (this.items && this.items.length > 1);
				},
				afterClose: function() {
					$('body').removeClass("mfp-zoom-out-cur");
					$(".sidebar").show();
					caSessSet("sidebarAppName",sidebarAppName);
					caSessSet("sidebarAppPath",sidebarAppPath);
					showRepoPopup(data.repository);
				}
			})
		});
		/* See app-popup straggler comment — caWithVideoResumeCallbacks
		   is needed here too to clear any prior gallery's thumb strip
		   leftover on the detached m.wrap. */
		$('.screenshot').not($('.caMediaGallery').find('.screenshot')).magnificPopup({
			type:'image',
			closeMarkup: "<span class='mfp-close magnificPopup caButton popUpClose' aria-label='"+tr("Close")+"' title='"+tr("Close")+"'>&times;</span>",
			closeOnContentClick: true,
			removalDelay: 100,
			mainClass: 'mfp-fade',
			zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
			callbacks: caWithVideoResumeCallbacks({})
		});

		/* Repo profile icon → open the gallery at idx 0 (hidden seed). */
		$('.caIconOpensGallery').off('click.caIconGallery').on('click.caIconGallery', function(ev) {
			ev.preventDefault();
			ev.stopPropagation();
			var $gallery = $('.caMediaGallery');
			if ($gallery.length) $gallery.magnificPopup('open', 0);
		});
		caMountInlineVideoPreviews();
	});
}

/**
 * Ensure a non-startup sort icon is enabled; if none, reset to server default (`defaultSortOrder` POST).
 */
function checkSortOrder() {
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( !sortButton) {
		$(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
		post({action:"defaultSortOrder"},function(data) {
			$("#defaultSort").addClass("enabledIcon");
		});
	}
}

/**
 * Show in Apps from a Docker Hub result that matched an existing CA template:
 * leave Docker Hub mode and render just that one template (by TemplateURL) in
 * the app store. Posts the showInApps action, the single result counterpart to
 * doSearch.
 *
 * @param {string} templateURL Matched template's TemplateURL.
 * @param {string} [name]      Matched template's display Name (shown in the box).
 */
function caShowInApps(templateURL, name) {
	templateURL = String(templateURL == null ? "" : templateURL);
	if (templateURL === "") return;
	name = String(name == null ? "" : name);

	/* The box shows the friendly template Name. The Clear Search line shows the
	   URL plus the templateURL. The actual lookup posts the raw TemplateURL. */
	var boxTerm = name || templateURL;

	caLeaveDockerMode();
	data.section = "AppStore";
	/* Seed the box and inline search state as a committed term so the search
	   input, the Clear Search toggle and the clear or backspace flow all behave
	   exactly like a normal text search. */
	$("#searchBox").val(boxTerm);
	$("#caInlineSearchBox").val(boxTerm);
	$(".caInlineSearchClear").removeClass("ca_hide");
	if (typeof caInlineSearchSetCommitted === "function") caInlineSearchSetCommitted(boxTerm);
	data.committedSearchFilter = boxTerm;
	data.searchActive = true;
	data.searchFlag = true;
	/* Subtitle override: show the URL on the Clear Search line while the box
	   keeps the Name. Tagged to this committed term so it self clears on any
	   later search or navigation. */
	data.committedSearchSubtitle = "URL:" + templateURL;
	data.committedSearchSubtitleFor = boxTerm;
	caSyncHomeSearchSubtitle(); // flip Home to Clear Search immediately

	hideMultiInstall();
	scrollToTop();
	if (typeof caCloseSearchModal === "function") caCloseSearchModal();
	$("#sortIconArea").show();
	/* Back to normal app store chrome. The Docker Hub button is available and
	   the docker templateSearch toggle is hidden. */
	if (!dockerNotEnabled) {
		$('.dockerSearch').removeClass("ca_hide");
		$('.templateSearch').addClass("ca_hide");
	} else {
		$('.dockerSearch,.templateSearch').addClass("ca_hide");
	}

	/* Same epoch and callback shape as doSearch so this jump runs the normal
	   app store render path. Select All Apps, then refresh the category menu
	   via getCategoriesPresent so only the displayed template categories stay
	   enabled. */
	var myEpoch = ++data.searchEpoch;
	post({ action: 'showInApps', templateURL: templateURL }, function(result) {
		if (myEpoch !== data.searchEpoch) return; // user moved on
		if (typeof enableButtons === "function") enableButtons();
		$(".selectedMenu").removeClass("selectedMenu");
		$(".subCategory").hide();
		$(".allApps").addClass("selectedMenu");
		updateDisplay(result.display_data || result.display);
		caSyncSearchFilterCollapsed();
		data.section = "AppStore";
		/* A TemplateURL deep link has no Name on the client, so adopt the Name
		   the server resolved and show it in the box instead of the raw URL.
		   Re-tag the subtitle override to the new committed term so it keeps
		   matching. Skipped when a Name was passed in, the docker click path. */
		if (!name && result && result.name) {
			var srvName = String(result.name);
			$("#searchBox").val(srvName);
			$("#caInlineSearchBox").val(srvName);
			if (typeof caInlineSearchSetCommitted === "function") caInlineSearchSetCommitted(srvName);
			data.committedSearchFilter = srvName;
			data.committedSearchSubtitleFor = srvName;
		}
		caSyncHomeSearchSubtitle();
		postNoSpin({ action: 'getCategoriesPresent' }, function(result) {
			if (myEpoch !== data.searchEpoch) return; // user moved on
			$(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
			result.forEach(function(category) {
				var menuItem = $.find(".caMenuItem[data-category='" + category + "']");
				$(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
			});
		});
	});
}

/**
 * Enter Docker Hub search mode: disable non-docker categories, hide sort icons, clear section labels, {@link dockerSearch} page 1.
 */
function initDockerSearch() {
	data.docker = "searching docker";
	data.section = "";
	data.selected_category = "";
	$(".selectedMenu").removeClass("selectedMenu");
	/* Categories stay enabled in docker mode — clicking one is a valid way to
	   leave docker and return to the app store (getContent clears data.docker). */
	hideSortIcons();
	$(".subCategory").hide();
	caSyncSearchFilterCollapsed();
	/* Entering docker: the Clear Search line should track the input field, so
	   drop any caShowInApps URL override. Its committed term can equal the
	   docker filter, which would otherwise keep it stuck. */
	data.committedSearchSubtitle = "";
	data.committedSearchSubtitleFor = "";
	caSyncHomeSearchSubtitle();
	dockerSearch(1);
}

/**
 * Query Docker Hub via PHP (`search_dockerhub`) and paint results (supports append for infinite scroll).
 *
 * @param {number|string} pageNumber Hub search page index
 * @param {boolean} [append] Append cards vs replace
 */
function dockerSearch() {
	/* Docker Hub search loads ONE capped page - the server returns up to 100
	   results (page 1) with no pagination. A vague query ("test") returns
	   thousands of near-identical hits; showing the top 100 by Docker Hub's own
	   ranking and nudging the user to a more specific term beats letting them
	   scroll forever. We mark the result fully loaded, which disables infinite
	   scroll, the spacers and the random-access jump for this view. */
	var myDockerEpoch = (data.dockerSearchEpoch || 0) + 1;
	data.dockerSearchEpoch = myDockerEpoch;
	if (searchBoxAwesomplete) searchBoxAwesomplete.close();
	scrollToTop();
	$(".selectedMenu").removeClass("selectedMenu");
	var filter = $('#searchBox').val();
	data.docker = "searching docker";
	$(".dockerSearch").addClass("ca_hide");
	hideMultiInstall();
	$(".templateSearch").removeClass("ca_hide");
	post({action:'search_dockerhub',filter:filter,page:1},function(result) {
		/* Stale response guard: a newer docker search ran, or the user left
		   docker (Apps / Show in Apps / a category click cleared data.docker). */
		if (myDockerEpoch !== data.dockerSearchEpoch || !data.docker) return;
		/* The Clear Search line always tracks the docker input field, so drop
		   any caShowInApps URL override carried in from the single result view. */
		data.committedSearchSubtitle = "";
		data.committedSearchSubtitleFor = "";
		data.committedSearchFilter = $.trim(String(filter || ""));
		caSyncHomeSearchSubtitle();
		data.allLoaded = true;
		updateDisplay(result.display_data || result.display, false);
		caSyncSearchFilterCollapsed();
		/* Free the inline-search concurrency gate so live typing in sticky
		   docker mode flushes any keystrokes queued while this was in flight. */
		if (typeof caInlineSearchOnComplete === "function") caInlineSearchOnComplete();
	});
}

/**
 * Convert a Docker Hub image to a CA XML template: optionally run test container (`dockerConvert.php`) or POST `convert_docker` and open Add Container.
 *
 * @param {string} repo Docker repository string
 * @param {string} descB64 Base64-encoded description from the card (wire format for PHP)
 */
function dockerConvert(repo, descB64) {
	/* descB64 is the card's Description as it was rendered, base64-encoded by
	   the server so it survives passing through an onclick attribute string.
	   We forward it as-is — `convert_docker` base64_decodes it. Single
	   canonical decode point on the server side keeps the wire contract
	   unambiguous.

	   Used to prompt the user "Determine configuration?" — the YES path
	   spun up a test container via dockerConvert.php so `docker inspect`
	   could surface ExposedPorts / Env / Mounts. The convert_docker action
	   now pulls those same fields straight from the Docker Hub registry
	   API (no pull, no test container), so the prompt isn't needed any
	   more — the only path goes through convert_docker and the post()
	   spinner covers the latency of the three API calls. */
	saveState();
	post({ action: 'convert_docker', repo: repo, description: descB64 }, function(result) {
		myCloseAlert();
		/* Gate the redirect on a usable response. Without this, a backend
		   error (network blip on the Hub API path, malformed image config,
		   etc.) would still navigate the user to
		   `/Apps/AddContainer?xmlTemplate=default:undefined` and swallow
		   the real failure reason. Surface an error banner instead. */
		var xml = $.trim((result && result.xml) || "");
		if (!xml) {
			addBannerWarning(tr("Unable to convert this Docker image right now."), true, true);
			return;
		}
		openNewWindow("/Apps/AddContainer?xmlTemplate=default:" + xml);
	});
}

var caSortMenuObserver = null;
/**
 * Subscribe to DOM mutations on `#sortIconOptions` so the sort dropdown label stays in sync (`caRefreshSortMenu`).
 */
function caInitializeSortMenu() {
	caRefreshSortMenu();
	if (caSortMenuObserver) {
		return;
	}
	var sortContainer = $("#sortIconOptions").get(0);
	if (!sortContainer) {
		return;
	}
	caSortMenuObserver = new MutationObserver(function() {
		caRefreshSortMenu();
	});
	caSortMenuObserver.observe(sortContainer, {
		subtree: true,
		attributes: true,
		attributeFilter: ["class"]
	});
}

/**
 * Update `#sortByButton` label from the active `.sortIcons.enabledIcon` and rebuild its context-menu entries from {@link getSortOpts}.
 */
function caRefreshSortMenu() {
	if (!$("#sortByButton").length) {
		return;
	}
	/* Label is always just "Sort" with a sort glyph supplied by CSS via
	   #sortByButton::before — the previous "Sort By: <selection>" form
	   was redundant with the active highlight already visible in the
	   sort-icons row, and made the button overflow on cramped layouts.
	   Wrapped in .caBtnLabel so the @media (max-width: 767px) icon-only
	   rule in community.applications.responsive.css can hide it on
	   narrow viewports alongside the other top-bar buttons. */
	/* Button content: the fa-sort glyph (CSS ::before), then the current-sort
	   indicator icon, then the "Sort" label. caSortIndicatorClass() returns the
	   glyph class for the active sort (or null on a home "Show More" view where
	   every sort icon is startupMore and nothing is selected). The label gets
	   caSortHasInd only when an indicator precedes it, so the 1rem gap before
	   "Sort" appears solely in that case. */
	var ind = caSortIndicatorClass();
	var indHtml = ind ? "<span class='caSortIndIcon " + ind.cls + "'></span>" : "";
	var labelClass = "caBtnLabel" + (ind ? " caSortHasInd" : "");
	$("#sortByButton")
		.html(indHtml + "<span class='" + labelClass + "'><?tr("Sort");?></span>")
		.attr("title", ind ? ind.title : "");
	context.destroy("#sortByButton");
	context.attach("#sortByButton", getSortOpts());
}

/**
 * Map the active sort to its indicator glyph class + label, for the icon shown
 * inside the Sort button. Returns {cls, title} for name asc/desc, downloads, or
 * date added; null when nothing concrete is selected (eg. a home "Show More"
 * view tags every sort icon `startupMore`).
 *
 * @returns {{cls:string,title:string}|null}
 */
function caSortIndicatorClass() {
	var $active = $(".sortIcons.enabledIcon").not(".startupMore").first();
	if (!$active.length) return null;
	return { cls: caSortGlyphClass($active.attr("data-sortBy"), $active.attr("data-sortDir")), title: $.trim($active.text()) };
}

/**
 * Map a sortBy/sortDir pair to its indicator glyph class (shared by the Sort
 * button indicator and the dropdown rows): name asc/desc, downloads, date.
 *
 * @param {string} by  data-sortBy (Name / downloads / FirstSeen)
 * @param {string} dir data-sortDir (Up / Down)
 * @returns {string}
 */
function caSortGlyphClass(by, dir) {
	by  = (by  || "").toLowerCase();
	dir = (dir || "").toLowerCase();
	if (by === "downloads") return "ca_sortInd_downloads";
	if (by === "firstseen") return "ca_sortInd_date";
	return (dir === "down") ? "ca_sortInd_nameDesc" : "ca_sortInd_nameAsc";
}

/**
 * Build context-menu descriptor objects for each `.sortIcons` row (checkmark + click triggers native sort icon).
 *
 * @returns {Array<object>} Items for `context.attach`
 */
function getSortOpts() {
	var sortOpts = [];
	$(".sortIcons").each(function() {
		var sortOption = this;
		var $sortOption = $(sortOption);
		var sortText = $.trim($sortOption.text());
		var isSelected = $sortOption.hasClass("enabledIcon") && !$sortOption.hasClass("startupMore");
		/* Lead each row with the same order glyph used on the Sort button, before
		   the description, so the menu reads the icons and the labels together. */
		var glyph = "<span class='caSortIndIcon caSortMenuIcon " + caSortGlyphClass($sortOption.attr("data-sortBy"), $sortOption.attr("data-sortDir")) + "'></span>";
		var label = isSelected ? "<span class='ca_green'>" + sortText + "</span>" : sortText;
		sortOpts.push({
			icon: isSelected ? "ca_fa-checkmark" : " ",
			text: glyph + label,
			action: function() {
				$(sortOption).trigger("click");
			}
		});
	});
	return sortOpts;
}

/**
 * Background poll: POST `enableActionCentre` to toggle visibility of Action Centre menu entry.
 */
function setupActionCentre() {
	/* Use the post() helper (not raw $.post) so the request carries tabId
	   and matches the rest of CA's request shape. noSpinner keeps this a
	   silent background poll. */
	post({action:'enableActionCentre',noSpinner:true},function(ret) {
		if ( ret.status == "action" ) {
			if ( !$(".actionCentre").is(":visible") ) {
				$(".actionCentre").show();
			}
		} else
			$(".actionCentre").hide();
	});
}

/**
 * Refresh Action Centre visibility then trigger the selected menu (typically after a bulk check-for-updates completes).
 */
function postCheckForUpdates() {
	setupActionCentre();
	$(".selectedMenu").click();
}

/* Sticky "let go of the scrollbar" nudge rendered inside an empty spacer. The
   spacer reserves the scroll height for rows that are not fetched yet, so while
   the user drags the thumb over it (body.caScrollGrabbing) it is the natural
   place to tell them what they are scrubbing past will load when they release.
   Sticky so it stays pinned near the viewport centre wherever they are in the
   (often very tall) spacer. */
function caSpacerHintHtml() {
	/* The inner span reuses the .ca_displayCount class so caUpdateDisplayCount -
	   which already targets that class and derives the range from scrollTop -
	   keeps this label in sync with the toolbar "X - Y of Z" indicator as the
	   user drags, showing where in the list they are scrubbing to. No extra wiring
	   needed; the existing scroll-driven update populates it. */
	return "<div class='caSpacerHint' aria-hidden='true'><span class='caSpacerHintLetter'></span><span class='ca_displayCount'></span></div>";
}
/* Virtualization: evict cards far above the viewport into a top-spacer (so
   scroll height stays the same) and restore them from caCardCache.cache when the
   user scrolls back up. Cards are kept in row-aligned chunks because the float
   layout would mis-pack a partial row. */
function caVirtSpacer() {
	var $spacer = $("#templates_content .ca_virtTopSpacer").first();
	if ($spacer.length) return $spacer;
	var $first = $("#templates_content").find(".ca_holder").first();
	if (!$first.length) return $();
	$spacer = $("<div class='ca_virtTopSpacer'></div>").css({
		width: "100%",
		height: "0px",
		flexBasis: "100%"
	}).html(caSpacerHintHtml());
	$first.before($spacer);
	return $spacer;
}
/**
 * Pixel height of the virtualization top spacer (0 when absent).
 *
 * @returns {number}
 */
function caVirtSpacerHeight() {
	var $s = $("#templates_content .ca_virtTopSpacer").first();
	if (!$s.length) return 0;
	return parseFloat($s[0].style.height) || 0;
}
/**
 * Grow or shrink `#templates_content .ca_virtTopSpacer` height by `deltaPx` (clamped at 0).
 *
 * @param {number} deltaPx Pixel delta (positive adds scroll range for evicted rows)
 */
function caVirtAdjustSpacer(deltaPx) {
	var $s = caVirtSpacer();
	if (!$s.length) return;
	var current = parseFloat($s[0].style.height) || 0;
	var next = Math.max(0, current + deltaPx);
	$s.css("height", next + "px");
}
/* Bottom spacer: a full-width filler kept as the last child of
   .ca_templatesDisplay, sized to the rows that exist on the server but are not
   yet fetched. It makes .mainArea's native scrollbar reflect data.totalApps
   (the full result set) instead of only the cards currently loaded. */
function caVirtBottomSpacer() {
	var $display = $("#templates_content .ca_templatesDisplay").first();
	if (!$display.length) return $();
	var $spacer = $display.children(".ca_virtBottomSpacer").first();
	if (!$spacer.length) {
		$spacer = $("<div class='ca_virtBottomSpacer'></div>").css({
			width: "100%",
			height: "0px",
			flexBasis: "100%"
		}).html(caSpacerHintHtml());
		$display.append($spacer);
	}
	return $spacer;
}
/**
 * Pixel height of the virtualization bottom spacer (0 when absent).
 *
 * @returns {number}
 */
function caVirtBottomSpacerHeight() {
	var $s = $("#templates_content .ca_virtBottomSpacer").first();
	if (!$s.length) return 0;
	return parseFloat($s[0].style.height) || 0;
}
/**
 * Size the bottom spacer to the not-yet-fetched rows below the loaded cards so
 * the native scrollbar tracks data.totalApps. Removed when there is nothing to
 * project (home view, fully-loaded sections, or no known total).
 */
function caVirtUpdateBottomSpacer() {
	var $display = $("#templates_content .ca_templatesDisplay").first();
	if (!$display.length) return;
	if (typeof data === "undefined" || data.allLoaded || !(data.totalApps > 0)) {
		$display.children(".ca_virtBottomSpacer").remove();
		return;
	}
	var $cards = $display.find(".ca_holder");
	if (!$cards.length) {
		$display.children(".ca_virtBottomSpacer").remove();
		return;
	}
	var perRow = caVirtCardsPerRow($cards);
	if (perRow < 1) return;
	var rowHeight = caVirtRowHeight($cards, perRow);
	if (rowHeight <= 0) {
		/* Only one rendered row, so the row-to-row delta is unavailable; fall
		   back to a single card's outer height. */
		var rect = $cards[0].getBoundingClientRect();
		var st = getComputedStyle($cards[0]);
		rowHeight = rect.height + (parseFloat(st.marginTop) || 0) + (parseFloat(st.marginBottom) || 0);
	}
	if (rowHeight <= 0) return;
	/* Rows below the DOM window = unfetched rows AND any loaded rows we evicted
	   into this spacer. Both are "below the last DOM card", so measure from
	   lastInDom (global index offset + lastInDom). Fall back to cache length for
	   legacy paths that never set lastInDom. */
	var domEnd = (typeof caCardCache.lastInDom === "number" && caCardCache.lastInDom >= 0)
		? caCardCache.lastInDom + 1
		: (Array.isArray(caCardCache.cache) ? caCardCache.cache.length : 0);
	var loadedEnd = (parseInt(caCardCache.offset, 10) || 0) + domEnd;
	var remainingBelow = Math.max(0, data.totalApps - loadedEnd);
	var bottomRows = Math.ceil(remainingBelow / perRow);
	/* Nothing below the loaded window (scrolled to the very end): a 0px spacer
	   reserves no scroll space, so drop the element entirely rather than leave a
	   zero-height div whose sticky hint can still peek in at the bottom edge. */
	if (bottomRows <= 0) {
		$display.children(".ca_virtBottomSpacer").remove();
		return;
	}
	var $spacer = caVirtBottomSpacer();
	if (!$spacer.length) return;
	/* Keep it last so appended/restored cards always sit above it. */
	$display.append($spacer);
	$spacer.css("height", (bottomRows * rowHeight) + "px");
}
/**
 * Size the top spacer to all rows above the first DOM card: unfetched rows
 * above the cache (offset) plus loaded rows evicted upward (firstInDom). Formula
 * driven (mirrors the bottom spacer) so it stays correct after a lazy
 * move-to-end / backfill, with no delta drift over many evict/restore cycles.
 */
function caVirtUpdateTopSpacer() {
	var $display = $("#templates_content .ca_templatesDisplay").first();
	if (!$display.length) return;
	if (typeof data === "undefined" || data.allLoaded) {
		/* No rows above the window: remove the element rather than leave a 0px div
		   whose sticky hint could peek in at the top edge (mirrors the bottom). */
		$display.children(".ca_virtTopSpacer").remove();
		return;
	}
	var aboveCount = (parseInt(caCardCache.offset, 10) || 0) + (caCardCache.firstInDom || 0);
	if (aboveCount <= 0) {
		$display.children(".ca_virtTopSpacer").remove();
		return;
	}
	var $cards = $display.find(".ca_holder");
	if (!$cards.length) return;
	var perRow = caVirtCardsPerRow($cards);
	if (perRow < 1) return;
	var rowHeight = caVirtRowHeight($cards, perRow);
	if (rowHeight <= 0) {
		var rect = $cards[0].getBoundingClientRect();
		var st = getComputedStyle($cards[0]);
		rowHeight = rect.height + (parseFloat(st.marginTop) || 0) + (parseFloat(st.marginBottom) || 0);
	}
	if (rowHeight <= 0) return;
	caVirtSpacer().css("height", (Math.ceil(aboveCount / perRow) * rowHeight) + "px");
}
/**
 * Scroll-space height of the not-yet-fetched rows above the cached region
 * (0 when offset === 0). The upward backfill trigger uses this to know when the
 * viewport is nearing the unfetched region and another page should be fetched.
 *
 * @returns {number}
 */
function caVirtUnfetchedAboveHeight() {
	var off = parseInt(caCardCache.offset, 10) || 0;
	if (off <= 0) return 0;
	var $cards = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
	if (!$cards.length) return 0;
	var perRow = caVirtCardsPerRow($cards);
	if (perRow < 1) return 0;
	var rowHeight = caVirtRowHeight($cards, perRow);
	if (rowHeight <= 0) {
		var rect = $cards[0].getBoundingClientRect();
		var st = getComputedStyle($cards[0]);
		rowHeight = rect.height + (parseFloat(st.marginTop) || 0) + (parseFloat(st.marginBottom) || 0);
	}
	if (rowHeight <= 0) return 0;
	return Math.ceil(off / perRow) * rowHeight;
}
/**
 * Count how many `.ca_holder` cards share the first row’s `offsetTop` (cards per row for float layout).
 *
 * @param {jQuery} $cards Card collection
 * @returns {number}
 */
function caVirtCardsPerRow($cards) {
	if (!$cards.length) return 0;
	var firstTop = $cards[0].offsetTop;
	for (var i = 1; i < $cards.length; i++) {
		if ($cards[i].offsetTop !== firstTop) return i;
	}
	return $cards.length;
}
/**
 * Vertical distance between the first card in row 0 and the first card in row 1.
 *
 * @param {jQuery} $cards Card collection
 * @param {number} perRow From {@link caVirtCardsPerRow}
 * @returns {number}
 */
function caVirtRowHeight($cards, perRow) {
	if (perRow < 1 || $cards.length <= perRow) return 0;
	return $cards[perRow].offsetTop - $cards[0].offsetTop;
}
/**
 * Single source of truth for "which global card row sits at the top of the
 * viewport", derived from the scrollbar fraction across the FULL scroll height
 * (spacers included). The display-count label AND the random-access jump both
 * read this, so the position the user sees and the page that gets fetched can
 * never disagree (a drift there lands you on blank cards). Also returns the
 * measured per-row / row-height so callers can map the row back to a pixel
 * scrollTop in the same layout. Null when the grid is not measurable.
 *
 * @param {HTMLElement} el Scroll container (.mainArea)
 * @param {jQuery} $cards Rendered .ca_holder cards
 * @param {number} total data.totalApps
