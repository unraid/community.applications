/* Per-tab id: sessionStorage is scoped per browser-tab and survives reloads of
   that same tab, which is exactly what we need so the server-side cache files
   (displayed.{id}.json, etc.) line up with this tab's view. */
(function() {
	/* Migration cleanup: this state moved from cookies to session/local storage
	   in later CA versions. First carry the two persistent preferences over to
	   localStorage so an upgrading user keeps their remembered startup screen,
	   then expire every stale cookie copy. setcookie from the .page PHP runs
	   after headers are sent, so this has to happen client side. */
	["ca_startupButton","ca_selectedMenu"].forEach(function(c) {
		try {
			var m = document.cookie.match(new RegExp("(?:^|; )" + c + "=([^;]*)"));
			if (m && !localStorage.getItem(c)) localStorage.setItem(c, decodeURIComponent(m[1]));
		} catch (e) { /* no-op */ }
	});
	["ca_memoryOverride","ca_apps_referrer","ca_languageSwitch","ca_plugininstallpending","pluginVar","pluginCountVar","ca_categoryText","updateLanguage","sidebarAppPath","sidebarAppName","ca_startupButton","ca_selectedMenu"].forEach(function(c) {
		try {
			document.cookie = c + "=; Max-Age=0; path=/";
			document.cookie = c + "=; Max-Age=0; path=/; SameSite=Lax";
		} catch (e) { /* no-op */ }
	});
	/* When the page is reloading specifically to kick off a pending multi-plugin
	   install (see updateContent → ca_openPlugin via the ca_plugininstallpending
	   cookie), defer setting the swal `customClass` default. Unraid's openPlugin
	   uses swal internally, and our customClass leaks our `body:has(.ca_sweetalert_open)`
	   stacking rules into that modal, leaving it parked behind the main display.
	   We re-arm the default right after the openPlugin call so subsequent CA
	   swals still pick it up. */
	var caPendingPluginInstall = false;
	try { caPendingPluginInstall = !!sessionStorage.getItem("ca_plugininstallpending"); } catch (e) {}
	if ( ! caPendingPluginInstall ) {
		swal.setDefaults({ customClass: "ca_sweetalert_open" });
	}

