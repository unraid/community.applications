/**
 * POST `previous_apps` and re-sort the grid for Installed / Previous / Action lists.
 *
 * @param {boolean|string} installed Mode flag (see {@link previousApps})
 * @param {string} filter Passed through to PHP
 * @param {boolean} dontClear When false, clears multi-select for previous/action views
 */
function getPrevApps(installed,filter,dontClear) {
	data.maxPerPage = getMaxPerPage();
	post({action:'previous_apps',installed:installed,filter:filter,maxPerPage:data.maxPerPage},function(result) {
		if ( installed == true ) {
			$(".multi_installDiv").hide();
		} else {
			$(".multi_installDiv").show();
			if ( ! dontClear ) {
				clearMultiInstall();
			}
			if ( installed == "action" )
				$(".multi_deleteButton,.multi_installButton").addClass("actionCenter");
			else
				$(".multi_deleteButton,.multi_installButton").removeClass("actionCenter");
		}
		switch(installed) {
			case true:
				var msg = "<?tr("Installed Apps");?>";
				break;
			case false:
				var msg = "<?tr("Previous Apps");?>";
				break;
			case "action":
				var msg = "<?tr("Action Centre");?>";
				break;
		}
	 // $(".category").html(msg);
		changeSortOrder(null,null,"true");
		enableMultiInstall();
	});
}

/**
