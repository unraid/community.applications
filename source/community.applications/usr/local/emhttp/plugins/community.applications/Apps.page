/**
 * Close the description sidebar: optionally preserve cookies, tear down context menus, submit dirty settings forms, and animate `sidenav` closed.
 *
 * @param {boolean} [cookie=false] When false, clear `sidebarAppPath` / `sidebarAppName` cookies
 * @param {boolean} [visible=false] Legacy visibility hint (unused)
 */
/* keepIdentity (true) → callers that intend to reopen the sidebar to the same
   app right after closing it (post-install refresh, MagnificPopup gallery's
   beforeOpen → afterClose round-trip, etc). Keep the cookies, the in-memory
   data.sidebarapp{path,name}, AND the sessionStorage ca_state sidebar fields
   so the reopen has somewhere to point. Default (false) is the normal user-
   initiated close: wipe all three so a later saveState / page reload doesn't
   silently auto-reopen the app the user just dismissed. The legacy parameter
   name `cookie` is kept as an alias because external callers (helpers.js, the
   install/update paths) still use it positionally. */
function closeSidebar(keepIdentity=false,visible=false) {
	if ( ! keepIdentity ) {
		$.cookie("sidebarAppPath","",{path:"/;SameSite=Lax"});
		$.cookie("sidebarAppName","",{path:"/;SameSite=Lax"});
		/* Clear the in-memory sidebar identity — without this, a later
		   saveState() call in the same tab (e.g. another sidebar opening, or
		   guiSearchOnUnload) would persist the dismissed app back into the
		   snapshot and the next restore would auto-reopen it. */
		data.sidebarapppath = "";
		data.sidebarappname = "";
		/* Wipe the sidebar identity from the saveState snapshot so a later
		   browser reload doesn't auto-reopen the sidebar to an app the user
		   just explicitly closed. Filter / sort / category / scroll stay
		   intact — only the two sidebar fields are blanked. */
		try {
			var _raw = sessionStorage.getItem("ca_state");
			if (_raw) {
				var _s = JSON.parse(_raw);
				if (_s && typeof _s === "object") {
					_s.sidebarAppPath = "";
					_s.sidebarAppName = "";
					sessionStorage.setItem("ca_state", JSON.stringify(_s));
				}
			}
		} catch (e) { /* no-op */ }
	}
	context.destroy("#actionsPopup");
	/* Drop the relocated per-app action strip so a stale row from the
	   previous app doesn't linger next to CLOSE when the sidebar reopens. */
	$(".popupCloseAreaButtons .popupStickyActions").remove();

	/* If a settings form was open with unsaved edits, submit it instead of just
	   closing — the submit handler saves and reloads, which subsumes closing. */
	var $settingsForm = $("#sidenavContent .ca_settingsForm");
	if ($settingsForm.length) {
		var initialState = $settingsForm.data("caInitialState");
		if (typeof initialState === "string" && $settingsForm.serialize() !== initialState) {
			$settingsForm.trigger("submit");
			return;
		}
	}

	$(".sidenav").removeClass("sidenavShow").addClass("sidenavHide").scrollTop(0);
	$(".nav-user.show").show();
	enableSearch();
}

/**
 * Confirm no other plugin operation is running, check optional upgrade requirements, then {@link actuallyInstallPlugin}.
 *
 * @param {string} pluginURL URL or path passed to `checkPluginInProgress`
 * @param {boolean} [update=false] Upgrade vs fresh install
 * @param {string} [requires=''] Dependency string for upgrade checks
 */
function installPlugin(pluginURL,update=false,requires="") {
	post({action:"checkPluginInProgress",pluginPath:pluginURL},function(data) {
		if (data.inProgress) {
			swal({
				title: "<?tr("Installation already in progress");?>",
				text: "<?tr("This plugin is currently being installed or uninstalled.  Wait until the current operation is completed and try again");?>",
				allowOutsideClick: false,
				showConfirmButton: true,
				showCancelButton: false,
				confirmButtonText: "<?tr("OK");?>",
				type: "warning"
			},function() {
				enableSearch();
			});
		} else {
			if ( update && requires ) {
				post({action:"checkRequirements",requires:requires},function(data) {
					if (! data.met) {
						swal({
							title: "<?tr('Requirements not met');?>",
							text: "<?tr('The requirements for this upgrade have not been met on your system');?>",
							allowOutsideClick: false,
							showConfirmButton: true,
							showCancelButton: false,
							confirmButtonText: "<?tr('OK');?>",
							type: "error",
							html: true
						},function(isConfirm) {
							enableSearch();
						});
					} else {
						actuallyInstallPlugin(pluginURL,update);
					}
				});
			} else {
				actuallyInstallPlugin(pluginURL,update);
			}
		}
	});
}

/**
 * Close sidebar, hide matching pending-action rows, pick post-install callback (`actionCentre` vs sidebar refresh), {@link ca_openPlugin}.
 *
 * @param {string} pluginURL Resolved install/update URL (proxied for new installs)
 * @param {boolean} [update=false]
 */
function actuallyInstallPlugin(pluginURL,update=false) {
	var type = update ? "update" : "install";
	if ( ! update ) {
		pluginURL = "<?=CA_PATHS['pluginProxy']?>" + pluginURL;
	}
	title = update ? "<?tr("Update Plugin");?>" : "<?tr("Install Plugin");?>";
	closeSidebar(true);
	hidePluginPending(pluginURL);

	if ( $(".selectedMenu").data("category") == "action_centre" ) {
		var postFunction = "actionCentre";
	} else {
		var postFunction = "OpenSidebarAndRefreshDisplay";
	}
	data.deprecated = false; // global var here to trigger a rescan of action centre
	if ( pluginURL.includes("&deprecated") || pluginURL.includes("&incompatible") ) {
		data.deprecated = true;
		pluginURL = pluginURL.replace("&deprecated","");
		pluginURL = pluginURL.replace("&incompatible","");
	}
	ca_openPlugin('plugin '+type+' '+pluginURL,title,'',postFunction);
}

/**
 * Hide Action Centre rows for a plugin whose install is now underway (match full URL or basename).
 *
 * @param {string} pluginURL
 */
function hidePluginPending(pluginURL) {
	if ( pluginURL.includes("/") ) {
		$(".actionsButton").each(function() {
			if ( $(this).data("pluginurl") == pluginURL || $(this).data("pluginurl")+"&deprecated" == pluginURL ) {
				$(this).hide();
			}
		});
	} else {
		$(".actionsButton").each(function() {
			if ( $(this).data("pluginurl").basename() == pluginURL ) {
				$(this).hide();
			}
		});
	}
}

/**
 * Hide Action Centre rows for a language pack about to be installed/updated/removed.
 *
 * @param {string} language Pack id or filename (`lang-` prefix / `.xml` stripped)
 */
function hideLanguagePending(language) {
	language = language.replace("lang-","");
	language = language.replace(".xml","");
	if ( ! language )
		return;

	$(".actionsButton").each(function() {
		if ( $(this).data("languagepack") == language ) {
			$(this).hide();
		}
	});
}

/**
 * After plugin install flows: reload the page when PHP reports startup, otherwise refresh the grid and reopen any saved sidebar app.
 */
function OpenSidebarAndRefreshDisplay() {
	post({action:"onStartupScreen"},function(result) {
		if (result.status) {
			window.location.reload();
		} else {
			var apppath = $.cookie("sidebarAppPath");
			var appname = $.cookie("sidebarAppName");

			appname = stripTags(appname);

			refreshDisplay();
			if ( $.trim(apppath) ) {
				showSidebarApp(apppath,appname);
			}
			if ( data.deprecated ) {
				data.deprecated = false;
				setupActionCentre();
			}

		}
	});
}

