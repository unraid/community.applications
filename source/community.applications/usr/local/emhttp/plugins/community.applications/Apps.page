			$(".multi_deleteButton").show();
		var buttonText = (count == 1) ? sprintf(tr(actionText + " <?tr("%s Selected Application")?>"),count) : sprintf(tr(actionText + " <?tr("%s Selected Applications")?>"),count);
		$(".multi_installButton").val(buttonText);
	}
	getSelectedApps();
}

