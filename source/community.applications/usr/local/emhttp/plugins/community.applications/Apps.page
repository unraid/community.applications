/* MagnificPopup iframe URL patterns for the media gallery. The lib's defaults
   only match `youtube.com/watch?v=...` (so `youtu.be/...` short links never
   get rewritten to the embed URL with autoplay). Override to handle both
   forms and add `mute=1` so the autoplay rule isn't blocked by the browser. */
var caMfpIframePatterns = {
	youtube: {
		index: "youtube.com/",
		id: function(url) {
			var m = url.match(/[?&]v=([A-Za-z0-9_-]+)/);
			return m ? m[1] : url;
		},
		src: "//www.youtube.com/embed/%id%?autoplay=1&mute=1&playsinline=1"
	},
	youtubeShort: {
		index: "youtu.be/",
		id: function(url) {
			var m = url.match(/youtu\.be\/([A-Za-z0-9_-]+)/);
			return m ? m[1] : url;
