   serialized for save-state, and (b) it's pure runtime — derived from
   server responses + the existing changeSortOrder restore path, never
   persisted across navigations. */
var caCardCache = {
	cache: [],       // current loaded slice of cards (HTML strings) — array, not necessarily aligned with global index
	offset: 0,       // global index of caCardCache.cache[0] (non-zero after a jump-load like move-to-end)
	firstInDom: 0    // index within caCardCache.cache of the first card currently in the DOM
};

/* Per-tab id: sessionStorage is scoped per browser-tab and survives reloads of
   that same tab, which is exactly what we need so the server-side cache files
   (displayed.{id}.json, etc.) line up with this tab's view. */
(function() {
	/* When the page is reloading specifically to kick off a pending multi-plugin
	   install (see updateContent → ca_openPlugin via the ca_plugininstallpending
	   cookie), defer setting the swal `customClass` default. Unraid's openPlugin
	   uses swal internally, and our customClass leaks our `body:has(.ca_sweetalert_open)`
	   stacking rules into that modal, leaving it parked behind the main display.
	   We re-arm the default right after the openPlugin call so subsequent CA
	   swals still pick it up. */
	var caPendingPluginInstall = document.cookie.split("; ").some(function(c){
		return c.indexOf("ca_plugininstallpending=") === 0;
	});
	if ( ! caPendingPluginInstall ) {
		swal.setDefaults({ customClass: "ca_sweetalert_open" });
	}

	var key = "ca_tabId";
	var id = "";
	try { id = sessionStorage.getItem(key) || ""; } catch (e) {}
	if (!id) {
		try {
			id = (window.crypto && crypto.randomUUID) ? crypto.randomUUID()
				: (Date.now().toString(36) + Math.random().toString(36).slice(2));
		} catch (e) {
			id = Date.now().toString(36) + Math.random().toString(36).slice(2);
		}
		try { sessionStorage.setItem(key, id); } catch (e) {}
	}
	data.tabId = id;
})();

