 * @param string $string
 * @param bool $ret When true return string; else echo
 * @return string|void
 */
function tr($string,$ret=false) {
	$string = str_replace(['"',"'"],["&#34;","&#39;"],_($string));
	if ( $ret )
		return $string;
	else
		echo $string;
}

