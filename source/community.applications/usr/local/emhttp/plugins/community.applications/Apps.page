/**
 * Load app popup HTML via `getPopupDescription`, wire MagnificPopup galleries, context menus, charts, and async readme/change sections.
 *
 * @param {string} apppath Template path key
 * @param {string} appname Human-readable application name
 */
function showSidebarApp(apppath,appname) {
	mySpinner();
	disableSearch();
	$.cookie("sidebarAppPath",apppath,{path:"/;SameSite=Lax"});
	$.cookie("sidebarAppName",appname,{path:"/;SameSite=Lax"});
	data.sidebarapppath = apppath;
	data.sidebarappname = appname;

	$(".popUpBack").addClass("ca_hide");
	$(".sidenav").removeClass("sidenavHide");
	$(".nav-user.show").hide();
	$("#sidenavContent").html($("#sidebarLoading").html());
	$(".sidebar").show();
		post({action:'getPopupDescription',appName:appname,appPath:apppath},function(result) {
			myCloseSpinner();
			$("#sidenavContent").html(result.description);
			caInitSidebarReadmore();
			caLoadSidebarReadmeSections();
			caLoadSidebarTemplateChanges();
			/* Bind to the .caMediaGallery wrapper with delegate so all photos +
			   videos inside are a single MFP gallery — MFP picks `image` vs
			   `iframe` per item from the per-element `mfp-<type>` class. The
			   carats / arrow keys / click-to-next now work because gallery
			   options are in object form (the boolean `gallery: true` form
			   never enabled the module — `r.enabled` was undefined). */
			$('.caMediaGallery').magnificPopup({
				delegate: '.screenshot',
				closeMarkup: "<span class='mfp-close magnificPopup caButton'>"+tr("CLOSE")+"</span>",
				/* Gallery mode: don't close on content click — gallery's own
				   navigateByImgClick handles image clicks (advances to next).
				   Otherwise the click both advances AND closes. */
				closeOnContentClick: false,
				removalDelay: 100,
				mainClass: 'mfp-fade',
				gallery: { enabled: true, navigateByImgClick: true, preload: [0,1] },
				zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
				iframe: { patterns: caMfpIframePatterns },
				callbacks: {
					beforeOpen: function() {
						closeSidebar();
					},
					afterClose: function() {
						showSidebarApp(data.sidebarapppath,data.sidebarappname);
					}
				}
			});
			/* Stragglers — .screenshot elements that aren't part of a gallery
			   (eg. the popup app icon) get a plain single-item popup. */
			$('.screenshot').not($('.caMediaGallery').find('.screenshot')).magnificPopup({
				type:'image',
				closeMarkup: "<span class='mfp-close magnificPopup caButton'>"+tr("CLOSE")+"</span>",
				closeOnContentClick: true,
				removalDelay: 100,
				mainClass: 'mfp-fade',
				zoom: { enabled: true, duration: 500, easing: 'ease-in-out' }
			});
			slideInSidebar();

			if (!data.caReadmoreTopLessBound) {
				data.caReadmoreTopLessBound = true;
				$("#sidenavContent").on("click", ".ca_readless_top", function(e) {
					e.preventDefault();
					e.stopPropagation();
					// This control sits right before the readmore section it controls.
					var $section = $(this).nextAll(".popup_readmore").first();
					if (!$section.length) return;
					// Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
					var $toggle = $section.nextAll(".readmore-js-toggle").first();
					if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
					if ($toggle.length) $toggle.trigger("click");
					else $section.readmore("toggle");
				});
			}

			popUpChart(result);
			setupContext(result.supportContext,"#supportPopup");
			setupContext(result.actionsContext,"#actionsPopup");

			$(".betaPopupText,.popupTableLeft,.upgradePopupText,.installedPopupText").fitText(true);

			postNoSpin({action:'getLastUpdate',ID:result.ID},function(lastUpdate) {
				if (lastUpdate.lastUpdate) {
					$("#template"+result.ID).fadeOut("slow","linear",function() {
						$("#template"+result.ID).html(lastUpdate.lastUpdate);
						$("#template"+result.ID).fadeIn("slow");
					});
				}
			});
		})
}

/**
 * Lazy-load README fragments for `.ReadmeSection` placeholders in the open sidebar (`getReadmeSection` POST per section).
 */
function caLoadSidebarReadmeSections() {
	var $sections = $("#sidenavContent .ReadmeSection[data-readme-url]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		if ($section.data("readmeLoaded") || $section.data("readmeLoading")) {
			return;
		}
		$section.data("readmeLoading", true);
		var readmeId = $section.attr("data-readme-id") || $section.attr("id") || "";
		var url = $section.attr("data-readme-url") || "";
		var fallback = $section.attr("data-readme-url-fallback") || "";
		postNoSpin({action:"getReadmeSection", readmeId: readmeId, url:url, fallback:fallback}, function(resp) {
			// Late responses must only update the currently displayed placeholder for this readmeId.
			var $current = readmeId ? $("#sidenavContent #" + readmeId) : $section;
			// If the user navigated away, the placeholder won't exist anymore: do nothing.
			if (!$current.length) return;
			var currentUrl = $current.attr("data-readme-url") || "";
			// Guard against re-use / DOM replacement while request was in flight.
			if (url && currentUrl !== url) return;

			if (resp && resp.html) $current.find(".ca_readme_body").html(resp.html);
			else $current.find(".ca_readme_body").text((resp && resp.message) ? resp.message : "README can't be loaded");
			$current.data("readmeLoaded", true);
			$current.data("readmeLoading", false);

			// Initialize readmore for this section now (don't wait for other readmes).
			caInitSidebarReadmore($current);
		});
	});
}

/**
 * Lazy-load template change-log HTML for `.ca_template_changes` blocks in the sidebar (`getTemplateChanges`).
 */
function caLoadSidebarTemplateChanges() {
	var $sections = $("#sidenavContent .ca_template_changes[data-changes-url]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		if ($section.data("changesLoaded") || $section.data("changesLoading") || $section.attr("data-changes-loaded") == "1") {
			return;
		}
		$section.data("changesLoading", true);
		var changesId = $section.attr("data-changes-id") || $section.attr("id") || "";
		var url = $section.attr("data-changes-url") || "";
		var cacheKey = $section.attr("data-changes-cachekey") || "";
		var type = $section.attr("data-changes-type") || "";

		postNoSpin({action:"getTemplateChanges", changesId: changesId, url:url, cacheKey: cacheKey, type: type}, function(resp) {
			var $current = changesId ? $("#sidenavContent #" + changesId) : $section;
			if (!$current.length) return;
			var currentUrl = $current.attr("data-changes-url") || "";
			if (url && currentUrl !== url) return;

			if (resp && resp.html) $current.html(resp.html);
			else $current.text((resp && resp.message) ? resp.message : "Change log can't be loaded");

			$current.data("changesLoaded", true);
			$current.data("changesLoading", false);
			$current.attr("data-changes-loaded", "1");
		});
	});
}

/**
 * Initialize jQuery readmore.js on `.popup_readmore` nodes (optional scoped root); inserts inline “show less” control for readme sections.
 *
 * @param {jQuery|HTMLElement|undefined} [$scope] When set, only initializes within this subtree
 */
function caInitSidebarReadmore($scope) {
	var $targets = $scope ? $scope : $('.popup_readmore');
	$targets.each(function() {
		var $el = $(this);
		// Avoid double-initializing readmore on the same element.
		if ($el.hasClass("readmore-js")) return;
		$el.readmore({
		maxHeight:250,
		moreLink:"<i class='ca_readmore fa fa-chevron-down'> <?=tr("SHOW MORE");?></i>",
		lessLink:"<i class='ca_readmore fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>",
		afterToggle:function(trigger, element, expanded) {
			var $el = $(element);
			if (!$el.hasClass("ReadmeSection")) return;
			$el.prev(".ca_readless_top").remove();
			if (!expanded) return;
			var topLess = "<i class='ca_readmore ca_readless_top fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>";
			$el.before(topLess);
		}
		});
	});
}

