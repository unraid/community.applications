		if (gapAbove <= farGap && gapBelow <= farGap) return false;
		/* Hand off to the deferred/gated path: caReevaluateJump waits out an
		   in-flight fetch or a held thumb, then re-reads the live position and
		   does a page-1 reset near the top or a page fetch elsewhere. */
		window.caJumpPending = true;
		if (jumpTimer) clearTimeout(jumpTimer);
		jumpTimer = setTimeout(function() {
			if (!window.caJumpPending) return;
			window.caJumpPending = false;
			window.caReevaluateJump();
		}, 120);
		return true;
	};

	/* CA's own scroll controls (.ca_back_to_top / .ca_move_to_end). dynamix's
	   .back_to_top / .move_to_end are left alone so other plugins keep working;
	   ours operate on whichever pane is currently the user-facing scroller —
	   .sidenav when the sidebar is open, otherwise .mainArea. Visibility is
	   driven from the same scroll events the rest of CA already uses. */
	var $backTop = $(".ca_back_to_top");
	var $moveEnd = $(".ca_move_to_end");
	var caGetActiveScroller = function() {
		var $sidenav = $(".sidenav.sidenavShow");
		if ($sidenav.length) return $sidenav[0];
		return $(".mainArea")[0];
	};
	$backTop.on("click", function(e) {
		e.preventDefault();
		var s = caGetActiveScroller();
		/* Jump instantly rather than animating. A gradual scroll-up fights the
		   virtualization restore (caVirtUpdate refills rows and shrinks the top
		   spacer a few at a time), making it crawl; an instant jump trips the
		   big-jump reset in caVirtUpdate instead, which reloads page 1 cleanly. */
		if (s) { $(s).stop(true, true); s.scrollTop = 0; }
		return false;
	});
	$moveEnd.on("click", function(e) {
		e.preventDefault();
		var s = caGetActiveScroller();
		if (!s) return false;

		/* Sidebar mode: content is already entirely in the DOM, just scroll
		   to its bottom — no fetch needed (and the Apps grid pagination logic
		   below would be irrelevant anyway). */
		if ($(".sidenav.sidenavShow").length) {
			$(s).stop(true, true);
			s.scrollTop = s.scrollHeight;
			return false;
		}

		/* Home page (no .ca_templatesDisplay): everything is already in the
		   DOM — just scroll to the bottom of the viewport, no fetch needed. */
		if (!$("#templates_content .ca_templatesDisplay").length) {
			$(s).stop(true, true);
			s.scrollTop = s.scrollHeight;
			return false;
		}

		var total = parseInt(data.totalApps, 10) || 0;
		if (total <= 0) return false;

		if (data.docker) {
			/* Docker Hub search is a single fully-loaded page now — every result
			   is already in the DOM, so just scroll to the bottom (no fetch). */
			$(s).stop(true, true);
			s.scrollTop = s.scrollHeight;
			return false;
		}

		/* Apps grid: jump to the LAST page only, then let triggerPrev backfill
		   upward as the user scrolls. The fresh render sets caCardCache.offset
		   from the page number, so the top spacer represents every row above the
		   last page and the native scrollbar still reflects the full result set —
		   without loading thousands of cards in one request. */
		var perPage = parseInt(data.maxPerPage, 10) || 12;
		var lastPage = Math.max(1, Math.ceil(total / perPage));
		data.currentpage = lastPage;
		var postFnEnd = data.searchInProgress ? postNoSpin : post;
		postFnEnd({action:'display_content', pageNumber:lastPage, selected:data.selected, maxPerPage:perPage}, function(result) {
			updateDisplay(result.display_data || result.display, false);
			/* Drop straight to the bottom; the top spacer holds the (empty) space
			   for all earlier pages, which backfill on scroll-up. */
			var ma2 = $(".mainArea")[0];
			if (ma2) ma2.scrollTop = ma2.scrollHeight;
			/* One page (12 cards) rarely fills the viewport, so actively backfill
			   upward until the visible area above the last page is covered: restore
			   any cached rows, then fetch earlier pages when the cache above runs
			   out, stopping when there is no top-spacer gap left in the viewport or
			   page 1 is reached. Mirrors caEnsureScrollable for the upward case. */
			var fillIter = 0;
			var fillUp = function() {
				var m = $(".mainArea")[0];
				if (!m || fillIter++ > 40) return;
				if (data.loadingMore) { setTimeout(fillUp, 80); return; }
				caVirtUpdate();
				var gap = caVirtSpacerHeight() - m.scrollTop; // top-spacer px visible above the viewport top
				if (gap <= 1) return;
				if ((caCardCache.firstInDom || 0) > 0) { setTimeout(fillUp, 30); return; }
				if ((parseInt(caCardCache.offset, 10) || 0) <= 0) return;
				triggerPrev();
				setTimeout(fillUp, 80);
			};
			setTimeout(fillUp, 60);
		});
		return false;
	});
	var caUpdateScrollControls = window.caUpdateScrollControls = function() {
		/* Fresh queries each call so a removed/re-added element or a class
		   change still gets picked up. */
		var $bt = $(".ca_back_to_top");
		var $me = $(".ca_move_to_end");
		if (!$bt.length && !$me.length) return;
		var s = caGetActiveScroller();
		if (!s) return;
		var atTop = s.scrollTop <= 0;
		var atBottom = s.scrollTop + s.clientHeight >= s.scrollHeight - 1;
		var canScroll = s.scrollHeight - s.clientHeight > 1;
		var showBack = canScroll && !atTop;
		var showEnd  = canScroll && !atBottom;
		if ($bt.length && ($bt.data("caShown") || false) !== showBack) {
			$bt.data("caShown", showBack);
			$bt.stop(true, true)[showBack ? "fadeIn" : "fadeOut"](500);
		}
		if ($me.length && ($me.data("caShown") || false) !== showEnd) {
			$me.data("caShown", showEnd);
			$me.stop(true, true)[showEnd ? "fadeIn" : "fadeOut"](500);
		}
	};
	/* Initial state: hide both until we know the page actually scrolls. */
	$backTop.hide().data("caShown", false);
	$moveEnd.hide().data("caShown", false);
	caUpdateScrollControls();
	/* Native scrollbars replaced the JS overlay that used to drive these
	   updates, so listen for scrolls directly. Capture phase catches scroll on
	   whichever inner pane is the active scroller (.mainArea, .sidenav,
	   .menuItems, .ca_homeTemplates) since scroll events don't bubble. */
	document.addEventListener("scroll", function() { caUpdateScrollControls(); }, true);
	/* Re-check after first paint so the initial values reflect post-layout
	   scroll dimensions, not whatever they are at attach time. */
	requestAnimationFrame(function() { caUpdateScrollControls(); });
	setTimeout(function() { caUpdateScrollControls(); }, 250);

	/* Sidebar open/close changes the active scroller, so recompute when its
	   class list flips between sidenavShow / sidenavHide. */
	(function() {
		var sn = $(".sidenav")[0];
		if (!sn || typeof MutationObserver !== "function") return;
		new MutationObserver(function() { caUpdateScrollControls(); })
			.observe(sn, { attributes: true, attributeFilter: ["class"] });
	})();

	$(".mainArea").on("scroll", function() {
		if (!virtScheduled) {
			virtScheduled = true;
			requestAnimationFrame(function() {
				virtScheduled = false;
				caVirtUpdate();
			});
		}
		caUpdateDisplayCount();
		var el = this;
		/* Scrollbar click / thumb-drag to a far position: jump straight to that
		   page rather than sequentially paging there. When a jump is pending the
		   sequential triggers below are skipped (they'd fetch the wrong page). */
		if (maybeJump(el)) return;
		/* Upward backfill: when the viewport nears the not-yet-fetched rows above
		   the cache (offset > 0, e.g. after a lazy move-to-end), pull the previous
		   page in. Mirror of the downward trigger below. */
		if (caCardCache.offset > 0) {
			var topGap = el.scrollTop - caVirtUnfetchedAboveHeight();
			if (topGap < 600) triggerPrev();
		}
		/* Trigger against the bottom of the loaded cards, not the absolute
		   scroll bottom: the bottom spacer represents unfetched rows, so the
		   real fetch boundary is scrollHeight minus that spacer. */
		var bottomGap = el.scrollHeight - caVirtBottomSpacerHeight() - el.clientHeight - el.scrollTop;
		if (bottomGap > 600) return;
		triggerNext();
	});

	$(".mainArea").on("wheel touchmove mousedown", function(e) {
		if (data.alphaJump) data.alphaJump = null;
		if (e.type !== "mousedown") {
			data.alphaWheelActive = true;
			clearTimeout(data.alphaWheelTimer);
			data.alphaWheelTimer = setTimeout(function() { data.alphaWheelActive = false; }, 400);
		}
	});

	/* When the user is parked at the exact scroll bottom, the browser stops
	   firing scroll events on further wheel/touch attempts — so a "scroll past
	   the end" gesture wouldn't pull the next page. Catch that intent directly
	   from the wheel/touch input. */
	$(".mainArea").on("wheel", function(e) {
		var dy = e.originalEvent ? e.originalEvent.deltaY : 0;
		if (dy <= 0) return; // only downward
		var el = this;
		if (el.scrollTop + el.clientHeight >= el.scrollHeight - 2) {
			triggerNext();
		}
	});
	var touchStartY = 0;
	$(".mainArea").on("touchstart", function(e) {
		var t = e.originalEvent && e.originalEvent.touches && e.originalEvent.touches[0];
		touchStartY = t ? t.clientY : 0;
	});
	$(".mainArea").on("touchmove", function(e) {
		var t = e.originalEvent && e.originalEvent.touches && e.originalEvent.touches[0];
		if (!t) return;
		if (touchStartY - t.clientY < 12) return; // upward swipe = scroll down; require modest distance
		var el = this;
		if (el.scrollTop + el.clientHeight >= el.scrollHeight - 2) {
			triggerNext();
		}
	});

	/* Global (0-based) index of the card currently at the top of the viewport,
	   derived the same way as the "Displaying X - Y" indicator. Used to keep the
	   user roughly in place across a page-size re-base. */
	var caCurrentTopGlobalIndex = function() {
		var ma = $(".mainArea")[0];
		var $cards = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
		var off = parseInt(caCardCache.offset, 10) || 0;
		var firstInDom = caCardCache.firstInDom || 0;
		if (!ma || !$cards.length) return off + firstInDom;
		var perRow = caVirtCardsPerRow($cards);
		if (perRow < 1) return off + firstInDom;
		var rowH = caVirtRowHeight($cards, perRow);
		if (rowH <= 0) {
			var rc = $cards[0].getBoundingClientRect();
			var rs = getComputedStyle($cards[0]);
			rowH = rc.height + (parseFloat(rs.marginTop) || 0) + (parseFloat(rs.marginBottom) || 0);
		}
		if (rowH <= 0) return off + firstInDom;
		var spacerH = caVirtSpacerHeight();
		var scrolledRows = Math.max(0, Math.floor((ma.scrollTop - spacerH) / rowH));
		return off + firstInDom + scrolledRows * perRow;
	};
	/* Re-base pagination after a viewport change (e.g. browser zoom): recompute
	   the viewport-sized page count, and if it changed, re-fetch the page that
	   contains whatever card was at the top and scroll that exact card back to
	   the top. We won't be pixel-identical but we land on the same app. Apps
	   grid only. */
	var caRebaseForViewport = function() {
		if (data.docker || data.allLoaded || data.loadingMore) return;
		if (!$("#templates_content .ca_templatesDisplay").length) return;
		if (!(parseInt(data.totalApps, 10) > 0)) return;
		var newMax = getMaxPerPage();
		var oldMax = parseInt(data.maxPerPage, 10) || 12;
		if (!newMax || newMax === oldMax) return; // count unchanged; the fast path already re-fit the spacers
		var G = caCurrentTopGlobalIndex();
		data.maxPerPage = newMax;
		var targetPage = Math.floor(G / newMax) + 1;
		data.loadingMore = true;
		var postFn = data.searchInProgress ? postNoSpin : post;
		postFn({action:'display_content', pageNumber:targetPage, selected:data.selected, maxPerPage:newMax}, function(result) {
			updateDisplay(result.display_data || result.display, false);
			var ma = $(".mainArea")[0];
			var $c = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
			var off = parseInt(caCardCache.offset, 10) || 0;
			var idxInPage = G - off;
			if (ma && $c.length && idxInPage >= 0 && idxInPage < $c.length) {
				ma.scrollTop = $c[idxInPage].getBoundingClientRect().top - ma.getBoundingClientRect().top + ma.scrollTop;
			}
		});
	};
	/* Zoom-out / window-resize can leave the page non-scrollable even though
	   more results exist on the server — without a scrollbar the infinite-scroll
	   handler never fires. The fast timer re-fits spacers / pulls pages so the
	   layout stays scrollable; the slow timer re-bases the page size to the new
	   viewport (debounced ~1s so a continuous zoom/drag doesn't thrash fetches). */
	var resizeTimer = null;
	var rebaseTimer = null;
	var onResize = function() {
		if (resizeTimer) clearTimeout(resizeTimer);
		resizeTimer = setTimeout(function() {
			resizeTimer = null;
			caVirtUpdateTopSpacer();
			caVirtUpdateBottomSpacer();
			caEnsureScrollable();
			/* Action bar can wrap to additional rows at narrow widths — re-sync
			   the bottom-padding variable so #sidenavContent never disappears
			   behind a taller fixed bar after a resize. */
			if (typeof caSyncSidenavBottomPadding === "function") caSyncSidenavBottomPadding();
			if (typeof caRethinAlphaBar === "function") caRethinAlphaBar();
		}, 150);
		if (rebaseTimer) clearTimeout(rebaseTimer);
		rebaseTimer = setTimeout(function() {
			rebaseTimer = null;
			caRebaseForViewport();
		}, 1000);
	};
	$(window).on("resize", onResize);
	if (window.visualViewport) {
		$(window.visualViewport).on("resize", onResize);
	}
	// A resize or orientation change can alter the bar height without changing
	// maxPerPage (which stays clamped at 12 or higher), so the viewport rebase
	// skips. Re-thin the A-Z index for the new height when it is shown, debounced
	// so resize and orientation triggers coalesce into one pass.
	var alphaRethinTimer = null;
	var caRethinAlphaBar = function() {
		if (alphaRethinTimer) clearTimeout(alphaRethinTimer);
		alphaRethinTimer = setTimeout(function() {
			alphaRethinTimer = null;
			var $bar = $("#caAlphaBar");
			if ($bar.length && !$bar.hasClass("ca_hide") && $.isArray(data.alphaAll) && typeof caUpdateAlphaBar === "function") {
				caUpdateAlphaBar(data.alphaAll);
			}
		}, 200);
	};
	if (window.matchMedia) {
		var caOrientationMq = window.matchMedia("(orientation: portrait)");
		if (caOrientationMq.addEventListener) caOrientationMq.addEventListener("change", caRethinAlphaBar);
		else if (caOrientationMq.addListener) caOrientationMq.addListener(caRethinAlphaBar);
	} else {
		$(window).on("orientationchange", caRethinAlphaBar);
	}
}
$(caInitInfiniteScroll);

</script>
