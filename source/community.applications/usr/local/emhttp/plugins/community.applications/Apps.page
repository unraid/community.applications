/**
 * Open sidebar with repository metadata (`getRepoDescription`): restores cookies when opened from a card vs nested navigation; sets up same media popup pattern as {@link showSidebarApp}.
 *
 * @param {string} repository Repository handle from PHP
 */
function showRepoPopup(repository) {
	if ( !repository ) return;
	data.repository = repository;
	context.destroy("#supportPopup");
	context.destroy("#actionsPopup");
	var fromCard = false;

	if ( ! $(".sidenavShow").length ) {
		$.cookie("sidebarAppName","",{path:"/;SameSite=Lax"});
		$.cookie("sidebarAppPath","",{path:"/;SameSite=Lax"});
		var fromCard = true;
	}
	var sidebarAppName = $.cookie("sidebarAppName");
	var sidebarAppPath = $.cookie("sidebarAppPath");

	$("#sidenavContent").html($("#sidebarLoading").html());

	$(".nav-user.show").hide();

	post({action:'getRepoDescription',repository:repository},function(result) {
		$("#sidenavContent").html(result.description);
		$(".sidenav").removeClass("sidenavHide").addClass("sidenavShow");
		caInitSidebarReadmore();
		caLoadSidebarReadmeSections();
		if (!data.caReadmoreTopLessBound) {
			data.caReadmoreTopLessBound = true;
			$("#sidenavContent").on("click", ".ca_readless_top", function(e) {
				e.preventDefault();
				e.stopPropagation();
				// This control sits right before the readmore section it controls.
				var $section = $(this).nextAll(".popup_readmore").first();
				if (!$section.length) return;
				// Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
				var $toggle = $section.nextAll(".readmore-js-toggle").first();
				if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
				if ($toggle.length) $toggle.trigger("click");
				else $section.readmore("toggle");
			});
		}

		if (fromCard) {
			$(".popUpBack").addClass("ca_hide");
		} else {
			$(".popUpBack").removeClass("ca_hide");
		}

		/* Same gallery + delegate setup as the app popup, but with the repo-
		   popup callbacks for sidebar restore. Items pick image/iframe type
		   from their own `mfp-image`/`mfp-iframe` class. */
		$('.caMediaGallery').magnificPopup({
			delegate: '.screenshot',
			closeMarkup: "<span class='mfp-close magnificPopup caButton'>"+tr("CLOSE")+"</span>",
			closeOnContentClick: false,    /* gallery's navigateByImgClick handles image clicks */
			removalDelay: 100,
			mainClass: 'mfp-fade',
			gallery: { enabled: true, navigateByImgClick: true, preload: [0,1] },
			zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
			iframe: { patterns: caMfpIframePatterns },
			callbacks: {
				beforeOpen: function() {
					closeSidebar();
				},
				afterClose: function() {
					$('body').removeClass("mfp-zoom-out-cur");
					$(".sidebar").show();
					$.cookie("sidebarAppName",sidebarAppName,{path:"/;SameSite=Lax"});
					$.cookie("sidebarAppPath",sidebarAppPath,{path:"/;SameSite=Lax"});
					showRepoPopup(data.repository);
				}
			}
		});
		$('.screenshot').not($('.caMediaGallery').find('.screenshot')).magnificPopup({
			type:'image',
			closeMarkup: "<span class='mfp-close magnificPopup caButton'>"+tr("CLOSE")+"</span>",
			closeOnContentClick: true,
			removalDelay: 100,
			mainClass: 'mfp-fade',
			zoom: { enabled: true, duration: 500, easing: 'ease-in-out' }
		});
	});
}

