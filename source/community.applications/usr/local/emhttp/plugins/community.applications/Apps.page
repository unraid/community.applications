		};
		var caInstallDialogOpen = function() {
			return $("#sb-nav").is(":visible");
		};
		if (caInstallDialogOpen()) {
			var poll = setInterval(function() {
				if ( ! caInstallDialogOpen()) {
					clearInterval(poll);
					fireReloadNotice();
				}
			}, 1000);
			return;
		}
		fireReloadNotice();
	}
	window.caHandleForeignFeedUpdate = caHandleForeignFeedUpdate;

	caInitializeSortMenu();
	caInitializeClickHandlers();
	caInitializeEventHandlers();
	caSyncSearchFilterCollapsed();
	caSyncHomeSearchSubtitle();

	/* Everything is now initialized.  This is the start of the actual "real" code */

	if ( "<?=$firstRun?>" == "true" ) {
		$(".ca_templatesDisplay").hide();
		swal({
			title: "<?tr("Disclaimer");?>",
			text: '<?tr('All applications listed here are 3rd party additions to Unraid.  Community Applications contains both docker containers and plugin applications.  Plugins are designed for OS enhancements, and run with full privileges on your system and are clearly identified within CA.  Neither the authors of Community Applications nor Limetech make any warranty as to the suitability of any application listed here');?> <br><span class="ca_italic"><font color="green"><?tr('Every attempt is made to ensure that only safe and compatible applications are present');?></font></span><br><br><center><a href="https://forums.unraid.net/topic/87144-ca-application-policies/" target="_blank"><?tr('Application / Privacy Policy');?></a>',
			html: true,
			type: 'warning',
			showCancelButton: true,
			showConfirmButton: true,
			cancelButtonText: "<?tr('Cancel');?>",
			confirmButtonText: "<?tr('I Understand');?>"
		}, function (isConfirm) {
			if ( isConfirm ) {
				post({action:'dismiss_warning'},function(result) {
					location.reload();
				});
			} else {
			$(".ca_templatesDisplay").show();
				addBannerWarning("<?tr("Installations of apps disabled.  You must accept the warning to be able to install applications.");?>   <a onclick='window.location.reload();' style='cursor:pointer;'><?tr("Click here");?></a>",true,true);
				updateContent();
			}
		});
	}	else {
		/* Restore state when we came back from a child URL of /Apps (Docker, plugin
		   install pages, etc.). document.referrer covers the "Done" button case;
		   the ca_apps_referrer cookie — set by ca_browser_back_helper.page on every Unraid
		   page load while the URL is under /Apps/ and cleared as soon as it
		   isn't — covers the browser-back case where the referrer is empty.
		   State now lives in sessionStorage (was cookies); saveState() writes
		   it at the top of showSidebarApp, so the snapshot is guaranteed to be
		   present whenever the user took an action that could navigate away. */
		var caSavedState = caReadSavedState();
		/* On a browser reload (F5 / Cmd-R / address-bar Enter), the saveState
		   snapshot still carries the last sidebarAppPath/Name from the install
		   round-trip — but a reload is the user explicitly asking for a fresh
		   page, so don't auto-reopen the sidebar to an app they may have
		   already closed. Blank just the sidebar fields; filter / sort /
		   category / scroll stay intact. */
		try {
			var _navEntries = performance.getEntriesByType && performance.getEntriesByType("navigation");
			if (caSavedState && _navEntries && _navEntries[0] && _navEntries[0].type === "reload") {
				caSavedState.sidebarAppPath = "";
				caSavedState.sidebarAppName = "";
				try {
					sessionStorage.setItem("ca_state", JSON.stringify(caSavedState));
				} catch (e) { /* no-op */ }
			}
		} catch (e) { /* no-op */ }
		var caCameFromAppsChild = (
			(document.referrer.indexOf("/Apps/") > 1)
			|| (caSessGet("ca_apps_referrer") === "true")
		);
		var caCanRestore = (
			/* An explicit templateURL deep link is a direct request for one
			   template and must win over saved-state restore, otherwise this tab
			   would reopen the prior view instead of the requested app. */
			!startupTemplateURL
			&& "<?=$startupDisplayed?>" != "true"
			&& caCameFromAppsChild
			&& ("<?=$dockerConvertFlag?>" != "true")
			&& caSavedState
			&& !caSavedState.wasHome
		);
		/* Register this tab with the server before any other request. The
		   server creates a marker file at CA_PATHS['registeredTabs']/{tabId}
		   that gets wiped by DownloadApplicationFeed when another tab
		   triggers a fresh feed pull.

		   Arming caFeedTrackingArmed is gated on TWO events both completing:
		     1. registerTab acked — the marker exists server-side
		     2. bootstrap settled — downloadStatistics returned, which both
		        the restore and non-restore boot paths fire as their last
		        sequential step
		   Without (2), in-flight bootstrap requests (force_update_skip,
		   hydrateFullFeed, getCategories) would start carrying caFeedCheck
		   mid-load — a concurrent feed refresh in another tab could then
		   pop the "another browser updated" banner during page load
		   instead of on the next user action. */
		postNoSpin({action:'registerTab'}, function(result) {
			if (result && result.status === 'ok') {
				window.caRegisterTabAcked = true;
				caMaybeArmFeedCheck();
			}
		});
		if ( caCanRestore ) {
			getCategories();
			restoreState(caSavedState);
			<? if ( $dockerSearchActive ):?>
				dockerSearch(data.currentpage);
			<? else:?>
				/* If the user was past page 1 when they left, fetch every card from
				   page 1 through their saved page in one bulk request so they can
				   freely scroll back to earlier results, then snap the viewport to
				   where they were. */
				var _restoreSavedPage = parseInt(data.currentpage, 10) || 1;
				var _restorePerPage = parseInt(data.maxPerPage, 10) || 12;
				if (_restoreSavedPage > 1) {
					data.maxPerPage = _restoreSavedPage * _restorePerPage;
					data.currentpage = 1;
					changePage(1, false);
				} else {
					refreshDisplay();
				}
				/* Scroll restore — independent of the page>1 bulk-fetch path so it
				   handles both. Targets the literal pixel scrollY saved at
				   sidebar-open (vs. the old card-boundary approximation that
				   landed users at the start of their saved page instead of the
				   actual position). Polls until .mainArea is tall enough that
				   scrolling to scrollY is meaningful, then sets scrollTop. Capped
				   at ~6s of polling so we don't loop forever if rendering never
				   reaches the saved depth (rare, but possible if filter results
				   shrunk between save and restore). */
				var _scrollTarget = parseInt(caSavedState.scrollY, 10) || 0;
				if (_scrollTarget > 0) {
					var _scrollAttempts = 0;
					var _scrollRestore = function() {
						var ma = $(".mainArea")[0];
						if (!ma) return;
						/* Either we have enough DOM height to honour the target,
						   or we've polled enough — apply and exit either way. */
						if (ma.scrollHeight >= _scrollTarget + ma.clientHeight || ++_scrollAttempts > 60) {
							ma.scrollTop = _scrollTarget;
							return;
						}
						setTimeout(_scrollRestore, 100);
					};
					setTimeout(_scrollRestore, 200);
				}
				searchBoxAwesomplete.close();
				if ( caSavedState.sidebarAppPath ) {
					showSidebarApp(caSavedState.sidebarAppPath, caSavedState.sidebarAppName);
				}
			<? endif;?>
			/* Restore path doesn't go through updateContent → downloadStatistics,
			   so kick off downloadStatistics() directly. Beyond fetching stats,
			   this is what arms the ca_gettingTemplates subscriber — without it
			   a restored tab would never see the "another instance updated the
			   feed" reload banner. */
			downloadStatistics();
		} else {
			post({action:"defaultSortOrder"},function() {
				myAlert("","<div class='ca_center caLogoIcon'></div><?tr('Community Applications');?><br><br><?tr('Updating Applications');?><br><span class='updateContent-swal'>"+tr('Please Wait')+"</span><div class='caDownloadProgress ca_hide'><span class='caDownloadProgressText'></span><div class='caButton ca_quitUpdate'>"+tr('Abort')+"</div></div>","","",false,false,false,"");

				updateContent(false,false);
			 // clearTimeout(downloadStatusTimer);
				/* Home / wasHome case: the templates-view restore is intentionally
				   skipped (the home view has no .ca_templatesDisplay grid to
				   restore into — see saveState()). But the user was looking at
				   an app in the sidebar when they navigated away, so reopen it
				   once the home paint settles. Gated on caSavedState.wasHome so
				   we only reopen for an *explicit* home snapshot — not for
				   non-home snapshots that happened to skip the if-branch for
				   other reasons (dockerConvertFlag, mismatched referrer, etc.). */
				if ( caSavedState && caSavedState.wasHome && caSavedState.sidebarAppPath && caCameFromAppsChild && ("<?=$dockerConvertFlag?>" != "true") ) {
					showSidebarApp(caSavedState.sidebarAppPath, caSavedState.sidebarAppName);
				}
			});
		}
		setupActionCentre();
		/* Submenu disable-state sync is chained inside getCategories() so it
		   can't race with the wholesale caMenuEnabled reset there — both
		   bootstrap branches above route through getCategories(). */
		/* Consume the ca_apps_referrer value now that we've used it — fresh
		   visits to Apps (not from a child URL) shouldn't auto-restore state. */
		caSessRemove("ca_apps_referrer");
	}
	<?endif;?>
});

/**
 * Hide sort controls (flows such as startup views where the user should not change sort).
 */
function disableSort() {
	hideSortIcons();
}
/**
 * Hide the sort-by control row (`#sortIconArea`).
 */
function hideSortIcons() {
	$("#sortIconArea").hide();
}
/**
 * Show the sort-by control row (`#sortIconArea`).
 */
function showSortIcons() {
	$("#sortIconArea").show();
}
/**
 * Queue a plugin operation through Unraid `openPlugin`, rewriting `plugin install` to `downloadPlugin`, and dismiss CA alerts first.
 *
 * @param {string} cmd Full command (`plugin install` / `plugin update` / `multiplugin` / etc.)
 * @param {string} title Dialog title passed to `openPlugin`
 * @param {string} plg Plugin identifier argument for `openPlugin`
 * @param {string} func Global callback name when the operation finishes (e.g. `refresh`, `actionCentre`)
 */
function ca_openPlugin(cmd,title,plg,func) {
	if ( cmd.startsWith("plugin install") ) {
		cmd = "downloadPlugin "+cmd;
	}
	setTimeout(function(){
		// force the install to run even if another install is already in progress
		openPlugin(cmd,title,plg,func,"",1);
		myCloseAlert();
	},250);
}

/**
 * Pull the cached monthly-spotlight symbol sprite from the server and drop it
 * into the holder div at the bottom of skin.html. The page-load copy is emitted
 * into that same holder by skin.html, but a live feed refresh rebuilds the cache
 * server-side without reloading the page, so this fetches the fresh sprite
 * (same-origin, no CORS) and replaces the holder's contents. Always the same
 * spotlight_svg_holder node, so the sprite never moves around the DOM. use
 * references in the skin resolve regardless of where they sit relative to it.
 */
function caInjectSpotlightSprite() {
	postNoSpin({action:'getSpotlightSprite'}, function(result) {
		if ( ! result || ! result.ok || ! result.html ) return;
		$(".spotlight_svg_holder").html(result.html);
	});
}

/**
 * Refresh templates and redraw the store: reset search UI, apply startup category from cookie or clicked button, POST `force_update` (or `force_update_skip`), then reload listing or restore an in-progress search.
 *
 * @param {HTMLElement} [button] Optional menu item whose `data-category` becomes the active startup screen
 * @param {boolean} [skipAppfeed=true] When true, use `force_update_skip` to avoid blocking on full appfeed work
 */
function updateContent(button,skipAppfeed=true) {
	clearSearchBox();
	clearCategory();
	$(".caMenuItem").removeClass("selectedMenu");
	$(".subCategory").hide();

	startupScreen = caLocalGet("ca_startupButton") ? caLocalGet("ca_startupButton") : "onlynew";
	var $startupMatch = $(".caMenuItem[data-category='"+startupScreen+"']");
	if ($startupMatch.filter(".caCategoryAll").length) {
		$startupMatch = $startupMatch.filter(".caCategoryAll");
		/* Reveal the parent's sub wrapper so the active "All" is visible. */
		$startupMatch.closest(".subCategory").show();
	}
	$startupMatch.addClass("selectedMenu");

	startupScreen = button ? $(button).data("category") : startupScreen;
	caLocalSet("ca_startupButton",startupScreen);
	caLocalSet("ca_selectedMenu",startupScreen);
	disableSearch();
	var postAction = skipAppfeed ? "force_update_skip" : "force_update";
	/* No feed update on this init? Wipe the docker info cache so a stale
	   snapshot can't leak through. (A feed update path already wipes the
	   whole tempFiles dir, so we don't double-fire there.) */
	if (skipAppfeed && typeof caDropInfoCache === "function") caDropInfoCache();
	post({action:postAction}, function(result) {
		/* A fresh feed download rebuilt the spotlight sprite cache server-side
		   (the tempFiles wipe took the page-load copy's backing file with it),
		   so pull the new one and swap it into the DOM without a full reload. */
		if ( result.spotlightSpriteUpdated ) caInjectSpotlightSprite();
		if ( result.data ) {
			updateDisplay(result.data);
		} else {
			data.searchActive = false;
			if ( startupTemplateURL ) {
				/* Deep link by TemplateURL. caShowInApps manages its own button
				   visibility and resolves the Name from the server response. */
				caShowInApps(startupTemplateURL);
				populateAutoComplete();
				startupTemplateURL = "";
			} else if ( startupSearch ) {
				doSearch(false,startupSearch);
				populateAutoComplete();
				startupSearch = "";
				$(".dockerSearch,.templateSearch").addClass("ca_hide");
			} else {
				getContent(true,'INITIALIZE',"","",startupScreen);
			}
		}
		/* If the initial download used the slim feed, the full templates
		   cache is empty — kick off a background hydrate so install-time
		   port-conflict detection and createXML have Config available by
		   the time the user clicks Install. Server short-circuits with
		   `already_fresh` when the full cache is already on disk, so this
		   is safe to call unconditionally.

		   On completion, if a sidebar happens to be open and showing the
		   "Unavailable until feed downloads" notice (the slim-only render
		   from skin.php's full-cache guard), surgically swap just the
		   .popupStickyActions block with the freshly-rendered version
		   from the server — no full sidebar reload, no spinner flicker,
		   just the buttons appearing in place. */
		postNoSpin({action:'hydrateFullFeed'}, function(hydrateResult) {
			if (hydrateResult && hydrateResult.status === 'failed') return;
			if (!data.sidebarapppath) return;
			if (!$('.popupActionsAreaInner .caFeedPending').length) return;
			/* Snapshot the app identity we're about to fetch, so the
			   callback can verify the same app is still in the sidebar
			   when the response arrives. Without this, a fast user opening
			   a different (also pending) sidebar between request and
			   response would have the new sidebar's action row clobbered
			   with the PREVIOUS app's buttons. */
			var requestedAppName = data.sidebarappname;
			var requestedAppPath = data.sidebarapppath;
			postNoSpin({action:'getPopupDescription', appName: requestedAppName, appPath: requestedAppPath}, function(popResult) {
				if (!popResult || !popResult.description) return;
				/* Sidebar might have closed or navigated to a different app
				   while the popup re-fetch was in flight — re-check both
				   the pending notice AND that the open sidebar is still
				   the same app we requested before touching the DOM. */
				if (!$('.popupActionsAreaInner .caFeedPending').length) return;
				if (data.sidebarappname !== requestedAppName || data.sidebarapppath !== requestedAppPath) return;
				var $tmp = $('<div>').html(popResult.description);
				var $newActions = $tmp.find('.popupStickyActions').first();
				if ($newActions.length) {
					$('.popupActionsAreaInner .popupStickyActions').replaceWith($newActions);
					caSyncSidenavBottomPadding();
				}
			});
		});
		getCategories(); /* now also re-applies count-based submenu gating */
		if ( caSessGet("ca_plugininstallpending") ) {
			var plugins = caSessGet("ca_plugininstallpending");
			caSessRemove("ca_plugininstallpending");
			myCloseAlert();
			post({action:'saveMultiPluginPending',plugin:plugins},function(data) {
				ca_openPlugin('multiplugin install '+plugins,"<?tr('Install Plugin Applications');?>",'','refresh');
				/* Re-arm the swal customClass default once openPlugin's modal is
				   on screen — see the deferral note in the IIFE near line 250. */
				setTimeout(function(){ swal.setDefaults({ customClass: "ca_sweetalert_open" }); }, 1500);
			});
		}
	});
}

/**
 * Enter a spotlight / startup category from the left menu: ensure a real sort is selected, then delegate to {@link showSpecials}.
 *
 * @param {HTMLElement} button Menu row with `data-category`
 */
function showSpecialCategory(button) {
	closeSidebar();
	clearSearchBox();
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( !sortButton) {
		$(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
		post({action:"defaultSortOrder"},function(data) {
			$("#defaultSort").addClass("enabledIcon");
			showSpecials(button)
		});
	} else {
		showSpecials(button);
	}
}

/**
 * Show startup-style storefront content: clear normal selection, set App Store section, grey out repository-aware menu.
 *
 * @param {HTMLElement} button Passed through to {@link changeCategory}
 */
function showSpecials(button) {
	showSortIcons();
	$(".caMenuItem").removeClass("selectedMenu");
	hideMultiInstall();
	data.selected_category = "DOESNTMATTERWHATSHERE";
	data.section = "AppStore";
	changeCategory(button,false);
	$(".caRepositoryMenu").addClass("caMenuDisabled").removeClass("caMenuEnabled");
	//$(".category").append(" - <?tr("Installs not allowed from this page");?>");
}

/**
 * Load templates for a sidebar category via {@link getContent}.
 *
 * @param {HTMLElement} button Menu item (`data-category`, label text)
 * @param {*} subSwitch Legacy argument (unused)
 */
function changeCategory(button,subSwitch) {
	var description = $(button).text();
	var category = $(button).attr("data-category");

	hideMultiInstall();
	getContent(false,category,description,false);
}

/**
 * Fetch a page of cards from the server (`display_content`), optionally appending for infinite scroll.
 *
 * @param {number|string} pageNumber 1-based page index
 * @param {boolean} [append] When true, append HTML/cards to the current grid
 */
function changePage(pageNumber, append) {
	pageNumber = parseInt(pageNumber, 10) || 1;
	/* append: true = forward infinite-scroll, "prepend" = upward backfill,
	   false = full replace (resets scroll to top). */
	var mode = (append === "prepend") ? "prepend" : !!append;
	caRestoreCommittedSearchIfDrafted();
	if (searchBoxAwesomplete) searchBoxAwesomplete.close();
	var selected = data.selected;
	data.currentpage = pageNumber;

	/* When this fires as part of an in-flight live search (doSearch sets
	   data.searchInProgress around its postNoSpin chain), route through
	   postNoSpin so the spinner doesn't flash and the inline pill doesn't
	   collapse mid-stream. User-driven infinite-scroll / pagination falls
	   through to plain post() — that's the very interaction we want to
	   trigger the collapse. */
	var postFn = data.searchInProgress ? postNoSpin : post;
	/* Snapshot the cache generation now; if a reset (caVirtResetToPageOne) bumps
	   it while this request is in flight, the response is stale - applying its
	   append/prepend would corrupt the freshly reset cache, so drop it. The reset
	   already cleared data.loadingMore and issued its own page-1 fetch. */
	var reqGen = caCardCache.generation || 0;
	postFn({action:'display_content',pageNumber:pageNumber,selected:selected,maxPerPage:data.maxPerPage},function(result) {
		if ((caCardCache.generation || 0) !== reqGen) return;
		updateDisplay(result.display_data || result.display, mode);
		if (mode === false) scrollToTop();
	});
}

/**
 * Close SweetAlert and spinner chrome and call {@link enableSearch}.
 *
 * @param {boolean} [force=false] When true, `swal.close` bypasses some guard paths (legacy)
 */
function myCloseAlert(force=false) {

	swal.close();
	$("div.spinner, .sweet-alert").hide();
	enableSearch();
}

/**
 * Close any modal, collapse the sidebar, and run {@link doSearch} with `newSearch`.
 *
 * @param {string} newSearch Committed search string
 */
function doSidebarSearch(newSearch) {
	swal.close();
	closeSidebar();
	var term = String(newSearch == null ? "" : newSearch);
	/* A URL: prefix means jump straight to that one template by its TemplateURL,
	   the Show in Apps view, instead of running a general text search. The
	   prefix match is case insensitive. */
	var urlMatch = term.match(/^\s*URL:(.+)$/i);
	if (urlMatch && typeof caShowInApps === "function") {
		caShowInApps($.trim(urlMatch[1]));
		return;
	}
	doSearch(false, term);
}

/**
 * Run template search (or navigate home when cleared): manages `searchActive`, Docker vs template toggles, commits filter, POSTs `get_content`.
 *
 * @param {*} button Legacy; often `false` means “use current `#searchBox` value”
 * @param {string|false} [newSearch] When a string, pre-fills the search box before filtering
 */
function doSearch(button,newSearch) {
	if ( data.searchInProgress )
		return;

	data.searchInProgress = true;

	if ( ! newSearch === false ) {
		$('#searchBox').val(newSearch);
	}
	var filter = $('#searchBox').val();
	filter = $.trim(filter);
	filter = stripTags(filter);

	/* Drop the one-shot "Show All Results" override the moment the user
	   edits the search term. The override is scoped to the exact filter
	   that earned it; anything else and we're back to whatever the user
	   set under "Limit searches to name". */
	if (data.searchLimitOverride && filter !== data.searchLimitOverrideFilter) {
		data.searchLimitOverride = false;
		data.searchLimitOverrideFilter = "";
	}

	/* Sticky Docker Hub search: once a Docker Hub search has run, keep search
	   input (live typing, Enter, autocomplete picks) going to Docker Hub
	   instead of reverting to the app store. Only the Apps / Home button and
	   menu navigation drop out of docker mode (they clear data.docker). An
	   empty filter falls through to the normal clear handling below. */
	if (data.docker && filter) {
		$('#searchBox').val(filter);
		data.searchInProgress = false;
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		if (filter !== $.trim(String(data.committedSearchFilter || ""))) {
			dockerSearch(1);
		} else if (typeof caInlineSearchOnComplete === "function") {
			caInlineSearchOnComplete();   // same term — just free the inline-search gate
		}
		return;
	}

	/* No-op: term hasn't changed from the currently committed search.
	   Close the modal; if maxPerPage changed (viewport/layout changed), re-render current
	   search pagination via changePage so cards-per-page and page mapping stay consistent. */
	var committedFilter = $.trim(String(data.committedSearchFilter || ""));
	var hasActiveAppSearch = !!(data.searchActive || data.searchFlag) && !data.docker;
	if (filter && hasActiveAppSearch && filter === committedFilter) {
		$('#searchBox').val(filter);
		data.searchInProgress = false;
		if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
			$('.dockerSearch').removeClass("ca_hide");
			$('.templateSearch').addClass("ca_hide");
		} else {
			$('.dockerSearch,.templateSearch').addClass("ca_hide");
		}
		var nextMax = getMaxPerPage();
		var oldMax = Math.max(1, parseInt(data.maxPerPage, 10) || 1);
		var maxChanged = nextMax && nextMax > 0 && nextMax !== oldMax;
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		if (maxChanged && typeof changePage === "function") {
			/* Trigger page-geometry banner by passing a different page token.
			   changePage() will remap to the correct page based on old first-visible index. */
			var curPage = Math.max(1, parseInt(data.currentpage, 10) || 1);
			changePage(curPage === 1 ? 2 : 1);
		}
		return;
	}

	if ( ! filter ) {
		$("#searchBox").val(filter);
		data.searchInProgress = false;
		if ( data.searchActive || data.searchFlag || data.docker ) {
			if (typeof caCloseSearchModal === "function") caCloseSearchModal();
			var $homeBtn = $(".startupButton").first();
			if ($homeBtn.length) {
				$homeBtn.trigger("click");
			} else {
				appStore();
			}
			return;
		}
		data.committedSearchFilter = "";
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		else caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
		return;
	}

	caLeaveDockerMode();
	data.section = "AppStore";

	$('#searchBox').val(filter);
	hideMultiInstall();

	scrollToTop();
	if (filter) {
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		$("#sortIconArea").show();
	 // $(".category").html(sprintf("<?tr("Search for %s")?>",filter));
		data.searchFlag = true;
	} else {
		if (searchBoxAwesomplete) searchBoxAwesomplete.close();
		/* Cleared filter: only leave search / go home via updateContent when a search was actually active. Draft text alone must not trigger home. */
		if (data.searchActive || data.searchFlag || data.docker) {
			updateContent();
		}
		data.searchFlag = false;
		data.searchInProgress = false;
		data.committedSearchFilter = "";
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		else caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
		return;
	}
	data.searchActive = true;

	if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
		$('.dockerSearch').removeClass("ca_hide");
		$('.templateSearch').addClass("ca_hide");
	} else {
		$('.dockerSearch,.templateSearch').addClass("ca_hide");
	}

	data.searchInProgress = true;
	data.committedSearchFilter = filter;
	/* A real text search owns its own subtitle, so drop any caShowInApps URL
	   override here to keep it from reappearing under a same named query. */
	data.committedSearchSubtitle = "";
	data.committedSearchSubtitleFor = "";
	caSyncHomeSearchSubtitle();

	data.maxPerPage = getMaxPerPage();
	/* Per-request epoch token. Each doSearch call bumps the counter
	   and snapshots the new value; if a later side-action (e.g. user
	   switching to Installed / Previous / a section menu — which call
	   caInvalidateSearchEpoch via clearSearchBox) changes the global,
	   our two callbacks below detect that and bail out instead of
	   stomping the new view with stale search results. */
	var myEpoch = ++data.searchEpoch;
	/* Live search uses postNoSpin: no spinner flash on every keystroke,
	   and because postNoSpin sets noSpinner=true the post() callback's
	   inline-pill collapse + unselected-subs hide are both skipped — so
	   typing doesn't fold the input away or fight menu state. Nested
	   getCategoriesPresent uses the same route. */
	postNoSpin({action:'get_content',filter:filter,maxPerPage:data.maxPerPage,searchLimitOverride:data.searchLimitOverride?1:0},function(result) {
		if (myEpoch !== data.searchEpoch) return; // user moved on
		enableButtons();
		$(".selectedMenu").removeClass("selectedMenu");
		$(".subCategory").hide();
		$(".allApps").addClass("selectedMenu");
		updateDisplay(result.display_data || result.display);
		caSyncSearchFilterCollapsed();
		data.section = "AppStore";
		postNoSpin({action:'getCategoriesPresent'},function(result) {
			if (myEpoch !== data.searchEpoch) return; // user moved on
			$(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
			result.forEach(function(category) {
				var menuItem = $.find(".caMenuItem[data-category='"+category+"']");
				$(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
			});
			data.searchInProgress = false;
			/* Tell the inline-search input we're free again so it can flush
			   any keystrokes the user typed while this search was in flight. */
			if (typeof caInlineSearchOnComplete === "function") caInlineSearchOnComplete();
		});
	});
}

/**
 * Re-render the card grid with the active sort. For Previous / Installed / Action Centre, loads all rows up front (`maxPerPage` 99999, `data.allLoaded`).
 *
 * @param {HTMLElement} [button] Optional element that triggered the resort
 * @param {string} [buttonClass] Legacy class hint
 * @param {boolean|string} [previousApps] Truthy enables “load everything” mode for multi-select lists
 */
function changeSortOrder(button,buttonClass,previousApps) {
	var pageNumber = data.currentpage;
	var selected = data.selected;
	var startup = false;
	if ( button || buttonClass || previousApps) {
		data.searchFlag = false;
	}

	$(".startupButton").each(function(){
		if ($(this).hasClass("selectedMenu")) {
			startup = "true";
		}
	});
	/* Previous Apps / Installed Apps / Action Centre rely on Select All etc., so
	   load every card up front (no pagination) and disable the virtualizer's
	   eviction so the full DOM stays available. */
	var postOpts = {action:'display_content',pageNumber:pageNumber,selected:selected,startup:startup};
	if (previousApps) {
		postOpts.maxPerPage = 99999;
		data.allLoaded = true;
	} else {
		data.allLoaded = false;
	}
	/* Same gating as changePage(): if we're mid live-search, stay silent
	   (no spinner, no inline-collapse). Otherwise treat it as a user
	   interaction that should fold the pill away. */
	var postFn = data.searchInProgress ? postNoSpin : post;
	postFn(postOpts,function(result) {
		updateDisplay(result.display_data || result.display);
		/* A sort change refetches only page 1, so the user expects to land at
		   the top. Without this, a deep-scrolled viewport stays put over the new
		   page-1 cards and shows blank until the virtualizer repaints on the next
		   scroll. Skip the Previous Apps caller, which bulk-loads every card and
		   manages its own scroll. */
		if ( ! previousApps ) scrollToTop();
	});
}

/**
 * Fetch a category or home page from the server (`get_content`): resets pagination, adjusts labels for repository view, wires max rows on home.
 *
 * @param {boolean} init Legacy init flag (unused in current flow)
 * @param {string} category Menu key, `INITIALIZE`, `NONE`, or empty for All/New
 * @param {string} description Human-readable title for the category row
 * @param {string} newApp Spotlight / new-app hint passed to PHP
 * @param {string} startupDisplay Startup screen cookie / default view key
 */
/**
 * Drop sticky Docker Hub mode and re-enable paged virtualization. Used
 * by every code path that transitions out of a Docker Hub session
 * (`doSearch`, `caShowInApps`, `pins`, category clicks, etc.). Always
 * resets BOTH `data.docker` and `data.allLoaded` together — leaving
 * `allLoaded` set after exiting docker mode causes the paged App Store
 * grid to keep virtualization off and grow the DOM unbounded as the
 * user scrolls.
 */
function caLeaveDockerMode() {
	data.docker = "";
	data.allLoaded = false;
}

function getContent(init,category,description,newApp,startupDisplay) {
	data.currentpage = 1;
	/* Any app-content load (a category, Installed/Previous/Pinned, Home, etc.)
	   leaves Docker Hub mode — the docker flow never routes through getContent
	   (it uses dockerSearch directly), so this is always the right place to drop
	   sticky docker when the user navigates the menu. */
	caLeaveDockerMode();
	var initialize;
	var maxHomeApps = Math.max(1, caCardsPerRow()); // Row capacity; sections with a Show More tile render one fewer app to make room for it (server side), minimum 1
	data.maxPerPage = getMaxPerPage();

	enableSearch();

	if ( category != "NONE" ) {
		if ( category == "INITIALIZE" ) {
			initializeAppStore();
			category = "NONE";
			initialize = true;
			enableButtons();
			data.maxPerPage = maxHomeApps;
		}

		if ( (category == "New") || (category == "All") ) {
			category = "";
		}
		var el_dl = $.find(".sortIcons[data-sortby='downloads']");
		var el_tr = $.find(".sortIcons[data-sortby='trending']");

		if ( category == "repos" ) {
			$(el_dl).html("<?=tr("Number Of Apps");?>");
			$(el_tr).html("<?=tr("Average Trend");?>");
		} else {
			$(el_dl).html("<?=tr("Downloads");?>");
			$(el_tr).html("<?=tr("Trend");?>");
		}
		caRefreshSortMenu();

		var filter = $('#searchBox').val();
		if ( ! filter ) {
			$('.dockerSearch,.templateSearch').addClass("ca_hide");
		}
		if ( description && ! filter ) {
		 // $(".category").html(description);
		}
		post({action:'get_content',maxPerPage:data.maxPerPage,filter:filter,category:category,newApp:newApp,startupDisplay:startupDisplay,maxHomeApps:maxHomeApps,mobileDevice:cssVar("--mobileDevice"),searchLimitOverride:data.searchLimitOverride?1:0},function(result) {
			updateDisplay(result.display_data || result.display);
			if ( initialize ) {
				populateAutoComplete();
				downloadStatistics();
			}
		});
	}
}

/**
 * Trigger background statistics/template fetch. Also marks bootstrap as
 * settled — see caMaybeArmFeedCheck — since both boot paths (restore and
 * non-restore) fire this as their last sequential step.
 */
function downloadStatistics() {
	postNoSpin({action:'downloadStatistics'}, function() {
		window.caBootstrapSettled = true;
		caMaybeArmFeedCheck();
	});
}

/**
 * Arms `window.caFeedTrackingArmed` once both registerTab has acked AND
 * bootstrap has settled. Idempotent. See the registerTab block in the
 * IIFE near the top of this file for the rationale.
 */
function caMaybeArmFeedCheck() {
	if (window.caRegisterTabAcked && window.caBootstrapSettled) {
		window.caFeedTrackingArmed = true;
	}
}

/**
 * Load search suggestions into Awesomplete and bind `awesomplete-selectcomplete` to {@link awesompleteSearch}.
 *
 * @param {function} [after] Optional callback after the list is installed
 */
function populateAutoComplete(after) {
	postNoSpin({action:'populateAutoComplete'},function(result) {
		searchBoxAwesomplete.list = result.autocomplete;
		searchBoxAwesomplete.maxItems = 20;
		searchBoxAwesomplete.minChars = 3;
		/* Same list feeds the desktop inline strip; keep its display caps
		   wider since it lays out as a horizontal scroller. */
		if (inlineSearchAwesomplete) {
			inlineSearchAwesomplete.list = result.autocomplete;
			inlineSearchAwesomplete.maxItems = 100;
			inlineSearchAwesomplete.minChars = 2;
		}
		
		$("#searchBox").off("awesomplete-selectcomplete", awesompleteSearch);
		$("#searchBox").on("awesomplete-selectcomplete", awesompleteSearch);
		searchBoxAwesomplete.close(); // otherwise it opens automatically during restore state
		if (typeof after === "function") {
			after();
		}
	});
}

/**
 * Awesomplete pick handler: if no real sort is active, reset to default sort server-side, then {@link doSearch}.
 */
function awesompleteSearch() {
	// this is the check sort order function
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( !sortButton) {
		$(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
		post({action:"defaultSortOrder"},function(data) {
			$("#defaultSort").addClass("enabledIcon");
			doSearch(false);
		});
	} else {
		doSearch(false);
	}
}

/**
 * Persist CA state with {@link saveState}, open `newURL`, and warn if the browser blocks pop-ups.
 *
 * @param {string} newURL Destination URL
 * @param {string} [target='_self'] `window.open` target name
 */
function openNewWindow(newURL,target='_self') {
	/* Installing a container opens the AddContainer page, which ends the Docker
	   Hub search the user installed from. On the way back to Apps they want the
	   template results, not the docker results. Clear docker mode before
	   saveState so the saved snapshot records dockerMode false: restoreState
	   then brings back the app store chrome (DockerHub button plus sort icons)
	   instead of the docker chrome (Apps button). The matching server side
	   unlink of dockerSearchActive in createXML and convert_docker stops the
	   bootstrap from re-running the docker search on return. */
	if ( typeof newURL === "string" && newURL.indexOf("/Apps/AddContainer") !== -1 ) {
		caLeaveDockerMode();
	}
	saveState();
	var popUp = window.open(newURL,target);
	if ( !popUp || popUp.closed || typeof popUp == "undefined" ) {
		var popupWarning = addBannerWarning("<?=_('Popup Blocked.');?>");
		setTimeout(function() {
			removeBannerWarning(popupWarning);}
			,10000);
	}
}

/**
 * Clear `#searchBox`, re-enable all category rows, reset search/docker flags, and sync collapsed search / Home menu labels.
 */
function clearSearchBox() {
	/* Invalidate any in-flight live-search response so its callback
	   can't repaint App Store state over whatever view the caller is
	   about to show (Installed / Previous / Pinned / a category / etc.). */
	data.searchEpoch = (data.searchEpoch || 0) + 1;
	$(".categoryMenu").removeClass("caMenuDisabled").addClass("caMenuEnabled");
	$("#searchBox").val("");
	/* Mirror to the desktop inline input (skin.html .caDesktopSearchInline) so
	   it doesn't show a stale query after Home / soft-clear / restore. Also
	   reset the inline closure's bookkeeping (lastCommitted etc.) so re-typing
	   the just-cleared term immediately works as a fresh search. */
	$("#caInlineSearchBox").val("");
	$(".caInlineSearchClear").addClass("ca_hide");
	if (typeof caInlineSearchResetState === "function") caInlineSearchResetState();
	hideSortIcons();
	data.committedSearchFilter = "";
	/* Reset search-state flags so the Home menu reverts from "Clear Search" to
	   "Home" and the All Apps item from "All Results" back to "All Apps" when
	   the user navigates away from search results into Installed / Previous /
	   Pinned / Action Centre / Favourite Repo. */
	data.searchActive = false;
	data.searchFlag = false;
	caLeaveDockerMode();
	/* Close the autocomplete suggestion strip as part of clearing the search.
	   searchActive / searchFlag are already false and the inputs are blank by
	   here, so the #caInlineSearchBox awesomplete-close re-open guard stays quiet
	   and the strip does not pop back open. Without this, clearing via the X or
	   the Clear Search menu item left the suggestion chips on screen unless the
	   search had been started from Home (that path unwinds through appStore). */
	if (typeof inlineSearchAwesomplete !== "undefined" && inlineSearchAwesomplete) {
		try { inlineSearchAwesomplete.close(); } catch (e) { /* no-op */ }
	}
	if (typeof searchBoxAwesomplete !== "undefined" && searchBoxAwesomplete) {
		try { searchBoxAwesomplete.close(); } catch (e) { /* no-op */ }
	}
	caSyncSearchFilterCollapsed();
	caSyncHomeSearchSubtitle();
	if (typeof caSyncHomeMenuLabel === "function") caSyncHomeMenuLabel();
}

/**
 * Close the description sidebar: optionally preserve cookies, tear down context menus, submit dirty settings forms, and animate `sidenav` closed.
 *
 * @param {boolean} [cookie=false] When false, clear `sidebarAppPath` / `sidebarAppName` cookies
 * @param {boolean} [visible=false] Legacy visibility hint (unused)
 */
/* keepIdentity (true) → callers that intend to reopen the sidebar to the same
   app right after closing it (post-install refresh, MagnificPopup gallery's
   beforeOpen → afterClose round-trip, etc). Keep the cookies, the in-memory
   data.sidebarapp{path,name}, AND the sessionStorage ca_state sidebar fields
   so the reopen has somewhere to point. Default (false) is the normal user-
   initiated close: wipe all three so a later saveState / page reload doesn't
   silently auto-reopen the app the user just dismissed. The legacy parameter
   name `cookie` is kept as an alias because external callers (helpers.js, the
   install/update paths) still use it positionally. */
function closeSidebar(keepIdentity=false,visible=false) {
	/* Sidebar is closing - leave the Credits view-stack so a later app-back
	   doesn't get routed to Credits. */
	window.caSidebarBackTarget = "";
	/* Always tear down the live-CPU poll loop on sidebar close — even when
	   keepIdentity is true (gallery transitions etc.), because the gallery's
	   afterClose path reopens the sidebar with a fresh popUpChart() call that
	   will restart polling cleanly. Leaving the interval armed would double-
	   poll once the new sidebar lands. */
	if (typeof caStopLiveStats === "function") caStopLiveStats();
	if ( ! keepIdentity ) {
		caSessRemove("sidebarAppPath");
		caSessRemove("sidebarAppName");
		/* Clear the in-memory sidebar identity — without this, a later
		   saveState() call in the same tab (e.g. another sidebar opening, or
		   guiSearchOnUnload) would persist the dismissed app back into the
		   snapshot and the next restore would auto-reopen it. */
		data.sidebarapppath = "";
		data.sidebarappname = "";
		/* Wipe the sidebar identity from the saveState snapshot so a later
		   browser reload doesn't auto-reopen the sidebar to an app the user
		   just explicitly closed. Filter / sort / category / scroll stay
		   intact — only the two sidebar fields are blanked. */
		try {
			var _raw = sessionStorage.getItem("ca_state");
			if (_raw) {
				var _s = JSON.parse(_raw);
				if (_s && typeof _s === "object") {
					_s.sidebarAppPath = "";
					_s.sidebarAppName = "";
					sessionStorage.setItem("ca_state", JSON.stringify(_s));
				}
			}
		} catch (e) { /* no-op */ }
	}
	context.destroy("#actionsPopup");
	/* Drop the relocated per-app action strip so a stale row from the
	   previous app doesn't linger next to CLOSE when the sidebar reopens. */
	$(".popupActionsAreaInner .popupStickyActions").remove();

	/* If a settings form was open with unsaved edits, submit it instead of just
	   closing — the submit handler saves and reloads, which subsumes closing. */
	var $settingsForm = $("#sidenavContent .ca_settingsForm");
	if ($settingsForm.length) {
		var initialState = $settingsForm.data("caInitialState");
		if (typeof initialState === "string" && $settingsForm.serialize() !== initialState) {
			$settingsForm.trigger("submit");
			return;
		}
	}

	$(".sidenav").removeClass("sidenavShow").addClass("sidenavHide").scrollTop(0);
	$(".nav-user.show").show();
	enableSearch();
}

/**
 * Confirm no other plugin operation is running, check optional upgrade requirements, then {@link actuallyInstallPlugin}.
 *
 * @param {string} pluginURL URL or path passed to `checkPluginInProgress`
 * @param {boolean} [update=false] Upgrade vs fresh install
 * @param {string} [requires=''] Dependency string for upgrade checks
 */
function installPlugin(pluginURL,update=false,requires="") {
	post({action:"checkPluginInProgress",pluginPath:pluginURL},function(data) {
		if (data.inProgress) {
			swal({
				title: "<?tr("Installation already in progress");?>",
				text: "<?tr("This plugin is currently being installed or uninstalled.  Wait until the current operation is completed and try again");?>",
				allowOutsideClick: false,
				showConfirmButton: true,
				showCancelButton: false,
				confirmButtonText: "<?tr("OK");?>",
				type: "warning"
			},function() {
				enableSearch();
			});
		} else {
			if ( update && requires ) {
				post({action:"checkRequirements",requires:requires},function(data) {
					if (! data.met) {
						swal({
							title: "<?tr('Requirements not met');?>",
							text: "<?tr('The requirements for this upgrade have not been met on your system');?>",
							allowOutsideClick: false,
							showConfirmButton: true,
							showCancelButton: false,
							confirmButtonText: "<?tr('OK');?>",
							type: "error",
							html: true
						},function(isConfirm) {
							enableSearch();
						});
					} else {
						actuallyInstallPlugin(pluginURL,update);
					}
				});
			} else {
				actuallyInstallPlugin(pluginURL,update);
			}
		}
	});
}

/**
 * Close sidebar, hide matching pending-action rows, pick post-install callback (`actionCentre` vs sidebar refresh), {@link ca_openPlugin}.
 *
 * @param {string} pluginURL Resolved install/update URL (proxied for new installs)
 * @param {boolean} [update=false]
 */
function actuallyInstallPlugin(pluginURL,update=false) {
	var type = update ? "update" : "install";
	if ( ! update ) {
		pluginURL = "<?=CA_PATHS['pluginProxy']?>" + pluginURL;
	}
	title = update ? "<?tr("Update Plugin");?>" : "<?tr("Install Plugin");?>";
	closeSidebar(true);
	hidePluginPending(pluginURL);

	if ( $(".selectedMenu").data("category") == "action_centre" ) {
		var postFunction = "actionCentre";
	} else {
		var postFunction = "OpenSidebarAndRefreshDisplay";
	}
	data.deprecated = false; // global var here to trigger a rescan of action centre
	if ( pluginURL.includes("&deprecated") || pluginURL.includes("&incompatible") ) {
		data.deprecated = true;
		pluginURL = pluginURL.replace("&deprecated","");
		pluginURL = pluginURL.replace("&incompatible","");
	}
	ca_openPlugin('plugin '+type+' '+pluginURL,title,'',postFunction);
}

/**
 * Hide Action Centre rows for a plugin whose install is now underway (match full URL or basename).
 *
 * @param {string} pluginURL
 */
function hidePluginPending(pluginURL) {
	if ( pluginURL.includes("/") ) {
		$(".actionsButton").each(function() {
			if ( $(this).data("pluginurl") == pluginURL || $(this).data("pluginurl")+"&deprecated" == pluginURL ) {
				$(this).hide();
			}
		});
	} else {
		$(".actionsButton").each(function() {
			if ( $(this).data("pluginurl").basename() == pluginURL ) {
				$(this).hide();
			}
		});
	}
}

/**
 * Hide Action Centre rows for a language pack about to be installed/updated/removed.
 *
 * @param {string} language Pack id or filename (`lang-` prefix / `.xml` stripped)
 */
function hideLanguagePending(language) {
	language = language.replace("lang-","");
	language = language.replace(".xml","");
	if ( ! language )
		return;

	$(".actionsButton").each(function() {
		if ( $(this).data("languagepack") == language ) {
			$(this).hide();
		}
	});
}

/**
 * After plugin install flows: reload the page when PHP reports startup, otherwise refresh the grid and reopen any saved sidebar app.
 */
function OpenSidebarAndRefreshDisplay() {
	post({action:"onStartupScreen"},function(result) {
		if (result.status) {
			window.location.reload();
		} else {
			var apppath = caSessGet("sidebarAppPath");
			var appname = caSessGet("sidebarAppName");

			appname = stripTags(appname);

			refreshDisplay();
			if ( $.trim(apppath) ) {
				showSidebarApp(apppath,appname);
			}
			if ( data.deprecated ) {
				data.deprecated = false;
				setupActionCentre();
			}

		}
	});
}

/**
 * Show Installed Apps, Previous Apps (multi-select), or Action Centre prep: clear search, enforce default sort when needed, then {@link getPrevApps}.
 *
 * @param {boolean|string} installed `true` installed only, `false` previous list, `"action"` action-centre mode
 * @param {boolean} [dontClear=false] Keep prior multi-select state when true
 * @param {string} [filter=''] Server filter for previous-apps section
 */
function previousApps(installed,dontClear=false,filter="") {
	clearCategory();
	setPageOne();
	caLeaveDockerMode();

	clearSearchBox();
	$(".dockerSearch,.templateSearch").addClass("ca_hide");
	showSortIcons();

	// this is the checkSortOrder function running to prevent a race condition
	var sortButton = false;
	$(".sortIcons").each(function() {
