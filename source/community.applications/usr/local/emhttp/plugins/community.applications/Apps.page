/**
 * Toggle a single sidebar menu item between enabled/disabled state by adding/
 * removing caMenuEnabled and caMenuDisabled. caMenuDisabled is what the
 * .sectionMenu click handler checks to swallow clicks on empty submenus.
 *
 * @param {string} category Value of the menu item's `data-category` attribute
 * @param {boolean} enabled True to enable, false to grey out and swallow clicks
 */
function caToggleMenuItem(category, enabled) {
	var $item = $(".caMenuItem[data-category='" + category + "']");
	if ( ! $item.length) return;
	if (enabled) {
		$item.removeClass("caMenuDisabled").addClass("caMenuEnabled");
	} else {
		$item.removeClass("caMenuEnabled").addClass("caMenuDisabled");
	}
}

/**
 * Pull the four Installed / Previous Apps submenu populations from the server
 * and grey out the submenu items that would render nothing — e.g. Installed
 * Apps > Docker is disabled when no containers are present (and therefore
 * also when docker itself is off, since collectDockerApplications short-
 * circuits to []). Cheap enough to call after every install/uninstall.
 */
function caRefreshInstalledMenuStates() {
	post({action:'installedAndPreviousCounts'}, function(result) {
		if ( ! result || ! result.counts) return;
		caToggleMenuItem("inst_docker",  result.counts.instDocker  > 0);
		caToggleMenuItem("inst_plugins", result.counts.instPlugins > 0);
		caToggleMenuItem("prev_docker",  result.counts.prevDocker  > 0);
		caToggleMenuItem("prev_plugins", result.counts.prevPlugins > 0);
	});
}

/**
 * Fetch favourite repository name from PHP and enable/disable `.favouriteRepo` menu + `data-repository`.
 */
function setFavRepoSearch() {
	post({action:'getFavourite'},function(result) {
		if (result.favourite) {
			$(".favouriteRepo").addClass("caMenuEnabled").removeClass("caMenuDisabled");
		} else {
			$(".favouriteRepo").addClass("caMenuDisabled").removeClass("caMenuEnabled");
		}
		$(".favouriteRepo").attr("data-repository",result.favourite);
	});
}

/**
 * Repaint category HTML from server, re-enable standard menu rows, sync favourite + pinned states, restore menu selection from cookies when applicable.
 */
function getCategories() {
	post({action:'get_categories'},function(result) {
		$("#category_list").html(result.categories);
		$(".subCategory").hide();
		$(".caMenuItem").each(function() {
			if ( ! ( $(this).hasClass("favouriteRepo") || $(this).hasClass("caPinnedMenu") ) ) {
				$(this).addClass("caMenuEnabled").removeClass("caMenuDisabled");
			}
		});
		/* Re-apply count-based gating on the Installed / Previous submenus
		   *after* the wholesale caMenuEnabled reset above, otherwise our
		   caMenuDisabled state gets clobbered when these two requests race. */
		caRefreshInstalledMenuStates();
		setFavRepoSearch();

		post({action:'areAppsPinned'},function(result) {
			if (!result.status) {
				$(".caPinnedMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
			} else {
				$(".caPinnedMenu").removeClass("caMenuDisabled").addClass("caMenuEnabled");
			}
		});

		if ( ! restoreStateMenu )
			restoreStateMenu = $.cookie("ca_startupButton");

		caDebug(restoreStateMenu);
		var menuItem = $.find(".caMenuItem[data-category='"+restoreStateMenu+"']");
		$(".caMenuItem").each(function(){
			$(this).removeClass("selectedMenu");
		});
		$(menuItem).addClass("selectedMenu");
		$(menuItem).parent().show();
		$(menuItem).next().show();
		/* If the restored item is a sub-item nested inside a `<li class='subCategory'>`
		   wrapper (e.g. Media Servers → Photos), the immediate parent is the inner
		   `<ul>` — but the .subCategory wrapper is what's hidden by the wholesale
		   $(".subCategory").hide() above, and a visible `<ul>` inside a hidden
		   `<li>` still renders nothing. Show the wrapper so the branch the leaf
		   belongs to opens up. */
		$(menuItem).closest(".subCategory").show();
		restoreStateMenu = false;

		if ( $("#searchBox").val() ) {
			post({action:'getCategoriesPresent'},function(result) {
				$(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
				result.forEach(function(category) {
					var menuItem = $.find(".caMenuItem[data-category='"+category+"']");
					$(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
					document.referrer = "/Apps";
				});
				var selectedMenu = $.cookie("ca_selectedMenu");
				if ( selectedMenu ) {
					var menuItem = $.find(".caMenuItem[data-category='"+selectedMenu+"']");
					$(menuItem).addClass("selectedMenu");
				}	else
					$(".allApps").addClass("selectedMenu");

			});
		}
	});
}

