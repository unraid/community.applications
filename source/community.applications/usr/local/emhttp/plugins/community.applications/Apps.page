	   something on a stale tab. */
	function caHandleForeignFeedUpdate() {
		/* If a plugin / docker install (or any Unraid openPlugin / openDocker
		   dialog) is currently on screen, hold the "another session updated
		   the feed" notice until it's done — otherwise the viewport blocker
		   slams down over the install modal and the user can't reach Done. */
		if (window.caFeedReloadNoticePending) return;
		window.caFeedReloadNoticePending = true;
		var fireReloadNotice = function() {
			caBlockViewportForReload();
			caShowFatalReloadBanner(tr("Another browser instance updated the application feed. Click anywhere to reload the page."));
		};
		var caInstallDialogOpen = function() {
			return $("#sb-nav").is(":visible");
		};
		if (caInstallDialogOpen()) {
			var poll = setInterval(function() {
				if ( ! caInstallDialogOpen()) {
					clearInterval(poll);
					fireReloadNotice();
				}
			}, 1000);
			return;
		}
		fireReloadNotice();
	}
	window.caHandleForeignFeedUpdate = caHandleForeignFeedUpdate;

	caInitializeSortMenu();
	caInitializeClickHandlers();
	caInitializeEventHandlers();
	caSyncSearchFilterCollapsed();
	caSyncHomeSearchSubtitle();

	/* Everything is now initialized.  This is the start of the actual "real" code */

	if ( "<?=$firstRun?>" == "true" ) {
		$(".ca_templatesDisplay").hide();
		swal({
			title: "<?tr("Disclaimer");?>",
			text: '<?tr('All applications listed here are 3rd party additions to Unraid.  Community Applications contains both docker containers and plugin applications.  Plugins are designed for OS enhancements, and run with full privileges on your system and are clearly identified within CA.  Neither the authors of Community Applications nor Limetech make any warranty as to the suitability of any application listed here');?> <br><span class="ca_italic"><font color="green"><?tr('Every attempt is made to ensure that only safe and compatible applications are present');?></font></span><br><br><center><a href="https://forums.unraid.net/topic/87144-ca-application-policies/" target="_blank"><?tr('Application / Privacy Policy');?></a>',
			html: true,
			type: 'warning',
			showCancelButton: true,
			showConfirmButton: true,
			cancelButtonText: "<?tr('Cancel');?>",
			confirmButtonText: "<?tr('I Understand');?>"
		}, function (isConfirm) {
			if ( isConfirm ) {
				post({action:'dismiss_warning'},function(result) {
					location.reload();
				});
			} else {
			$(".ca_templatesDisplay").show();
				addBannerWarning("<?tr("Installations of apps disabled.  You must accept the warning to be able to install applications.");?>   <a onclick='window.location.reload();' style='cursor:pointer;'><?tr("Click here");?></a>",true,true);
				updateContent();
			}
		});
	}	else {
		/* Restore state when we came back from a child URL of /Apps (Docker, plugin
		   install pages, etc.). document.referrer covers the "Done" button case;
		   the ca_apps_referrer cookie — set by CA_notices.page on every Unraid
		   page load while the URL is under /Apps/ and cleared as soon as it
		   isn't — covers the browser-back case where the referrer is empty.
		   State now lives in sessionStorage (was cookies); saveState() writes
		   it at the top of showSidebarApp, so the snapshot is guaranteed to be
		   present whenever the user took an action that could navigate away. */
		var caSavedState = caReadSavedState();
		/* On a browser reload (F5 / Cmd-R / address-bar Enter), the saveState
		   snapshot still carries the last sidebarAppPath/Name from the install
		   round-trip — but a reload is the user explicitly asking for a fresh
		   page, so don't auto-reopen the sidebar to an app they may have
		   already closed. Blank just the sidebar fields; filter / sort /
		   category / scroll stay intact. */
		try {
			var _navEntries = performance.getEntriesByType && performance.getEntriesByType("navigation");
			if (caSavedState && _navEntries && _navEntries[0] && _navEntries[0].type === "reload") {
				caSavedState.sidebarAppPath = "";
				caSavedState.sidebarAppName = "";
				try {
					sessionStorage.setItem("ca_state", JSON.stringify(caSavedState));
				} catch (e) { /* no-op */ }
			}
		} catch (e) { /* no-op */ }
		var caCameFromAppsChild = (
			(document.referrer.indexOf("/Apps/") > 1)
			|| <?=$ca_apps_referrer?>
		);
		var caCanRestore = (
			"<?=$startupDisplayed?>" != "true"
			&& caCameFromAppsChild
			&& ("<?=$dockerConvertFlag?>" != "true")
			&& caSavedState
			&& !caSavedState.wasHome
		);
		/* Register this tab with the server before any other request. The
		   server creates a marker file at CA_PATHS['registeredTabs']/{tabId}
		   that gets wiped by DownloadApplicationFeed when another tab
		   triggers a fresh feed pull.

		   Arming caFeedTrackingArmed is gated on TWO events both completing:
		     1. registerTab acked — the marker exists server-side
		     2. bootstrap settled — downloadStatistics returned, which both
		        the restore and non-restore boot paths fire as their last
		        sequential step
		   Without (2), in-flight bootstrap requests (force_update_skip,
		   hydrateFullFeed, getCategories) would start carrying caFeedCheck
		   mid-load — a concurrent feed refresh in another tab could then
		   pop the "another browser updated" banner during page load
		   instead of on the next user action. */
		postNoSpin({action:'registerTab'}, function(result) {
			if (result && result.status === 'ok') {
				window.caRegisterTabAcked = true;
				caMaybeArmFeedCheck();
			}
		});
		if ( caCanRestore ) {
			getCategories();
			restoreState(caSavedState);
			<? if ( $dockerSearchActive ):?>
				dockerSearch(data.currentpage);
			<? else:?>
				/* If the user was past page 1 when they left, fetch every card from
				   page 1 through their saved page in one bulk request so they can
				   freely scroll back to earlier results, then snap the viewport to
				   where they were. */
				var _restoreSavedPage = parseInt(data.currentpage, 10) || 1;
				var _restorePerPage = parseInt(data.maxPerPage, 10) || 12;
				if (_restoreSavedPage > 1) {
					data.maxPerPage = _restoreSavedPage * _restorePerPage;
					data.currentpage = 1;
					changePage(1, false);
				} else {
					refreshDisplay();
				}
				/* Scroll restore — independent of the page>1 bulk-fetch path so it
				   handles both. Targets the literal pixel scrollY saved at
				   sidebar-open (vs. the old card-boundary approximation that
				   landed users at the start of their saved page instead of the
				   actual position). Polls until .mainArea is tall enough that
				   scrolling to scrollY is meaningful, then sets scrollTop. Capped
				   at ~6s of polling so we don't loop forever if rendering never
				   reaches the saved depth (rare, but possible if filter results
				   shrunk between save and restore). */
				var _scrollTarget = parseInt(caSavedState.scrollY, 10) || 0;
				if (_scrollTarget > 0) {
					var _scrollAttempts = 0;
					var _scrollRestore = function() {
						var ma = $(".mainArea")[0];
						if (!ma) return;
						/* Either we have enough DOM height to honour the target,
						   or we've polled enough — apply and exit either way. */
						if (ma.scrollHeight >= _scrollTarget + ma.clientHeight || ++_scrollAttempts > 60) {
							ma.scrollTop = _scrollTarget;
							return;
						}
						setTimeout(_scrollRestore, 100);
					};
					setTimeout(_scrollRestore, 200);
				}
				searchBoxAwesomplete.close();
				if ( caSavedState.sidebarAppPath ) {
					showSidebarApp(caSavedState.sidebarAppPath, caSavedState.sidebarAppName);
				}
			<? endif;?>
			/* Restore path doesn't go through updateContent → downloadStatistics,
			   so kick off downloadStatistics() directly. Beyond fetching stats,
			   this is what arms the ca_gettingTemplates subscriber — without it
			   a restored tab would never see the "another instance updated the
			   feed" reload banner. */
			downloadStatistics();
		} else {
			post({action:"defaultSortOrder"},function() {
				myAlert("","<div class='ca_center caLogoIcon'></div><?tr('Community Applications');?><br><br><?tr('Updating Applications');?><br><span class='updateContent-swal'>"+tr('Please Wait')+"</span><div class='caDownloadProgress ca_hide'><span class='caDownloadProgressText'></span><div class='caButton ca_quitUpdate'>"+tr('Abort')+"</div></div>","","",false,false,false,"");

				updateContent(false,false);
			 // clearTimeout(downloadStatusTimer);
				/* Home / wasHome case: the templates-view restore is intentionally
				   skipped (the home view has no .ca_templatesDisplay grid to
				   restore into — see saveState()). But the user was looking at
				   an app in the sidebar when they navigated away, so reopen it
				   once the home paint settles. Gated on caSavedState.wasHome so
				   we only reopen for an *explicit* home snapshot — not for
				   non-home snapshots that happened to skip the if-branch for
				   other reasons (dockerConvertFlag, mismatched referrer, etc.). */
				if ( caSavedState && caSavedState.wasHome && caSavedState.sidebarAppPath && caCameFromAppsChild && ("<?=$dockerConvertFlag?>" != "true") ) {
					showSidebarApp(caSavedState.sidebarAppPath, caSavedState.sidebarAppName);
				}
			});
		}
		setupActionCentre();
		/* Submenu disable-state sync is chained inside getCategories() so it
		   can't race with the wholesale caMenuEnabled reset there — both
		   bootstrap branches above route through getCategories(). */
		/* Consume the ca_apps_referrer cookie now that we've used it — fresh
		   visits to Apps (not from a child URL) shouldn't auto-restore state. */
		$.removeCookie("ca_apps_referrer", { path: "/" });
	}
	<?endif;?>
});

/**
 * Hide sort controls (flows such as startup views where the user should not change sort).
 */
function disableSort() {
	hideSortIcons();
}
/**
 * Hide the sort-by control row (`#sortIconArea`).
 */
function hideSortIcons() {
	$("#sortIconArea").hide();
}
/**
 * Show the sort-by control row (`#sortIconArea`).
 */
function showSortIcons() {
	$("#sortIconArea").show();
}
/**
 * Queue a plugin operation through Unraid `openPlugin`, rewriting `plugin install` to `downloadPlugin`, and dismiss CA alerts first.
 *
 * @param {string} cmd Full command (`plugin install` / `plugin update` / `multiplugin` / etc.)
 * @param {string} title Dialog title passed to `openPlugin`
 * @param {string} plg Plugin identifier argument for `openPlugin`
 * @param {string} func Global callback name when the operation finishes (e.g. `refresh`, `actionCentre`)
 */
function ca_openPlugin(cmd,title,plg,func) {
	if ( cmd.startsWith("plugin install") ) {
		cmd = "downloadPlugin "+cmd;
	}
	setTimeout(function(){
		// force the install to run even if another install is already in progress
		openPlugin(cmd,title,plg,func,"",1);
		myCloseAlert();
	},250);
}

/**
 * Refresh templates and redraw the store: reset search UI, apply startup category from cookie or clicked button, POST `force_update` (or `force_update_skip`), then reload listing or restore an in-progress search.
 *
 * @param {HTMLElement} [button] Optional menu item whose `data-category` becomes the active startup screen
 * @param {boolean} [skipAppfeed=true] When true, use `force_update_skip` to avoid blocking on full appfeed work
 */
function updateContent(button,skipAppfeed=true) {
	clearSearchBox();
	clearCategory();
	$(".caMenuItem").removeClass("selectedMenu");
	$(".subCategory").hide();

	startupScreen = $.cookie("ca_startupButton") ? $.cookie("ca_startupButton") : "onlynew";
	$(".caMenuItem[data-category='"+startupScreen+"']").addClass("selectedMenu");

	startupScreen = button ? $(button).data("category") : startupScreen;
	$.cookie("ca_startupButton",startupScreen,{expires:365,path:"/;SameSite=Lax",secure:true});
	$.cookie("ca_selectedMenu",startupScreen,{expires:365,path:"/;SameSite=Lax",secure:true});
	disableSearch();
	var postAction = skipAppfeed ? "force_update_skip" : "force_update";
	post({action:postAction}, function(result) {
		if ( result.data ) {
			updateDisplay(result.data);
		} else {
			data.searchActive = false;
			if ( startupSearch ) {
				doSearch(false,startupSearch);
				populateAutoComplete();
				startupSearch = "";
				$(".dockerSearch,.templateSearch").hide();
			} else {
				getContent(true,'INITIALIZE',"","",startupScreen);
			}
		}
		/* If the initial download used the slim feed, the full templates
		   cache is empty — kick off a background hydrate so install-time
		   port-conflict detection and createXML have Config available by
		   the time the user clicks Install. Server short-circuits with
		   `already_fresh` when the full cache is already on disk, so this
		   is safe to call unconditionally.

		   On completion, if a sidebar happens to be open and showing the
		   "Unavailable until feed downloads" notice (the slim-only render
		   from skin.php's full-cache guard), surgically swap just the
		   .popupStickyActions block with the freshly-rendered version
		   from the server — no full sidebar reload, no spinner flicker,
		   just the buttons appearing in place. */
		postNoSpin({action:'hydrateFullFeed'}, function(hydrateResult) {
			if (hydrateResult && hydrateResult.status === 'failed') return;
			if (!data.sidebarapppath) return;
			if (!$('.popupCloseAreaButtons .caFeedPending').length) return;
			/* Snapshot the app identity we're about to fetch, so the
			   callback can verify the same app is still in the sidebar
			   when the response arrives. Without this, a fast user opening
			   a different (also pending) sidebar between request and
			   response would have the new sidebar's action row clobbered
			   with the PREVIOUS app's buttons. */
			var requestedAppName = data.sidebarappname;
			var requestedAppPath = data.sidebarapppath;
			postNoSpin({action:'getPopupDescription', appName: requestedAppName, appPath: requestedAppPath}, function(popResult) {
				if (!popResult || !popResult.description) return;
				/* Sidebar might have closed or navigated to a different app
				   while the popup re-fetch was in flight — re-check both
				   the pending notice AND that the open sidebar is still
				   the same app we requested before touching the DOM. */
				if (!$('.popupCloseAreaButtons .caFeedPending').length) return;
				if (data.sidebarappname !== requestedAppName || data.sidebarapppath !== requestedAppPath) return;
				var $tmp = $('<div>').html(popResult.description);
				var $newActions = $tmp.find('.popupStickyActions').first();
				if ($newActions.length) {
					$('.popupCloseAreaButtons .popupStickyActions').replaceWith($newActions);
				}
			});
		});
		getCategories(); /* now also re-applies count-based submenu gating */
		if ( $.cookie("ca_plugininstallpending" || ! button ) ) {
			var plugins = $.cookie("ca_plugininstallpending");
			$.removeCookie("ca_plugininstallpending");
			myCloseAlert();
			post({action:'saveMultiPluginPending',plugin:plugins},function(data) {
				ca_openPlugin('multiplugin install '+plugins,"<?tr('Install Plugin Applications');?>",'','refresh');
				/* Re-arm the swal customClass default once openPlugin's modal is
				   on screen — see the deferral note in the IIFE near line 250. */
				setTimeout(function(){ swal.setDefaults({ customClass: "ca_sweetalert_open" }); }, 1500);
			});
		}
	});
}

/**
 * Enter a spotlight / startup category from the left menu: ensure a real sort is selected, then delegate to {@link showSpecials}.
 *
 * @param {HTMLElement} button Menu row with `data-category`
 */
function showSpecialCategory(button) {
	closeSidebar();
	clearSearchBox();
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( !sortButton) {
		$(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
		post({action:"defaultSortOrder"},function(data) {
			$("#defaultSort").addClass("enabledIcon");
			showSpecials(button)
		});
	} else {
		showSpecials(button);
	}
}

/**
 * Show startup-style storefront content: clear normal selection, set App Store section, grey out repository-aware menu.
 *
 * @param {HTMLElement} button Passed through to {@link changeCategory}
 */
function showSpecials(button) {
	showSortIcons();
	$(".caMenuItem").removeClass("selectedMenu");
	$(".multi_installDiv").hide();
	data.selected_category = "DOESNTMATTERWHATSHERE";
	data.section = "AppStore";
	changeCategory(button,false);
	$(".caRepositoryMenu").addClass("caMenuDisabled").removeClass("caMenuEnabled");
	//$(".category").append(" - <?tr("Installs not allowed from this page");?>");
}

/**
 * Load templates for a sidebar category via {@link getContent}.
 *
 * @param {HTMLElement} button Menu item (`data-category`, label text)
 * @param {*} subSwitch Legacy argument (unused)
 */
function changeCategory(button,subSwitch) {
	var description = $(button).text();
	var category = $(button).attr("data-category");

	$(".multi_installDiv").hide();
	getContent(false,category,description,false);
}

/**
 * Fetch a page of cards from the server (`display_content`), optionally appending for infinite scroll.
 *
 * @param {number|string} pageNumber 1-based page index
 * @param {boolean} [append] When true, append HTML/cards to the current grid
 */
function changePage(pageNumber, append) {
	pageNumber = parseInt(pageNumber, 10) || 1;
	var doAppend = !!append;
	caRestoreCommittedSearchIfDrafted();
	if (searchBoxAwesomplete) searchBoxAwesomplete.close();
	var selected = data.selected;
	data.currentpage = pageNumber;

	post({action:'display_content',pageNumber:pageNumber,selected:selected,maxPerPage:data.maxPerPage},function(result) {
		updateDisplay(result.display_data || result.display, doAppend);
		if (!doAppend) scrollToTop();
	});
}

/**
 * Close SweetAlert and spinner chrome and call {@link enableSearch}.
 *
 * @param {boolean} [force=false] When true, `swal.close` bypasses some guard paths (legacy)
 */
function myCloseAlert(force=false) {

	swal.close();
	$("div.spinner, .sweet-alert").hide();
	enableSearch();
}

/**
 * Close any modal, collapse the sidebar, and run {@link doSearch} with `newSearch`.
 *
 * @param {string} newSearch Committed search string
 */
function doSidebarSearch(newSearch) {
	swal.close();
	closeSidebar();
	doSearch(false,newSearch);
}

/**
 * Run template search (or navigate home when cleared): manages `searchActive`, Docker vs template toggles, commits filter, POSTs `get_content`.
 *
 * @param {*} button Legacy; often `false` means “use current `#searchBox` value”
 * @param {string|false} [newSearch] When a string, pre-fills the search box before filtering
 */
function doSearch(button,newSearch) {
	if ( data.searchInProgress )
		return;

	data.searchInProgress = true;

	if ( ! newSearch === false ) {
		$('#searchBox').val(newSearch);
	}
	var filter = $('#searchBox').val();
	filter = $.trim(filter);
	filter = stripTags(filter);

	/* No-op: term hasn't changed from the currently committed search.
	   Close the modal; if maxPerPage changed (viewport/layout changed), re-render current
	   search pagination via changePage so cards-per-page and page mapping stay consistent. */
	var committedFilter = $.trim(String(data.committedSearchFilter || ""));
	var hasActiveAppSearch = !!(data.searchActive || data.searchFlag) && !data.docker;
	if (filter && hasActiveAppSearch && filter === committedFilter) {
		$('#searchBox').val(filter);
		data.searchInProgress = false;
		if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
			$('.dockerSearch').removeClass("ca_hide");
			$('.templateSearch').addClass("ca_hide");
		} else {
			$('.dockerSearch,.templateSearch').addClass("ca_hide");
		}
		var nextMax = getMaxPerPage();
		var oldMax = Math.max(1, parseInt(data.maxPerPage, 10) || 1);
		var maxChanged = nextMax && nextMax > 0 && nextMax !== oldMax;
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		if (maxChanged && typeof changePage === "function") {
			/* Trigger page-geometry banner by passing a different page token.
			   changePage() will remap to the correct page based on old first-visible index. */
			var curPage = Math.max(1, parseInt(data.currentpage, 10) || 1);
			changePage(curPage === 1 ? 2 : 1);
		}
		return;
	}

	if ( ! filter ) {
		$("#searchBox").val(filter);
		data.searchInProgress = false;
		if ( data.searchActive || data.searchFlag || data.docker ) {
			if (typeof caCloseSearchModal === "function") caCloseSearchModal();
			var $homeBtn = $(".startupButton").first();
			if ($homeBtn.length) {
				$homeBtn.trigger("click");
			} else {
				appStore();
			}
			return;
		}
		data.committedSearchFilter = "";
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		else caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
		return;
	}

	data.docker = "";
	data.section = "AppStore";

	$('#searchBox').val(filter);
	$(".multi_installDiv").hide();

	scrollToTop();
	if (filter) {
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		caClearHomeSectionSubtitle();
		$("#sortIconArea").show();
	 // $(".category").html(sprintf("<?tr("Search for %s")?>",filter));
		data.searchFlag = true;
	} else {
		if (searchBoxAwesomplete) searchBoxAwesomplete.close();
		/* Cleared filter: only leave search / go home via updateContent when a search was actually active. Draft text alone must not trigger home. */
		if (data.searchActive || data.searchFlag || data.docker) {
			updateContent();
		}
		data.searchFlag = false;
		data.searchInProgress = false;
		data.committedSearchFilter = "";
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		else caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
		return;
	}
	data.searchActive = true;

	if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
		$('.dockerSearch').removeClass("ca_hide");
		$('.templateSearch').addClass("ca_hide");
	} else {
		$('.dockerSearch,.templateSearch').addClass("ca_hide");
	}

	data.searchInProgress = true;
	data.committedSearchFilter = filter;
	caSyncHomeSearchSubtitle();

	data.maxPerPage = getMaxPerPage();
	post({action:'get_content',filter:filter,maxPerPage:data.maxPerPage},function(result) {
		enableButtons();
		$(".selectedMenu").removeClass("selectedMenu");
		$(".subCategory").hide();
		$(".allApps").addClass("selectedMenu");
		updateDisplay(result.display_data || result.display);
		caSyncSearchFilterCollapsed();
		data.section = "AppStore";
		post({action:'getCategoriesPresent'},function(result) {
			$(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
			result.forEach(function(category) {
				var menuItem = $.find(".caMenuItem[data-category='"+category+"']");
				$(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
			});
			data.searchInProgress = false;
		});
	});
}

/**
 * Re-render the card grid with the active sort. For Previous / Installed / Action Centre, loads all rows up front (`maxPerPage` 99999, `data.allLoaded`).
 *
 * @param {HTMLElement} [button] Optional element that triggered the resort
 * @param {string} [buttonClass] Legacy class hint
 * @param {boolean|string} [previousApps] Truthy enables “load everything” mode for multi-select lists
 */
function changeSortOrder(button,buttonClass,previousApps) {
	var pageNumber = data.currentpage;
	var selected = data.selected;
	var startup = false;
	if ( button || buttonClass || previousApps) {
		data.searchFlag = false;
	}

	$(".startupButton").each(function(){
		if ($(this).hasClass("selectedMenu")) {
			startup = "true";
		}
	});
	/* Previous Apps / Installed Apps / Action Centre rely on Select All etc., so
	   load every card up front (no pagination) and disable the virtualizer's
	   eviction so the full DOM stays available. */
	var postOpts = {action:'display_content',pageNumber:pageNumber,selected:selected,startup:startup};
	if (previousApps) {
		postOpts.maxPerPage = 99999;
		data.allLoaded = true;
	} else {
		data.allLoaded = false;
	}
	post(postOpts,function(result) {
		updateDisplay(result.display_data || result.display);
	});
}

/**
 * Fetch a category or home page from the server (`get_content`): resets pagination, adjusts labels for repository view, wires max rows on home.
 *
 * @param {boolean} init Legacy init flag (unused in current flow)
 * @param {string} category Menu key, `INITIALIZE`, `NONE`, or empty for All/New
 * @param {string} description Human-readable title for the category row
 * @param {string} newApp Spotlight / new-app hint passed to PHP
 * @param {string} startupDisplay Startup screen cookie / default view key
 */
function getContent(init,category,description,newApp,startupDisplay) {
	data.currentpage = 1;
	var initialize;
	var maxHomeApps = 6; // Maximum number of apps to display in each row on home page
	data.maxPerPage = getMaxPerPage();

	enableSearch();

	if ( category != "NONE" ) {
		if ( category == "INITIALIZE" ) {
			initializeAppStore();
			category = "NONE";
			initialize = true;
			enableButtons();
			data.maxPerPage = maxHomeApps;
		}

		if ( (category == "New") || (category == "All") ) {
			category = "";
		}
