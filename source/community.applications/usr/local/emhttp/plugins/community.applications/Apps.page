	if ( ! array_key_exists($caDefaultKey, $GLOBALS['caSettings']) ) continue;
	if ( (string)$GLOBALS['caSettings'][$caDefaultKey] !== (string)$caDefaultValue ) {
		$caSettingsClasses[] = "ca_" . $caDefaultKey;
	}
}
$caSettingsClasses = implode(" ", $caSettingsClasses);

/**
