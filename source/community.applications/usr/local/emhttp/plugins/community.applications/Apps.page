/**
 * Fetch a page of cards from the server (`display_content`), optionally appending for infinite scroll.
 *
 * @param {number|string} pageNumber 1-based page index
 * @param {boolean} [append] When true, append HTML/cards to the current grid
 */
function changePage(pageNumber, append) {
	pageNumber = parseInt(pageNumber, 10) || 1;
	var doAppend = !!append;
	caRestoreCommittedSearchIfDrafted();
	if (searchBoxAwesomplete) searchBoxAwesomplete.close();
	var selected = data.selected;
	data.currentpage = pageNumber;

	post({action:'display_content',pageNumber:pageNumber,selected:selected,maxPerPage:data.maxPerPage},function(result) {
		updateDisplay(result.display_data || result.display, doAppend);
		if (!doAppend) scrollToTop();
	});
}

/**
 * Close SweetAlert and spinner chrome and call {@link enableSearch}.
 *
 * @param {boolean} [force=false] When true, `swal.close` bypasses some guard paths (legacy)
 */
function myCloseAlert(force=false) {

	swal.close();
	$("div.spinner, .sweet-alert").hide();
	enableSearch();
}

/**
 * Close any modal, collapse the sidebar, and run {@link doSearch} with `newSearch`.
 *
 * @param {string} newSearch Committed search string
 */
function doSidebarSearch(newSearch) {
	swal.close();
	closeSidebar();
	doSearch(false,newSearch);
}

/**
 * Run template search (or navigate home when cleared): manages `searchActive`, Docker vs template toggles, commits filter, POSTs `get_content`.
 *
 * @param {*} button Legacy; often `false` means “use current `#searchBox` value”
 * @param {string|false} [newSearch] When a string, pre-fills the search box before filtering
 */
function doSearch(button,newSearch) {
	if ( data.searchInProgress )
		return;

	data.searchInProgress = true;

	if ( ! newSearch === false ) {
		$('#searchBox').val(newSearch);
	}
	var filter = $('#searchBox').val();
	filter = $.trim(filter);
	filter = stripTags(filter);

	/* No-op: term hasn't changed from the currently committed search.
	   Close the modal; if maxPerPage changed (viewport/layout changed), re-render current
	   search pagination via changePage so cards-per-page and page mapping stay consistent. */
	var committedFilter = $.trim(String(data.committedSearchFilter || ""));
	var hasActiveAppSearch = !!(data.searchActive || data.searchFlag) && !data.docker;
	if (filter && hasActiveAppSearch && filter === committedFilter) {
		$('#searchBox').val(filter);
		data.searchInProgress = false;
		if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
			$('.dockerSearch').removeClass("ca_hide");
			$('.templateSearch').addClass("ca_hide");
		} else {
			$('.dockerSearch,.templateSearch').addClass("ca_hide");
		}
		var nextMax = getMaxPerPage();
		var oldMax = Math.max(1, parseInt(data.maxPerPage, 10) || 1);
		var maxChanged = nextMax && nextMax > 0 && nextMax !== oldMax;
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		if (maxChanged && typeof changePage === "function") {
			/* Trigger page-geometry banner by passing a different page token.
			   changePage() will remap to the correct page based on old first-visible index. */
			var curPage = Math.max(1, parseInt(data.currentpage, 10) || 1);
			changePage(curPage === 1 ? 2 : 1);
		}
		return;
	}

	if ( ! filter ) {
		$("#searchBox").val(filter);
		data.searchInProgress = false;
		if ( data.searchActive || data.searchFlag || data.docker ) {
			if (typeof caCloseSearchModal === "function") caCloseSearchModal();
			var $homeBtn = $(".startupButton").first();
			if ($homeBtn.length) {
				$homeBtn.trigger("click");
			} else {
				appStore();
			}
			return;
		}
		data.committedSearchFilter = "";
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		else caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
		return;
	}

	data.docker = "";
	data.section = "AppStore";

	$('#searchBox').val(filter);
	$(".multi_installDiv").hide();

	scrollToTop();
	if (filter) {
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		caClearHomeSectionSubtitle();
		$("#sortIconArea").show();
	 // $(".category").html(sprintf("<?tr("Search for %s")?>",filter));
		data.searchFlag = true;
	} else {
		if (searchBoxAwesomplete) searchBoxAwesomplete.close();
		/* Cleared filter: only leave search / go home via updateContent when a search was actually active. Draft text alone must not trigger home. */
		if (data.searchActive || data.searchFlag || data.docker) {
			updateContent();
		}
		data.searchFlag = false;
		data.searchInProgress = false;
		data.committedSearchFilter = "";
		if (typeof caCloseSearchModal === "function") caCloseSearchModal();
		else caSyncSearchFilterCollapsed();
		caSyncHomeSearchSubtitle();
		return;
	}
	data.searchActive = true;

	if ( ! dockerNotEnabled && (filter.indexOf(" Repository") < 1) ) {
		$('.dockerSearch').removeClass("ca_hide");
		$('.templateSearch').addClass("ca_hide");
	} else {
		$('.dockerSearch,.templateSearch').addClass("ca_hide");
	}

	data.searchInProgress = true;
	data.committedSearchFilter = filter;
	caSyncHomeSearchSubtitle();

	data.maxPerPage = getMaxPerPage();
	post({action:'get_content',filter:filter,maxPerPage:data.maxPerPage},function(result) {
		enableButtons();
		$(".selectedMenu").removeClass("selectedMenu");
		$(".subCategory").hide();
		$(".allApps").addClass("selectedMenu");
		updateDisplay(result.display_data || result.display);
		caSyncSearchFilterCollapsed();
		data.section = "AppStore";
		post({action:'getCategoriesPresent'},function(result) {
			$(".categoryMenu").removeClass("caMenuEnabled").addClass("caMenuDisabled");
			result.forEach(function(category) {
				var menuItem = $.find(".caMenuItem[data-category='"+category+"']");
				$(menuItem).removeClass("caMenuDisabled").addClass("caMenuEnabled");
			});
			data.searchInProgress = false;
		});
	});
}

/**
 * Re-render the card grid with the active sort. For Previous / Installed / Action Centre, loads all rows up front (`maxPerPage` 99999, `data.allLoaded`).
 *
 * @param {HTMLElement} [button] Optional element that triggered the resort
 * @param {string} [buttonClass] Legacy class hint
 * @param {boolean|string} [previousApps] Truthy enables “load everything” mode for multi-select lists
 */
function changeSortOrder(button,buttonClass,previousApps) {
	var pageNumber = data.currentpage;
	var selected = data.selected;
	var startup = false;
	if ( button || buttonClass || previousApps) {
		data.searchFlag = false;
	}

	$(".startupButton").each(function(){
		if ($(this).hasClass("selectedMenu")) {
			startup = "true";
		}
	});
	/* Previous Apps / Installed Apps / Action Centre rely on Select All etc., so
	   load every card up front (no pagination) and disable the virtualizer's
	   eviction so the full DOM stays available. */
	var postOpts = {action:'display_content',pageNumber:pageNumber,selected:selected,startup:startup};
	if (previousApps) {
		postOpts.maxPerPage = 99999;
		data.allLoaded = true;
	} else {
		data.allLoaded = false;
	}
	post(postOpts,function(result) {
		updateDisplay(result.display_data || result.display);
	});
}

/**
 * Fetch a category or home page from the server (`get_content`): resets pagination, adjusts labels for repository view, wires max rows on home.
 *
 * @param {boolean} init Legacy init flag (unused in current flow)
 * @param {string} category Menu key, `INITIALIZE`, `NONE`, or empty for All/New
 * @param {string} description Human-readable title for the category row
 * @param {string} newApp Spotlight / new-app hint passed to PHP
 * @param {string} startupDisplay Startup screen cookie / default view key
 */
function getContent(init,category,description,newApp,startupDisplay) {
	data.currentpage = 1;
	var initialize;
	var maxHomeApps = 10; // Maximum number of apps to display in each row on home page
	data.maxPerPage = getMaxPerPage();

	enableSearch();

	if ( category != "NONE" ) {
		if ( category == "INITIALIZE" ) {
			initializeAppStore();
			category = "NONE";
			initialize = true;
			enableButtons();
			data.maxPerPage = maxHomeApps;
		}

		if ( (category == "New") || (category == "All") ) {
			category = "";
		}
		var el_dl = $.find(".sortIcons[data-sortby='downloads']");
		var el_tr = $.find(".sortIcons[data-sortby='trending']");

		if ( category == "repos" ) {
			$(el_dl).html("<?=tr("Number Of Apps");?>");
			$(el_tr).html("<?=tr("Average Trend");?>");
		} else {
			$(el_dl).html("<?=tr("Downloads");?>");
			$(el_tr).html("<?=tr("Trend");?>");
		}
		caRefreshSortMenu();

		var filter = $('#searchBox').val();
		if ( ! filter ) {
			$('.dockerSearch,.templateSearch').addClass("ca_hide");
		}
		if ( description && ! filter ) {
		 // $(".category").html(description);
		}
		post({action:'get_content',maxPerPage:data.maxPerPage,filter:filter,category:category,newApp:newApp,startupDisplay:startupDisplay,maxHomeApps:maxHomeApps,mobileDevice:cssVar("--mobileDevice")},function(result) {
			updateDisplay(result.display_data || result.display);
			if ( initialize ) {
				populateAutoComplete();
				downloadStatistics();
			}
		});
	}
}

/**
 * Trigger background statistics/template fetch: starts the optional nchan feed when configured, then `postNoSpin` `downloadStatistics`.
 */
function downloadStatistics() {
	try {
		if (window.caGettingTemplatesSub && !window.caGettingTemplatesSubStarted) {
			window.caGettingTemplatesSubIgnoreFirst = true;
			window.caGettingTemplatesSub.start();
			window.caGettingTemplatesSubStarted = true;
		}
	} catch(e) {}
	postNoSpin({action:'downloadStatistics'});
}

/**
 * Load search suggestions into Awesomplete and bind `awesomplete-selectcomplete` to {@link awesompleteSearch}.
 *
 * @param {function} [after] Optional callback after the list is installed
 */
function populateAutoComplete(after) {
	postNoSpin({action:'populateAutoComplete'},function(result) {
		searchBoxAwesomplete.list = result.autocomplete;
		searchBoxAwesomplete.maxItems = 20;
		searchBoxAwesomplete.minChars = 3;
		
		$("#searchBox").off("awesomplete-selectcomplete", awesompleteSearch);
		$("#searchBox").on("awesomplete-selectcomplete", awesompleteSearch);
		searchBoxAwesomplete.close(); // otherwise it opens automatically during restore state
		if (typeof after === "function") {
			after();
		}
	});
}

/**
 * Awesomplete pick handler: if no real sort is active, reset to default sort server-side, then {@link doSearch}.
 */
function awesompleteSearch() {
	// this is the check sort order function
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( !sortButton) {
		$(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
		post({action:"defaultSortOrder"},function(data) {
			$("#defaultSort").addClass("enabledIcon");
			doSearch(false);
		});
	} else {
		doSearch(false);
	}
}

/**
 * Persist CA state with {@link saveState}, open `newURL`, and warn if the browser blocks pop-ups.
 *
 * @param {string} newURL Destination URL
 * @param {string} [target='_self'] `window.open` target name
 */
function openNewWindow(newURL,target='_self') {
	saveState();
	var popUp = window.open(newURL,target);
	if ( !popUp || popUp.closed || typeof popUp == "undefined" ) {
		var popupWarning = addBannerWarning("<?=_('Popup Blocked.');?>");
		setTimeout(function() {
			removeBannerWarning(popupWarning);}
			,10000);
	}
}

/**
 * Clear `#searchBox`, re-enable all category rows, reset search/docker flags, and sync collapsed search / Home menu labels.
 */
function clearSearchBox() {
	$(".categoryMenu").removeClass("caMenuDisabled").addClass("caMenuEnabled");
	$("#searchBox").val("");
	hideSortIcons();
	data.committedSearchFilter = "";
	/* Reset search-state flags so the Home menu reverts from "Clear Search" to
	   "Home" and the All Apps item from "All Results" back to "All Apps" when
	   the user navigates away from search results into Installed / Previous /
	   Pinned / Action Centre / Favourite Repo. */
	data.searchActive = false;
	data.searchFlag = false;
	data.docker = "";
	caSyncSearchFilterCollapsed();
	caSyncHomeSearchSubtitle();
	if (typeof caSyncHomeMenuLabel === "function") caSyncHomeMenuLabel();
}

/**
 * Close the description sidebar: optionally preserve cookies, tear down context menus, submit dirty settings forms, and animate `sidenav` closed.
 *
 * @param {boolean} [cookie=false] When false, clear `sidebarAppPath` / `sidebarAppName` cookies
 * @param {boolean} [visible=false] Legacy visibility hint (unused)
 */
function closeSidebar(cookie=false,visible=false) {
	if ( ! cookie ) {
		$.cookie("sidebarAppPath","",{path:"/;SameSite=Lax"});
		$.cookie("sidebarAppName","",{path:"/;SameSite=Lax"});
	}
	context.destroy("#supportPopup");
	context.destroy("#actionsPopup");

	/* If a settings form was open with unsaved edits, submit it instead of just
	   closing — the submit handler saves and reloads, which subsumes closing. */
	var $settingsForm = $("#sidenavContent .ca_settingsForm");
	if ($settingsForm.length) {
		var initialState = $settingsForm.data("caInitialState");
		if (typeof initialState === "string" && $settingsForm.serialize() !== initialState) {
			$settingsForm.trigger("submit");
			return;
		}
	}

	$(".sidenav").removeClass("sidenavShow").addClass("sidenavHide").scrollTop(0);
	$(".nav-user.show").show();
	enableSearch();
}

/**
 * Confirm no other plugin operation is running, check optional upgrade requirements, then {@link actuallyInstallPlugin}.
 *
 * @param {string} pluginURL URL or path passed to `checkPluginInProgress`
 * @param {boolean} [update=false] Upgrade vs fresh install
 * @param {string} [requires=''] Dependency string for upgrade checks
 */
function installPlugin(pluginURL,update=false,requires="") {
	post({action:"checkPluginInProgress",pluginPath:pluginURL},function(data) {
		if (data.inProgress) {
			swal({
				title: "<?tr("Installation already in progress");?>",
				text: "<?tr("This plugin is currently being installed or uninstalled.  Wait until the current operation is completed and try again");?>",
				allowOutsideClick: false,
				showConfirmButton: true,
				showCancelButton: false,
				confirmButtonText: "<?tr("OK");?>",
				type: "warning"
			},function() {
				enableSearch();
			});
		} else {
			if ( update && requires ) {
				post({action:"checkRequirements",requires:requires},function(data) {
					if (! data.met) {
						swal({
							title: "<?tr('Requirements not met');?>",
							text: "<?tr('The requirements for this upgrade have not been met on your system');?>",
							allowOutsideClick: false,
							showConfirmButton: true,
							showCancelButton: false,
							confirmButtonText: "<?tr('OK');?>",
							type: "error",
							html: true
						},function(isConfirm) {
							enableSearch();
						});
					} else {
						actuallyInstallPlugin(pluginURL,update);
					}
				});
			} else {
				actuallyInstallPlugin(pluginURL,update);
			}
		}
	});
}

/**
 * Close sidebar, hide matching pending-action rows, pick post-install callback (`actionCentre` vs sidebar refresh), {@link ca_openPlugin}.
 *
 * @param {string} pluginURL Resolved install/update URL (proxied for new installs)
 * @param {boolean} [update=false]
 */
function actuallyInstallPlugin(pluginURL,update=false) {
	var type = update ? "update" : "install";
	if ( ! update ) {
		pluginURL = "<?=CA_PATHS['pluginProxy']?>" + pluginURL;
	}
	title = update ? "<?tr("Update Plugin");?>" : "<?tr("Install Plugin");?>";
	closeSidebar(true);
	hidePluginPending(pluginURL);

	if ( $(".selectedMenu").data("category") == "action_centre" ) {
		var postFunction = "actionCentre";
	} else {
		var postFunction = "OpenSidebarAndRefreshDisplay";
	}
	data.deprecated = false; // global var here to trigger a rescan of action centre
	if ( pluginURL.includes("&deprecated") || pluginURL.includes("&incompatible") ) {
		data.deprecated = true;
		pluginURL = pluginURL.replace("&deprecated","");
		pluginURL = pluginURL.replace("&incompatible","");
	}
	ca_openPlugin('plugin '+type+' '+pluginURL,title,'',postFunction);
}

/**
 * Hide Action Centre rows for a plugin whose install is now underway (match full URL or basename).
 *
 * @param {string} pluginURL
 */
function hidePluginPending(pluginURL) {
	if ( pluginURL.includes("/") ) {
		$(".actionsButton").each(function() {
			if ( $(this).data("pluginurl") == pluginURL || $(this).data("pluginurl")+"&deprecated" == pluginURL ) {
				$(this).hide();
			}
		});
	} else {
		$(".actionsButton").each(function() {
			if ( $(this).data("pluginurl").basename() == pluginURL ) {
				$(this).hide();
			}
		});
	}
}

/**
 * Hide Action Centre rows for a language pack about to be installed/updated/removed.
 *
 * @param {string} language Pack id or filename (`lang-` prefix / `.xml` stripped)
 */
function hideLanguagePending(language) {
	language = language.replace("lang-","");
	language = language.replace(".xml","");
	if ( ! language )
		return;

	$(".actionsButton").each(function() {
		if ( $(this).data("languagepack") == language ) {
			$(this).hide();
		}
	});
}

/**
 * After plugin install flows: reload the page when PHP reports startup, otherwise refresh the grid and reopen any saved sidebar app.
 */
function OpenSidebarAndRefreshDisplay() {
	post({action:"onStartupScreen"},function(result) {
		if (result.status) {
			window.location.reload();
		} else {
			var apppath = $.cookie("sidebarAppPath");
			var appname = $.cookie("sidebarAppName");

			appname = stripTags(appname);

			refreshDisplay();
			if ( $.trim(apppath) ) {
				showSidebarApp(apppath,appname);
			}
			if ( data.deprecated ) {
				data.deprecated = false;
				setupActionCentre();
			}

		}
	});
}

/**
 * Show Installed Apps, Previous Apps (multi-select), or Action Centre prep: clear search, enforce default sort when needed, then {@link getPrevApps}.
 *
 * @param {boolean|string} installed `true` installed only, `false` previous list, `"action"` action-centre mode
 * @param {boolean} [dontClear=false] Keep prior multi-select state when true
 * @param {string} [filter=''] Server filter for previous-apps section
 */
function previousApps(installed,dontClear=false,filter="") {
	clearCategory();
	setPageOne();
	data.docker = "";

	clearSearchBox();
	$(".dockerSearch,.templateSearch").addClass("ca_hide");
	showSortIcons();

	// this is the checkSortOrder function running to prevent a race condition
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( installed == "action" )
		$(".multi_installButton").addClass("actionCenter");
