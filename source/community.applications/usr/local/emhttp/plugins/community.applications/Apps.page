/**
 * Detach the per-app action + support button strip from the freshly-rendered
 * sidebar content and append it next to the always-visible CLOSE button in
 * .popupCloseAreaButtons. Server keeps emitting the strip inside the popup
 * body (so it ships with the right per-app actions); this just relocates it
 * after each render so the buttons live at the top of the sidebar instead
 * of inline with the icon area.
 */
function caRelocatePopupActions() {
	$(".popupCloseAreaButtons .popupStickyActions").remove();   // clear any stragglers
	var $strip = $("#sidenavContent .popupStickyActions").first();
	if ($strip.length) $strip.detach().appendTo(".popupCloseAreaButtons");
}

/**
 * Load app popup HTML via `getPopupDescription`, wire MagnificPopup galleries, context menus, charts, and async readme/change sections.
 *
 * @param {string} apppath Template path key
 * @param {string} appname Human-readable application name
 */
function showSidebarApp(apppath,appname) {
	mySpinner();
	disableSearch();
	$.cookie("sidebarAppPath",apppath,{path:"/;SameSite=Lax"});
	$.cookie("sidebarAppName",appname,{path:"/;SameSite=Lax"});
	data.sidebarapppath = apppath;
	data.sidebarappname = appname;
	/* Sidebar-open is the canonical save trigger. Every install / uninstall /
	   update / xmlInstall path lives behind a sidebar button, so the snapshot
	   is guaranteed to be fresh before any navigation away from /Apps. */
	saveState();

	$(".popUpBack").addClass("ca_hide");
	$(".sidenav").removeClass("sidenavHide");
	$(".nav-user.show").hide();
	$("#sidenavContent").html($("#sidebarLoading").html());
	$(".sidebar").show();
		post({action:'getPopupDescription',appName:appname,appPath:apppath},function(result) {
			myCloseSpinner();
			$("#sidenavContent").html(result.description);
			caRelocatePopupActions();
			caInitSidebarReadmore();
			caLoadSidebarReadmeSections();
			caLoadSidebarTemplateChanges();
			caRenderSidebarRequires();
			/* Bind to the .caMediaGallery wrapper with delegate so all photos +
			   videos inside are a single MFP gallery — MFP picks `image` vs
			   `iframe` per item from the per-element `mfp-<type>` class. The
			   carats / arrow keys / click-to-next now work because gallery
			   options are in object form (the boolean `gallery: true` form
			   never enabled the module — `r.enabled` was undefined). */
			$('.caMediaGallery').magnificPopup({
				delegate: '.screenshot',
				closeMarkup: "<span class='mfp-close magnificPopup caButton caButtonLarge caButtonRed'>"+tr("CLOSE")+"</span>",
				/* Gallery mode: don't close on content click — gallery's own
				   navigateByImgClick handles image clicks (advances to next).
				   Otherwise the click both advances AND closes. */
				closeOnContentClick: false,
				removalDelay: 100,
				mainClass: 'mfp-fade',
				gallery: { enabled: true, navigateByImgClick: true, preload: [0,1] },
				zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
				iframe: { patterns: caMfpIframePatterns },
				callbacks: {
					beforeOpen: function() {
						/* keepIdentity=true: afterClose below reopens the same
						   sidebar via data.sidebarapp{path,name}, which the
						   default closeSidebar() path would have nuked → the
						   reopen would silently fall through to the first app
						   in displayed.json. */
						closeSidebar(true);
						/* MFP binds keydown(left/right) to gallery.next/prev
						   regardless of item count. With the default loop:true,
						   a single-item gallery wraps back to itself on each
						   key, which re-runs updateItemHTML() and recreates
						   the iframe with ?autoplay=1 — restarting the video.
						   Disabling loop makes next()/prev() early-return at
						   both boundaries (0 and length-1), so the keys are
						   effectively no-ops when items.length === 1. */
						this.st.gallery.loop = (this.items && this.items.length > 1);
					},
					afterClose: function() {
						showSidebarApp(data.sidebarapppath,data.sidebarappname);
					}
				}
			});
			/* Stragglers — .screenshot elements that aren't part of a gallery
			   (eg. the popup app icon) get a plain single-item popup. */
			$('.screenshot').not($('.caMediaGallery').find('.screenshot')).magnificPopup({
				type:'image',
				closeMarkup: "<span class='mfp-close magnificPopup caButton caButtonLarge caButtonRed'>"+tr("CLOSE")+"</span>",
				closeOnContentClick: true,
				removalDelay: 100,
				mainClass: 'mfp-fade',
				zoom: { enabled: true, duration: 500, easing: 'ease-in-out' }
			});
			slideInSidebar();

			if (!data.caReadmoreTopLessBound) {
				data.caReadmoreTopLessBound = true;
				$("#sidenavContent").on("click", ".ca_readless_top", function(e) {
					e.preventDefault();
					e.stopPropagation();
					// This control sits right before the readmore section it controls.
					var $section = $(this).nextAll(".popup_readmore").first();
					if (!$section.length) return;
					// Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
					var $toggle = $section.nextAll(".readmore-js-toggle").first();
					if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
					if ($toggle.length) $toggle.trigger("click");
					else $section.readmore("toggle");
				});
			}

			popUpChart(result);
			/* Support entries now render as inline caButtons in skin.php — no
			   #supportPopup dropdown to attach. Actions still uses the menu. */
			setupContext(result.actionsContext,"#actionsPopup");

			$(".betaPopupText,.popupTableLeft,.upgradePopupText,.installedPopupText").fitText(true);

			postNoSpin({action:'getLastUpdate',ID:result.ID},function(lastUpdate) {
				if (lastUpdate.lastUpdate) {
					$("#template"+result.ID).fadeOut("slow","linear",function() {
						$("#template"+result.ID).html(lastUpdate.lastUpdate);
						$("#template"+result.ID).fadeIn("slow");
					});
				}
			});
		})
}

/**
 * Lazy-load README fragments for `.ReadmeSection` placeholders in the open sidebar.
 *
 * Goes through the PHP backend (`caFetchSidebarSource` action) rather than
 * fetch()ing the upstream README directly. Two reasons:
 *   1. CORS — some repo hosts don't set Access-Control-Allow-Origin, which
 *      broke the old client-side path with a console error and no fallback.
 *   2. Shared on-disk cache — the backend stores the body under
 *      templates-community as `{RepoName}-README.md`, so repeat opens (and
 *      concurrent tabs) reuse one copy. Cache lives until the next appfeed
 *      refresh, same window the old browser HTTP cache was valid for.
 *
 * Falls through to the existing `data-readme-url-fallback` (master branch
 * variant) on first-call failure.
 */
function caLoadSidebarReadmeSections() {
	var $sections = $("#sidenavContent .ReadmeSection[data-readme-url]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		if ($section.data("readmeLoaded") || $section.data("readmeLoading")) {
			return;
		}
		$section.data("readmeLoading", true);
		var readmeId = $section.attr("data-readme-id") || $section.attr("id") || "";
		var url = $section.attr("data-readme-url") || "";
		var fallback = $section.attr("data-readme-url-fallback") || "";
		var repoName = $section.attr("data-readme-repo") || "";

		/* Server-side fetch + cache. caIsPublicHttpUrlJs is still applied as
		   a belt-and-braces gate — the backend re-validates with the stricter
		   caIsPublicHttpUrl, but failing fast here avoids a round-trip on a
		   URL we already know is unusable. */
		function fetchText(u) {
			if (!caIsPublicHttpUrlJs(u)) return Promise.reject(new Error("URL not allowed"));
			/* $.post directly (not postNoSpin) so the Promise also rejects on
			   transport failures — non-2xx responses, XHR aborts, JSON parse
			   errors. postNoSpin only fires its callback on the success path,
			   which would leave the README section stuck in "Loading…" forever
			   on any backend hiccup. tabId stamped manually since we're
			   bypassing post()'s auto-stamping. */
			return new Promise(function(resolve, reject) {
				$.post(execURL, {
					action: "caFetchSidebarSource",
					url: u,
					repoName: repoName,
					kind: "readme",
					noSpinner: true,
					tabId: (typeof data !== "undefined" && data.tabId) ? data.tabId : ""
				})
				.done(function(result) {
					if (result && result.ok && typeof result.content === "string" && result.content !== "") {
						resolve(result.content);
					} else {
						reject(new Error((result && result.message) ? result.message : "fetch failed"));
					}
				})
				.fail(function() { reject(new Error("transport failure")); });
			});
		}
		function paint($current, html, isError) {
			if (isError) {
				$current.find(".ca_readme_body").text(html);
			} else {
				$current.find(".ca_readme_body").html(html);
			}
			$current.data("readmeLoaded", true);
			$current.data("readmeLoading", false);
			caInitSidebarReadmore($current);
		}
		function locateCurrent() {
			/* Re-locate by id in case the sidebar was re-rendered mid-flight.
			   Then verify the placeholder still points at the same URL we set
			   out to fetch — drops the response on the floor if the user has
			   moved on to a different app. */
			var $current = readmeId ? $("#sidenavContent #" + readmeId) : $section;
			if (!$current.length) return null;
			var currentUrl = $current.attr("data-readme-url") || "";
			if (url && currentUrl !== url) return null;
			return $current;
		}

		fetchText(url)
			.catch(function() { return fallback ? fetchText(fallback) : Promise.reject(); })
			.then(function(text) {
				var $current = locateCurrent();
				if (!$current) return;
				paint($current, caSanitizeReadme(text), false);
			})
			.catch(function() {
				var $current = locateCurrent();
				if (!$current) return;
				paint($current, tr("README can't be loaded"), true);
			});
	});
}

/**
 * Lazy-load template change-log HTML for `.ca_template_changes` blocks in the
 * sidebar.
 *
 * The body (a .plg for plugins or a template XML for containers) is fetched
 * by the PHP backend (`caFetchSidebarSource` with kind=changes) so we don't
 * trip CORS on custom-hosted repos, and so the on-disk cache under
 * templates-community is shared across tabs. Cache file is named
 * `{RepoName}-{basename(url)}` which keeps the .plg / .xml suffix from the
 * source URL for debuggability.
 *
 * The `<CHANGES>` element is then extracted via caExtractChangesFromXml and
 * the markdown run through caSanitizeReadme (same strip+marked+DOMPurify+
 * URL allowlist pipeline as README).
 */
function caLoadSidebarTemplateChanges() {
	var $sections = $("#sidenavContent .ca_template_changes[data-changes-url]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		if ($section.data("changesLoaded") || $section.data("changesLoading") || $section.attr("data-changes-loaded") == "1") {
			return;
		}
		$section.data("changesLoading", true);
		var changesId = $section.attr("data-changes-id") || $section.attr("id") || "";
		var url = $section.attr("data-changes-url") || "";
		var repoName = $section.attr("data-changes-repo") || "";

		function locateCurrent() {
			var $current = changesId ? $("#sidenavContent #" + changesId) : $section;
			if (!$current.length) return null;
			var currentUrl = $current.attr("data-changes-url") || "";
			if (url && currentUrl !== url) return null;
			return $current;
		}
		function paint($current, content, isHtml) {
			if (isHtml) $current.html(content);
			else $current.text(content);
			$current.data("changesLoaded", true);
			$current.data("changesLoading", false);
			$current.attr("data-changes-loaded", "1");
		}

		/* Gate the URL through caIsPublicHttpUrlJs before posting so a
		   future drift that lets a feed-controlled value land in the
		   data-changes-url attribute can't make the server pull from a
		   LAN host. The backend re-validates anyway. */
		/* $.post directly (not postNoSpin) so the Promise also rejects on
		   transport failures — non-2xx, XHR aborts, JSON parse errors. The
		   postNoSpin callback only fires on the success path, which would
		   leave the Changes section stuck in "Loading…" on any backend
		   hiccup. See the README block above for the same pattern. */
		var fetchPromise = caIsPublicHttpUrlJs(url)
			? new Promise(function(resolve, reject) {
				$.post(execURL, {
					action: "caFetchSidebarSource",
					url: url,
					repoName: repoName,
					kind: "changes",
					noSpinner: true,
					tabId: (typeof data !== "undefined" && data.tabId) ? data.tabId : ""
				})
				.done(function(result) {
					if (result && result.ok && typeof result.content === "string" && result.content !== "") {
						resolve(result.content);
					} else {
						reject(new Error((result && result.message) ? result.message : "fetch failed"));
					}
				})
				.fail(function() { reject(new Error("transport failure")); });
			})
			: Promise.reject(new Error("URL not allowed"));
		fetchPromise
			.then(function(xmlText) {
				var $current = locateCurrent();
				if (!$current) return;
				var markdown = caExtractChangesFromXml(xmlText);
				if (markdown === "") {
					paint($current, tr("Change log can't be loaded"), false);
					return;
				}
				paint($current, caSanitizeReadme(markdown), true);
			})
			.catch(function() {
				var $current = locateCurrent();
				if (!$current) return;
				paint($current, tr("Change log can't be loaded"), false);
			});
	});
}

/**
 * Render the Additional Requirements block client-side. skin.php emits a
 * placeholder `<div class='ca_requires_pending' data-requires='...'>` with the
 * raw text JSON-encoded in the data attribute; this walks every such div in
 * the freshly-loaded sidebar, pipes the text through the same
 * strip→marked→DOMPurify chain we use for README/Changes, then applies the
 * sidebar-search-link substitution that's unique to this field.
 *
 * No fetch — the data is already in the DOM payload, just deferred-render so
 * the sanitization pipeline matches everywhere else. JSON-decode is defensive
 * against the attribute being absent or malformed.
 */
function caRenderSidebarRequires() {
	var $sections = $("#sidenavContent .ca_requires_pending[data-requires]");
	if (!$sections.length) return;
	$sections.each(function() {
		var $section = $(this);
		var raw = "";
		try { raw = JSON.parse($section.attr("data-requires") || "\"\""); }
		catch (e) { raw = ""; }
		if (typeof raw !== "string" || raw === "") {
			$section.text("");
		} else {
			/* Normalize newlines the way the old PHP path did before handing
			   to markdown: drop \r and the &#xD; entity, turn \n into a
			   markdown hard-break (two trailing spaces + newline). marked
			   treats "  \n" as <br> regardless of the `breaks` option, which
			   matches caSanitizeReadme's defaults. */
			var normalized = raw.replace(/\r/g, "").replace(/&#xD;/g, "").replace(/\n/g, "  \n");
			var html = caSanitizeReadme(normalized);
			html = caApplySidebarSearchLinksJs(html);
			$section.html(html);
		}
		$section.removeAttr("data-requires").removeClass("ca_requires_pending");
	});
}

/**
 * Initialize jQuery readmore.js on `.popup_readmore` nodes (optional scoped root); inserts inline “show less” control for readme sections.
 *
 * @param {jQuery|HTMLElement|undefined} [$scope] When set, only initializes within this subtree
 */
function caInitSidebarReadmore($scope) {
	var $targets = $scope ? $scope : $('.popup_readmore');
	$targets.each(function() {
		var $el = $(this);
		// Avoid double-initializing readmore on the same element.
		if ($el.hasClass("readmore-js")) return;
		$el.readmore({
		maxHeight:250,
		moreLink:"<i class='ca_readmore fa fa-chevron-down'> <?=tr("SHOW MORE");?></i>",
		lessLink:"<i class='ca_readmore fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>",
		afterToggle:function(trigger, element, expanded) {
			var $el = $(element);
			if (!$el.hasClass("ReadmeSection")) return;
			$el.prev(".ca_readless_top").remove();
			if (!expanded) return;
			var topLess = "<i class='ca_readmore ca_readless_top fa fa-chevron-up'> <?=tr("SHOW LESS");?></i>";
			$el.before(topLess);
		}
		});
	});
}

/**
 * Apply CSS classes that slide the sidebar into view (`sidenavShow` / `sidenavHide`)
 * and move focus into the dialog so the first interaction inside it actually
 * fires its handler.
 *
 * Without the focus move, opening the sidebar from a card click leaves focus
 * on the card; on mobile the first tap inside the sidebar is consumed by the
 * browser establishing touch focus on the new pane instead of triggering the
 * click handler — the most visible symptom was needing to tap a video
 * thumbnail twice to open it. On desktop the same race occasionally appears
 * when focus didn't transfer cleanly from the opener.
 *
 * `preventScroll:true` avoids the panel jumping when focus lands on it
 * mid-transition (it's still partway off-screen during the 500ms slide).
 * Supported in every browser we target (Chrome 64+, Firefox 68+, Safari 15+).
 */
function slideInSidebar() {
	$(".sidenav").addClass("sidenavShow").removeClass("sidenavHide");
	var el = document.querySelector(".sidenav.sidenavShow");
	if (el) el.focus({ preventScroll: true });
}
/**
 * Open sidebar with repository metadata (`getRepoDescription`): restores cookies when opened from a card vs nested navigation; sets up same media popup pattern as {@link showSidebarApp}.
 *
 * @param {string} repository Repository handle from PHP
 */
function showRepoPopup(repository) {
	if ( !repository ) return;
	data.repository = repository;
	context.destroy("#actionsPopup");
	var fromCard = false;

	if ( ! $(".sidenavShow").length ) {
		$.cookie("sidebarAppName","",{path:"/;SameSite=Lax"});
		$.cookie("sidebarAppPath","",{path:"/;SameSite=Lax"});
		var fromCard = true;
	}
	var sidebarAppName = $.cookie("sidebarAppName");
	var sidebarAppPath = $.cookie("sidebarAppPath");

	$("#sidenavContent").html($("#sidebarLoading").html());

	$(".nav-user.show").hide();

	post({action:'getRepoDescription',repository:repository},function(result) {
		$("#sidenavContent").html(result.description);
		caRelocatePopupActions();
		/* Go through slideInSidebar() rather than toggling the classes inline so
		   the dialog focus handoff happens here too — without it, opening a
		   repo popup leaves focus on the originating card and the first tap
		   inside the panel gets eaten. */
		slideInSidebar();
		caInitSidebarReadmore();
		caLoadSidebarReadmeSections();
		if (!data.caReadmoreTopLessBound) {
			data.caReadmoreTopLessBound = true;
			$("#sidenavContent").on("click", ".ca_readless_top", function(e) {
				e.preventDefault();
				e.stopPropagation();
				// This control sits right before the readmore section it controls.
				var $section = $(this).nextAll(".popup_readmore").first();
				if (!$section.length) return;
				// Prefer proxy-clicking the library's own toggle control (more reliable than calling methods).
				var $toggle = $section.nextAll(".readmore-js-toggle").first();
				if (!$toggle.length) $toggle = $section.nextAll(".ca_readmore").first();
				if ($toggle.length) $toggle.trigger("click");
				else $section.readmore("toggle");
			});
		}

		if (fromCard) {
			$(".popUpBack").addClass("ca_hide");
		} else {
			$(".popUpBack").removeClass("ca_hide");
		}

		/* Same gallery + delegate setup as the app popup, but with the repo-
		   popup callbacks for sidebar restore. Items pick image/iframe type
		   from their own `mfp-image`/`mfp-iframe` class. */
		$('.caMediaGallery').magnificPopup({
			delegate: '.screenshot',
			closeMarkup: "<span class='mfp-close magnificPopup caButton caButtonLarge caButtonRed'>"+tr("CLOSE")+"</span>",
			closeOnContentClick: false,    /* gallery's navigateByImgClick handles image clicks */
			removalDelay: 100,
			mainClass: 'mfp-fade',
			gallery: { enabled: true, navigateByImgClick: true, preload: [0,1] },
			zoom: { enabled: true, duration: 500, easing: 'ease-in-out' },
			iframe: { patterns: caMfpIframePatterns },
			callbacks: {
				beforeOpen: function() {
					/* keepIdentity=true so afterClose's showRepoPopup() reopens
					   to the same repo; without this, closeSidebar() would
					   clear data.sidebarapp{path,name} and the cookies, and
					   the explicit cookie restore in afterClose would be the
					   only thing holding identity together (the in-memory copy
					   used by saveState() would already be gone). */
					closeSidebar(true);
					/* See app-popup gallery: disable loop for 1-item galleries
					   so arrow keys can't re-trigger updateItemHTML() and
					   restart the autoplay iframe. */
					this.st.gallery.loop = (this.items && this.items.length > 1);
				},
				afterClose: function() {
					$('body').removeClass("mfp-zoom-out-cur");
					$(".sidebar").show();
					$.cookie("sidebarAppName",sidebarAppName,{path:"/;SameSite=Lax"});
					$.cookie("sidebarAppPath",sidebarAppPath,{path:"/;SameSite=Lax"});
					showRepoPopup(data.repository);
				}
			}
		});
		$('.screenshot').not($('.caMediaGallery').find('.screenshot')).magnificPopup({
			type:'image',
			closeMarkup: "<span class='mfp-close magnificPopup caButton caButtonLarge caButtonRed'>"+tr("CLOSE")+"</span>",
			closeOnContentClick: true,
			removalDelay: 100,
			mainClass: 'mfp-fade',
			zoom: { enabled: true, duration: 500, easing: 'ease-in-out' }
		});
	});
}

/**
 * Ensure a non-startup sort icon is enabled; if none, reset to server default (`defaultSortOrder` POST).
 */
function checkSortOrder() {
	var sortButton = false;
	$(".sortIcons").each(function() {
		if ($(this).hasClass("enabledIcon") && ( ! $(this).hasClass("startupMore") ) ) {
			sortButton = true;
		}
	});
	if ( !sortButton) {
		$(".sortIcons").removeClass("enabledIcon").removeClass("startupMore");
		post({action:"defaultSortOrder"},function(data) {
			$("#defaultSort").addClass("enabledIcon");
		});
	}
}

/**
 * Enter Docker Hub search mode: disable non-docker categories, hide sort icons, clear section labels, {@link dockerSearch} page 1.
 */
function initDockerSearch() {
	caClearHomeSectionSubtitle();
	data.docker = "searching docker";
	data.section = "";
	data.selected_category = "";
	$(".selectedMenu").removeClass("selectedMenu");
	$(".nonDockerSearch").removeClass("caMenuEnabled").addClass("caMenuDisabled");
	hideSortIcons();
	$(".subCategory").hide();
	caSyncSearchFilterCollapsed();
	caSyncHomeSearchSubtitle();
	dockerSearch(1);
}

/**
 * Query Docker Hub via PHP (`search_dockerhub`) and paint results (supports append for infinite scroll).
 *
 * @param {number|string} pageNumber Hub search page index
 * @param {boolean} [append] Append cards vs replace
 */
function dockerSearch(pageNumber, append) {
	var doAppend = !!append;
	caRestoreCommittedSearchIfDrafted();
	if (searchBoxAwesomplete) searchBoxAwesomplete.close();
	if (!doAppend) scrollToTop();
	$(".selectedMenu").removeClass("selectedMenu");
	$(".nonDockerSearch").removeClass("caMenuEnabled").addClass("caMenuDisabled");
	var filter = $('#searchBox').val();
	var dockerURL = "https://registry.hub.docker.com/search?q=" + filter;
	data.docker = "searching docker";
	$(".dockerSearch").addClass("ca_hide");
	$(".multi_installDiv").hide();
	$(".templateSearch").removeClass("ca_hide");
 // $(".category").html(sprintf("<?tr("DockerHub Search for %s")?>",filter)+" <span id='pageNumber'></span>");
	post({action:'search_dockerhub',filter:filter,page:pageNumber},function(result) {
		data.committedSearchFilter = $.trim(String(filter || ""));
		caSyncHomeSearchSubtitle();
		updateDisplay(result.display_data || result.display, doAppend);
		caSyncSearchFilterCollapsed();
	});
}

/**
 * Convert a Docker Hub image to a CA XML template: optionally run test container (`dockerConvert.php`) or POST `convert_docker` and open Add Container.
 *
 * @param {string} repo Docker repository string
 * @param {string} descB64 Base64-encoded description from the card (wire format for PHP)
 */
function dockerConvert(repo, descB64) {
	/* descB64 is the card's Description as it was rendered, base64-encoded by
	   the server so it survives passing through an onclick attribute string.
	   We forward it as-is — the receiving PHP endpoints (dockerConvert.php and
	   exec.php convert_docker) base64_decode it. Single canonical decode point
	   on the server side keeps the wire contract unambiguous. */
	saveState();
	swal({
		title: "<?tr("Determine configuration?");?>",
		text: '<?tr('Would you like CA to attempt to determine any applicable paths, ports, and variables for the template?  This will entail performing a test installation of the container.  It will be automatically deleted after processing.  The container will not be started.');?>',
		html: true,
		type: 'info',
		showCancelButton: true,
		showConfirmButton: true,
		confirmButtonText: "<?tr('Yes');?>",
		cancelButtonText: "<?tr('No');?>"
	}, function (isConfirm) {
		if ( isConfirm ) {
			$("#sb-nav-close").css("visibility","hidden"); // Because docker install cannot be aborted so why allow window to close
			var url = '/plugins/<?=$plugin?>/scripts/dockerConvert.php?repo=' + encodeURIComponent(repo);
			if (descB64) url += '&description=' + encodeURIComponent(descB64);
			openBox(url,"<?tr('Docker Test Install')?>",600,1100,true);
		} else {
			post({action:'convert_docker',repo:repo,description:descB64},function(result) {
				myCloseAlert();
				templateURL = "/Apps/AddContainer?xmlTemplate=default:" + $.trim(result.xml);
				openNewWindow(templateURL);
			});
		}
	});

}

var caSortMenuObserver = null;
/**
 * Subscribe to DOM mutations on `#sortIconOptions` so the sort dropdown label stays in sync (`caRefreshSortMenu`).
 */
function caInitializeSortMenu() {
	caRefreshSortMenu();
	if (caSortMenuObserver) {
		return;
	}
	var sortContainer = $("#sortIconOptions").get(0);
	if (!sortContainer) {
		return;
	}
	caSortMenuObserver = new MutationObserver(function() {
		caRefreshSortMenu();
	});
	caSortMenuObserver.observe(sortContainer, {
		subtree: true,
		attributes: true,
		attributeFilter: ["class"]
	});
}

/**
 * Update `#sortByButton` label from the active `.sortIcons.enabledIcon` and rebuild its context-menu entries from {@link getSortOpts}.
 */
function caRefreshSortMenu() {
	if (!$("#sortByButton").length) {
		return;
	}
	/* Label is always just "Sort" with a sort glyph supplied by CSS via
	   #sortByButton::before — the previous "Sort By: <selection>" form
	   was redundant with the active highlight already visible in the
	   sort-icons row, and made the button overflow on cramped layouts.
	   Wrapped in .caBtnLabel so the @media (max-width: 767px) icon-only
	   rule in community.applications.responsive.css can hide it on
	   narrow viewports alongside the other top-bar buttons. */
	$("#sortByButton").html("<span class='caBtnLabel'><?tr("Sort");?></span>");
	context.destroy("#sortByButton");
	context.attach("#sortByButton", getSortOpts());
}

/**
 * Build context-menu descriptor objects for each `.sortIcons` row (checkmark + click triggers native sort icon).
 *
 * @returns {Array<object>} Items for `context.attach`
 */
function getSortOpts() {
	var sortOpts = [];
	$(".sortIcons").each(function() {
		var sortOption = this;
		var $sortOption = $(sortOption);
		var sortText = $.trim($sortOption.text());
		var isSelected = $sortOption.hasClass("enabledIcon") && !$sortOption.hasClass("startupMore");
		sortOpts.push({
			icon: isSelected ? "ca_fa-checkmark" : " ",
			text: isSelected ? "<span class='ca_green'>" + sortText + "</span>" : sortText,
			action: function() {
				$(sortOption).trigger("click");
			}
		});
	});
	return sortOpts;
}

/**
 * Background poll: POST `enableActionCentre` to toggle visibility of Action Centre menu entry.
 */
function setupActionCentre() {
	/* Use the post() helper (not raw $.post) so the request carries tabId
	   and matches the rest of CA's request shape. noSpinner keeps this a
	   silent background poll. */
	post({action:'enableActionCentre',noSpinner:true},function(ret) {
		if ( ret.status == "action" ) {
			if ( !$(".actionCentre").is(":visible") ) {
				$(".actionCentre").show();
			}
		} else
			$(".actionCentre").hide();
	});
}

/**
 * Refresh Action Centre visibility then trigger the selected menu (typically after a bulk check-for-updates completes).
 */
function postCheckForUpdates() {
	setupActionCentre();
	$(".selectedMenu").click();
}

/* Virtualization: evict cards far above the viewport into a top-spacer (so
   scroll height stays the same) and restore them from caCardCache.cache when the
   user scrolls back up. Cards are kept in row-aligned chunks because the float
   layout would mis-pack a partial row. */
function caVirtSpacer() {
	var $spacer = $("#templates_content .ca_virtTopSpacer").first();
	if ($spacer.length) return $spacer;
	var $first = $("#templates_content").find(".ca_holder").first();
	if (!$first.length) return $();
	$spacer = $("<div class='ca_virtTopSpacer'></div>").css({
		width: "100%",
		height: "0px",
		flexBasis: "100%"
	});
	$first.before($spacer);
	return $spacer;
}
/**
 * Pixel height of the virtualization top spacer (0 when absent).
 *
 * @returns {number}
 */
function caVirtSpacerHeight() {
	var $s = $("#templates_content .ca_virtTopSpacer").first();
	if (!$s.length) return 0;
	return parseFloat($s[0].style.height) || 0;
}
/**
 * Grow or shrink `#templates_content .ca_virtTopSpacer` height by `deltaPx` (clamped at 0).
 *
 * @param {number} deltaPx Pixel delta (positive adds scroll range for evicted rows)
 */
function caVirtAdjustSpacer(deltaPx) {
	var $s = caVirtSpacer();
	if (!$s.length) return;
	var current = parseFloat($s[0].style.height) || 0;
	var next = Math.max(0, current + deltaPx);
	$s.css("height", next + "px");
}
/**
 * Count how many `.ca_holder` cards share the first row’s `offsetTop` (cards per row for float layout).
 *
 * @param {jQuery} $cards Card collection
 * @returns {number}
 */
function caVirtCardsPerRow($cards) {
	if (!$cards.length) return 0;
	var firstTop = $cards[0].offsetTop;
	for (var i = 1; i < $cards.length; i++) {
		if ($cards[i].offsetTop !== firstTop) return i;
	}
	return $cards.length;
}
/**
 * Vertical distance between the first card in row 0 and the first card in row 1.
 *
 * @param {jQuery} $cards Card collection
 * @param {number} perRow From {@link caVirtCardsPerRow}
 * @returns {number}
 */
function caVirtRowHeight($cards, perRow) {
	if (perRow < 1 || $cards.length <= perRow) return 0;
	return $cards[perRow].offsetTop - $cards[0].offsetTop;
}
/**
 * Evict off-screen card rows into a top spacer or restore from `caCardCache.cache` on upward scroll; may trigger `changePage(1)` on large jumps.
 */
function caVirtUpdate() {
	var mainArea = $(".mainArea")[0];
	if (!mainArea) return;
	/* The home/spotlight view uses .ca_homeTemplates rows (everything already in
	   the DOM, no pagination), not the .ca_templatesDisplay grid we virtualize.
	   Skip eviction/restoration there. */
	if (!$("#templates_content .ca_templatesDisplay").length) return;
	/* When the section explicitly loaded everything (Previous Apps / Action
	   Centre / Installed Apps) we keep the full DOM around so things like
	   Select All can operate on every checkbox at once. */
	if (data.allLoaded) return;
	var $cards = $("#templates_content .ca_templatesDisplay").find(".ca_holder");
	if ($cards.length < 24) return;

	var perRow = caVirtCardsPerRow($cards);
	if (perRow < 1) return;
	var rowHeight = caVirtRowHeight($cards, perRow);
	if (rowHeight <= 0) return;

	var scrollTop = mainArea.scrollTop;
	var clientHeight = mainArea.clientHeight;
	var buffer = clientHeight; // 1 viewport above & below
	var mainTop = mainArea.getBoundingClientRect().top;

	/* If the user just jumped a long way upward (Cmd/Ctrl+Up, Home, End→top,
	   thumb drag, etc.) into the evicted region, the spacer can be many rows
	   tall and incremental restoration would only fill 8 rows per scroll event
	   — leaving them looking at blank space. Detect the jump and reset to a
	   fresh page-1 fetch instead. */
	var prevScrollTop = data._prevScrollTop || 0;
	data._prevScrollTop = scrollTop;
	if (caCardCache.firstInDom > 0 && scrollTop < buffer && (prevScrollTop - scrollTop) > clientHeight * 2) {
		caCardCache.firstInDom = 0;
		caCardCache.cache = [];
		data.loadingMore = false;
		data._prevScrollTop = 0;
		if (typeof changePage === "function") changePage(1);
		return;
	}

	/* EVICT: rows whose bottom is more than 1 viewport above the visible area. */
	var evictAboveY = scrollTop - buffer;
	var rowsToEvict = 0;
	for (var i = 0; i + perRow <= $cards.length; i += perRow) {
		var rowBottom = $cards[i].getBoundingClientRect().bottom - mainTop + scrollTop;
		if (rowBottom >= evictAboveY) break;
		rowsToEvict++;
	}
	var minKeep = 36;
	rowsToEvict = Math.min(rowsToEvict, Math.floor(($cards.length - minKeep) / perRow));
	if (rowsToEvict > 0) {
		var n = rowsToEvict * perRow;
		for (var k = 0; k < n; k++) {
			$cards[k].parentNode.removeChild($cards[k]);
		}
		caCardCache.firstInDom += n;
		caVirtAdjustSpacer(rowsToEvict * rowHeight);
		return;
	}

	/* RESTORE: user has scrolled back into the spacer region. */
	if (caCardCache.firstInDom > 0) {
		var spacerH = caVirtSpacerHeight();
		if (spacerH > 0 && scrollTop < spacerH + buffer) {
			var rowsToRestore = Math.min(
				Math.ceil(((spacerH + buffer) - scrollTop) / rowHeight),
				Math.floor(caCardCache.firstInDom / perRow) || 1
			);
			rowsToRestore = Math.min(rowsToRestore, 8);
			if (rowsToRestore <= 0) return;
			var cardsToRestore = Math.min(rowsToRestore * perRow, caCardCache.firstInDom);
			var html = "";
			for (var j = 0; j < cardsToRestore; j++) {
				var idx = caCardCache.firstInDom - cardsToRestore + j;
				html += caCardCache.cache[idx];
			}
			caCardCache.firstInDom -= cardsToRestore;
			caVirtSpacer().after(html);
			caVirtAdjustSpacer(-(rowsToRestore * rowHeight));
		}
	}
}

/* If the rendered page doesn't fill .mainArea — or only just barely fills it —
   pull the next page automatically. We require at least one card-row's worth
   of overflow past the viewport so there's always a visible "more below" cue
   at the bottom; this also covers the zoom-out edge case where the page goes
   from scrollable to non-scrollable without crossing the trigger. */
function caEnsureScrollable() {
	if (data.loadingMore) return;
	if (!data.nextpage || data.nextpage <= 0) return;
	var el = $(".mainArea")[0];
	if (!el) return;

	var rowHeight = 4;
	var $card = $("#templates_content").find(".ca_holder").first();
	if ($card.length) {
		var rect = $card[0].getBoundingClientRect();
		var style = getComputedStyle($card[0]);
		var rowH = rect.height + (parseFloat(style.marginTop) || 0) + (parseFloat(style.marginBottom) || 0);
		if (rowH > rowHeight) rowHeight = rowH;
	}

	if (el.scrollHeight - el.clientHeight > rowHeight * 2) return;

	data.loadingMore = true;
	var nextPage = data.nextpage;
	if (data.docker) {
		dockerSearch(nextPage, true);
	} else {
		changePage(nextPage, true);
	}
}

/* Infinite scroll: when the user nears the bottom of .mainArea and the most
   recent caRenderPageNavigation said another page exists (via data.nextpage),
   append the next batch of cards. dockerSearch and the regular display path
   share the same pagination state. */
function caInitInfiniteScroll() {
	var virtScheduled = false;
	var triggerNext = function() {
		if (data.loadingMore) return;
		if (!data.nextpage || data.nextpage <= 0) return;
		data.loadingMore = true;
		var nextPage = data.nextpage;
		if (data.docker) {
			dockerSearch(nextPage, true);
		} else {
			changePage(nextPage, true);
		}
	};

	/* CA's own scroll controls (.ca_back_to_top / .ca_move_to_end). dynamix's
	   .back_to_top / .move_to_end are left alone so other plugins keep working;
	   ours operate on whichever pane is currently the user-facing scroller —
	   .sidenav when the sidebar is open, otherwise .mainArea. Visibility is
	   driven from the same scroll events the rest of CA already uses. */
	var $backTop = $(".ca_back_to_top");
	var $moveEnd = $(".ca_move_to_end");
	var caGetActiveScroller = function() {
		var $sidenav = $(".sidenav.sidenavShow");
		if ($sidenav.length) return $sidenav[0];
		return $(".mainArea")[0];
	};
	$backTop.on("click", function(e) {
		e.preventDefault();
		var s = caGetActiveScroller();
		if (s) $(s).stop(true, true).animate({ scrollTop: 0 }, 500);
		return false;
	});
	$moveEnd.on("click", function(e) {
		e.preventDefault();
		var s = caGetActiveScroller();
		if (!s) return false;

		/* Sidebar mode: content is already entirely in the DOM, just scroll
		   to its bottom — no fetch needed (and the Apps grid pagination logic
		   below would be irrelevant anyway). */
		if ($(".sidenav.sidenavShow").length) {
			$(s).stop(true, true).animate({ scrollTop: s.scrollHeight }, 500);
			return false;
		}

		/* Home page (no .ca_templatesDisplay): everything is already in the
		   DOM — just scroll to the bottom of the viewport, no fetch needed. */
		if (!$("#templates_content .ca_templatesDisplay").length) {
			$(s).stop(true, true).animate({ scrollTop: s.scrollHeight }, 500);
			return false;
		}

		var total = parseInt(data.totalApps, 10) || 0;
		if (total <= 0) return false;

		if (data.docker) {
			/* DockerHub API caps each search at 25 results/page — we can't
			   ask for everything in one shot like the Apps grid path. Jump
			   to the last page instead; updateDisplay's structured-replace
			   path sets cardCacheOffset from the server's pageNumber so the
			   "Displaying X - Y of Z" indicator stays correct, and the
			   existing jump-to-top reset in caVirtUpdate handles scroll-up
			   back to page 1 when the user wants it. */
			var dockerPerPage = 25;
			var dockerLastPage = Math.max(1, Math.ceil(total / dockerPerPage));
			dockerSearch(dockerLastPage, false);
			return false;
		}

		/* Apps grid: fetch the entire result set in one request so the user can
		   scroll up freely from the end. Virtualization + content-visibility
		   keep this affordable even for thousands of cards. data.maxPerPage is
		   bumped only for this request and restored once cards are in the DOM. */
		var savedMaxPerPage = data.maxPerPage;
		data.maxPerPage = Math.max(total, 12);
		var scrollToEnd = function() {
			data.maxPerPage = savedMaxPerPage;
			var ma2 = $(".mainArea")[0];
			if (ma2) ma2.scrollTop = ma2.scrollHeight;
		};
		changePage(1, false);
		var attempts = 0;
		var poll = function() {
			if ($.isArray(caCardCache.cache) && caCardCache.cache.length >= total) {
				scrollToEnd();
				return;
			}
			if (++attempts > 60) {
				scrollToEnd();
				return;
			}
			setTimeout(poll, 100);
		};
		setTimeout(poll, 100);
		return false;
	});
	var caUpdateScrollControls = window.caUpdateScrollControls = function() {
		/* Fresh queries each call so a removed/re-added element or a class
		   change still gets picked up. */
		var $bt = $(".ca_back_to_top");
		var $me = $(".ca_move_to_end");
		if (!$bt.length && !$me.length) return;
		var s = caGetActiveScroller();
		if (!s) return;
		var atTop = s.scrollTop <= 0;
		var atBottom = s.scrollTop + s.clientHeight >= s.scrollHeight - 1;
		var canScroll = s.scrollHeight - s.clientHeight > 1;
		var showBack = canScroll && !atTop;
		var showEnd  = canScroll && !atBottom;
		if ($bt.length && ($bt.data("caShown") || false) !== showBack) {
			$bt.data("caShown", showBack);
			$bt.stop(true, true)[showBack ? "fadeIn" : "fadeOut"](500);
		}
		if ($me.length && ($me.data("caShown") || false) !== showEnd) {
			$me.data("caShown", showEnd);
			$me.stop(true, true)[showEnd ? "fadeIn" : "fadeOut"](500);
		}
	};
	/* Initial state: hide both until we know the page actually scrolls.
	   Live updates come from attachOverlay's existing scroll listener (which
	   already covers .mainArea, .sidenav, .menuItems, .ca_homeTemplates), so
	   we don't bind a second scroll handler here. */
	$backTop.hide().data("caShown", false);
	$moveEnd.hide().data("caShown", false);
	caUpdateScrollControls();
	/* Re-check after first paint so the initial values reflect post-layout
	   scroll dimensions, not whatever they are at attach time. */
	requestAnimationFrame(function() { caUpdateScrollControls(); });
	setTimeout(function() { caUpdateScrollControls(); }, 250);

	/* Sidebar open/close changes the active scroller, so recompute when its
	   class list flips between sidenavShow / sidenavHide. */
	(function() {
		var sn = $(".sidenav")[0];
		if (!sn || typeof MutationObserver !== "function") return;
		new MutationObserver(function() { caUpdateScrollControls(); })
			.observe(sn, { attributes: true, attributeFilter: ["class"] });
	})();

	$(".mainArea").on("scroll", function() {
		if (!virtScheduled) {
			virtScheduled = true;
			requestAnimationFrame(function() {
				virtScheduled = false;
				caVirtUpdate();
			});
		}
		caUpdateDisplayCount();
		var el = this;
		var bottomGap = el.scrollHeight - el.clientHeight - el.scrollTop;
		if (bottomGap > 600) return;
		triggerNext();
	});

	/* When the user is parked at the exact scroll bottom, the browser stops
	   firing scroll events on further wheel/touch attempts — so a "scroll past
	   the end" gesture wouldn't pull the next page. Catch that intent directly
	   from the wheel/touch input. */
	$(".mainArea").on("wheel", function(e) {
		var dy = e.originalEvent ? e.originalEvent.deltaY : 0;
		if (dy <= 0) return; // only downward
		var el = this;
		if (el.scrollTop + el.clientHeight >= el.scrollHeight - 2) {
			triggerNext();
		}
	});
	var touchStartY = 0;
	$(".mainArea").on("touchstart", function(e) {
		var t = e.originalEvent && e.originalEvent.touches && e.originalEvent.touches[0];
		touchStartY = t ? t.clientY : 0;
	});
	$(".mainArea").on("touchmove", function(e) {
		var t = e.originalEvent && e.originalEvent.touches && e.originalEvent.touches[0];
		if (!t) return;
		if (touchStartY - t.clientY < 12) return; // upward swipe = scroll down; require modest distance
		var el = this;
		if (el.scrollTop + el.clientHeight >= el.scrollHeight - 2) {
			triggerNext();
		}
	});

	/* Zoom-out / window-resize can leave the page non-scrollable even though
	   more results exist on the server — without a scrollbar the infinite-scroll
	   handler never fires. Re-run caEnsureScrollable on viewport changes so we
	   keep pulling pages until the layout is scrollable again. */
	var resizeTimer = null;
	var onResize = function() {
		if (resizeTimer) clearTimeout(resizeTimer);
		resizeTimer = setTimeout(function() {
			resizeTimer = null;
			caEnsureScrollable();
		}, 150);
	};
	$(window).on("resize", onResize);
	if (window.visualViewport) {
		$(window.visualViewport).on("resize", onResize);
	}
}
$(caInitInfiniteScroll);

</script>
