	var inlineSearchInput = $("#caInlineSearchBox").get(0);
	if (inlineSearchInput && typeof Awesomplete === "function") {
		inlineSearchAwesomplete = new Awesomplete(inlineSearchInput, {
			item: function(text, input) {
				var li = Awesomplete.ITEM(text, input);
				try {
					li.classList.add("caButton");
					li.classList.add("caInlineSuggestion");
				} catch (e) { /* no-op */ }
