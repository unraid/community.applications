		$("#caInlineSearchBox").on("awesomplete-selectcomplete", function() {
			var val = $.trim($(this).val());
			if (val !== "" && typeof doSearch === "function") {
				$("#searchBox").val(val);
				doSearch(false, val);
			}
		});
	}

	// While the Awesomplete dropdown is open, disable other click handlers by toggling a body class.
	$("#searchBox").on("awesomplete-open", function() {
		$("body").addClass("ca_awesomplete_open");
	});
	$("#searchBox").on("awesomplete-close", function() {
		$("body").removeClass("ca_awesomplete_open");
	});

	/* Hook Awesomplete evaluate() so we can call the status() callback after list renders. */
	try {
		var caOrigEvaluate = searchBoxAwesomplete.evaluate && searchBoxAwesomplete.evaluate.bind(searchBoxAwesomplete);
		if (caOrigEvaluate && !searchBoxAwesomplete.__caEvaluateHooked) {
