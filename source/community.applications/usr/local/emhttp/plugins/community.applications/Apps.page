		text: sprintf("<?tr("Are you sure you want to remove %s from the list of previously installed applications?")?>","<span class='ca_italic ca_bold caHighlight'>"+humanName+"</span>")+"<br><font size='0'>"+application+"</font>",
		type: "warning",
