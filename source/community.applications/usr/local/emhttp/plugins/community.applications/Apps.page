		/* Only update the text-bearing child — leaves any sibling controls
		   (eg. the static Abort button baked into the Updating-Applications
		   swal) untouched between ticks. .text() instead of .html() so a
		   progress payload can't inject markup. */
		$(".caDownloadProgressText").text(message);
		if ( message == "" ) {
